<!-- ═══ AI CHATBOT — reframed as live demo ═══ -->
<section id="ask-rodney" class="chat-section rc-fade">
    <p class="section__text__p1 text-center">Live AI Demo</p>
    <h1 class="title text-center">Try the AI Assistant</h1>
    <p class="text-center mb-3" style="font-size:0.9rem;color:rgba(142,207,223,0.55);font-weight:300;">
        This is a live example of AI integration I can build for your business. Ask anything about Rodney's background, skills, or experience.
    </p>

    <div class="chat-container">
        <div id="chat-messages" class="chat-messages" role="log" aria-live="polite"></div>
        <div class="chat-input-container">
            <input type="text" id="chat-input" class="chat-input" placeholder="Ask me anything..." maxlength="500" autocomplete="off" />
            <button type="button" id="chat-send" class="chat-send-btn" aria-label="Send message">
                <span class="chat-send-text">Send</span>
            </button>
        </div>
        <p class="chat-char-count"><span id="chat-char-remaining">500</span> characters remaining</p>
    </div>

    <div class="chat-docs-btn-container">
        <a href="https://github.com/ChefRod88/RodneyPortfolio/blob/main/docs/portfolio_ai_skills_implementation_67024d2c.plan.md"
           target="_blank" rel="noopener noreferrer" class="chat-docs-btn">View Documentation</a>
        <a href="https://github.com/ChefRod88/RodneyPortfolio/blob/main/docs/OPENAI_API_KEY_SETUP.md"
           target="_blank" rel="noopener noreferrer" class="chat-docs-btn">API Key Docs</a>
    </div>

    <div class="chat-transparency-panel">
        <button type="button" class="chat-transparency-toggle" id="chat-transparency-toggle" aria-expanded="false" aria-controls="chat-transparency-content">
            How this AI works
        </button>
        <div id="chat-transparency-content" class="chat-transparency-content" hidden>
            <dl class="chat-transparency-dl">
                <dt>Model</dt><dd>GPT-4o-mini (OpenAI Chat Completions API)</dd>
                <dt>Architecture</dt><dd>ASP.NET Core → OpenAI Chat Completions. Static prompt with resume context.</dd>
                <dt>Data</dt><dd>ResumeContext.txt. No RAG or embeddings.</dd>
                <dt>Safety</dt><dd>Input validation, content filtering, prompt guardrails.</dd>
                <dt>Hosting</dt><dd>Azure Web App, GitHub Actions CI/CD.</dd>
            </dl>
        </div>
    </div>

    <div class="chat-job-match">
        <h3 class="chat-job-match-title">Document Analyzer — Live Demo</h3>
        <p class="chat-job-match-desc">Paste any job description to see AI score and analyze it. This exact capability is available for your business.</p>
        <textarea id="job-match-input" class="chat-job-match-input" placeholder="Paste a job description or any document here..." maxlength="4000" rows="4"></textarea>
        <p class="chat-job-match-char-count"><span id="job-match-char-remaining">4000</span> characters remaining</p>
        <button type="button" id="job-match-analyze" class="chat-job-match-btn">Analyze</button>
        <div id="job-match-result" class="chat-job-match-result" hidden>
            <div class="chat-job-match-score">
                <span class="chat-job-match-score-label">Match Score</span>
                <span id="job-match-score-value" class="chat-job-match-score-value">0</span>
                <span class="chat-job-match-score-pct">%</span>
            </div>
            <div class="chat-job-match-lists">
                <div class="chat-job-match-list"><h4>Skills Aligned</h4><ul id="job-match-skills"></ul></div>
                <div class="chat-job-match-list"><h4>Gaps</h4><ul id="job-match-gaps"></ul></div>
                <div class="chat-job-match-list"><h4>Talking Points</h4><ul id="job-match-talking"></ul></div>
            </div>
        </div>
        <div class="chat-docs-btn-container" style="margin-top:1rem;">
            <a href="https://github.com/ChefRod88/RodneyPortfolio/blob/main/docs/JOB_MATCH_FEATURE.md"
               target="_blank" rel="noopener noreferrer" class="chat-docs-btn">Feature Technical Docs</a>
        </div>
    </div>
</section>

<!-- ═══ QUOTE FORM ═══ -->
<section id="quote" class="rc-fade">
    <p class="section__text__p1">Let's Build</p>
    <h1 class="title">Request a Quote</h1>

    <div class="rc-quote-grid">
        <div class="rc-quote-info">
            <h3 class="rc-quote-info-title">// What happens next</h3>
            <p>Fill out the form and I'll respond within 24 hours with a brief scope summary and a time to connect. No hard sell — just a real conversation about your project.</p>
            <p>Every project starts with a <span style="color:var(--c);">free 30-minute discovery call</span> where we define scope, timeline, and fit.</p>
            <ul class="rc-quote-promises">
                <li>Response within 24 hours</li>
                <li>Free discovery call — no commitment</li>
                <li>Written scope before any work begins</li>
                <li>Fixed-price or milestone billing</li>
                <li>You own 100% of the code</li>
            </ul>
        </div>

        <form id="quoteForm" class="rc-glass rc-quote-form" method="post" action="?handler=Quote" onsubmit="handleQuoteSubmit(event)">
            @Html.AntiForgeryToken()
            <div class="rc-form-row">
                <div class="rc-form-group">
                    <label class="rc-form-label">Your Name *</label>
                    <input type="text" name="Name" class="rc-form-input" placeholder="Jane Smith" required />
                </div>
                <div class="rc-form-group">
                    <label class="rc-form-label">Email *</label>
                    <input type="email" name="Email" class="rc-form-input" placeholder="jane@company.com" required />
                </div>
            </div>
            <div class="rc-form-group">
                <label class="rc-form-label">Company / Organization</label>
                <input type="text" name="Company" class="rc-form-input" placeholder="Acme Corp (optional)" />
            </div>
            <div class="rc-form-group">
                <label class="rc-form-label">Service Needed *</label>
                <select name="ServiceNeeded" class="rc-form-input rc-form-select" required>
                    <option value="" disabled selected>Select a service...</option>
                    <option>Web Application</option>
                    <option>AI Integration</option>
                    <option>API Development</option>
                    <option>Church / Nonprofit Site</option>
                    <option>Deployment / DevOps</option>
                    <option>Technical Support</option>
                    <option>Not sure — need advice</option>
                </select>
            </div>
            <div class="rc-form-group">
                <label class="rc-form-label">Estimated Budget *</label>
                <select name="EstimatedBudget" class="rc-form-input rc-form-select" required>
                    <option value="" disabled selected>Select a budget range...</option>
                    <option>Under $1,000</option>
                    <option>$1,000 – $2,500</option>
                    <option>$2,500 – $5,000</option>
                    <option>$5,000 – $10,000</option>
                    <option>$10,000+</option>
                    <option>Not sure yet</option>
                </select>
            </div>
            <div class="rc-form-group">
                <label class="rc-form-label">Project Description *</label>
