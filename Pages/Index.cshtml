@page
@model IndexModel
@{
    ViewData["Title"] = "Rodney Chery | Custom Software & Healthcare Engineering";
    ViewData["SeoMetadata"] = new RodneyPortfolio.Models.SeoMetadata
    {
        Title = "Rodney Chery | Custom Software & Healthcare Engineering",
        Description = "Enterprise software engineer specializing in custom software development, healthcare solutions, patient portals, AI integration, and ASP.NET Core consulting.",
        Keywords = "Software Engineer, Custom Software Development, Healthcare Software Engineering, Patient Portals, AI Integration, ASP.NET Core, Enterprise Web Applications, Rodney Chery",
        SchemaJson = @"
        {
          ""@context"": ""https://schema.org"",
          ""@type"": ""Person"",
          ""name"": ""Rodney Chery"",
          ""jobTitle"": ""Software Engineer"",
          ""url"": ""https://www.rodneyachery.com"",
          ""sameAs"": [
            ""https://www.linkedin.com/in/rodneyachery/"",
            ""https://github.com/ChefRod88""
          ]
        }"
    };
}

<!-- ═══ HERO ═══ -->
<section id="profile">
    <div class="section__pic-container rc-fade">
        <img src="~/assets/images/149A60A7-E1B9-45FA-A196-804C7DB392C7.webp" alt="Rodney Chery — Software Developer" loading="eager" />
    </div>

    <div class="section__text rc-fade">
        <p class="section__text__p1">Enterprise Software Engineer</p>
        <h1 class="title">Rodney Chery</h1>
        <p class="section__text__p2">I engineer secure, scalable, and intelligent web applications for healthcare and enterprise.</p>

        <div id="socials-container">
            <a href="https://www.linkedin.com/in/rodneyachery/" target="_blank" rel="noopener noreferrer" aria-label="LinkedIn Profile">
                <img src="~/assets/icons/linkedin.svg" alt="" class="icon" />
            </a>
            <a href="https://github.com/ChefRod88/RodneyPortfolio" target="_blank" rel="noopener noreferrer" aria-label="GitHub Profile">
                <img src="~/assets/icons/github.svg" alt="" class="icon" />
            </a>
        </div>

        <div class="rc-status-row">
