@page
@model ErrorModel
@{
    ViewData["Title"] = "System Notice // RC Dev";
}

<div class="error-page rc-fade">

    <div class="error-hero">
        <p class="section__text__p1">System Notice</p>
        <h1 class="title">Something unexpected happened</h1>
        <p class="error-hero-sub">
            We ran into a problem processing your request. The issue has been logged — please try again, or use one of the options below to continue.
        </p>
    </div>

    <div class="error-card rc-glass">
        <p class="error-card-label">// What you can do</p>
        <div class="error-actions">
            <a href="/" class="btn btn-outline-dark error-action-primary">Return Home</a>
            <a href="/#quote" class="btn btn-outline-dark">Get a Quote</a>
            <a href="/Portal" class="btn btn-outline-dark">Client Portal</a>
        </div>

        @if (Model.ShowRequestId)
        {
            <p class="error-ref">
                <span class="error-ref-label">Reference</span>
                <code>@Model.RequestId</code>
            </p>
        }
    </div>

</div>
