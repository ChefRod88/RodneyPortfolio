    </div>

    <!-- SIGNATURE BLOCKS -->
    <div style="margin-top: 50px; display: table; width: 100%;">
        <div style="display: table-row;">
            <div style="display: table-cell; width: 45%; border-top: 1px solid #000; padding-top: 5px;">
                <p><strong>CONTRACTOR: RC DEV LLC</strong></p>
                <p style="margin-top: 10px;">By: Rodney A. Chery</p>
                <p style="margin-top: 5px;">Title: Lead Architect &amp; Member</p>
                <p style="margin-top: 5px;">Date: <span id="pdfDateTextContractor">__________________</span></p>
            </div>
            <div style="display: table-cell; width: 10%;"></div>
            <div style="display: table-cell; width: 45%; border-top: 1px solid #000; padding-top: 5px;">
                <p><strong>CLIENT: <span id="pdfClientCompanyLabel">__________________</span></strong></p>
                <div style="margin-top: 10px; height: 50px;">
                    <img id="pdfSignatureImg" style="max-height: 50px; display: none;" />
                </div>
                <p style="border-top: 1px dashed #777; margin-top: 5px; padding-top: 3px;">By: <span id="pdfClientNameLabel">__________________</span></p>
                <p style="margin-top: 5px;">Date: <span id="pdfClientDateLabel">__________________</span></p>
                <p style="margin-top: 5px; font-size: 9pt; color: #555;">IP Address: <span id="pdfClientIpLabel">__________________</span></p>
