@page
@model RodneyPortfolio.Pages.AgreementModel
@{
    ViewData["Title"] = "Software Services Agreement";
    ViewData["HideMatrix"] = true;
}

<div class="faq-page rc-fade agreement-page-wrapper">
    <div class="faq-hero" style="padding-top: 3rem; padding-bottom: 1.5rem;">
        <p class="section__text__p1">Contract &amp; Compliance</p>
        <h1 class="title">Services Agreement</h1>
        <p class="faq-hero-sub">Please review the agreement terms below, fill in your signing information, and draw your signature. Upon completion, a formal PDF copy will be generated and sent to you and RC DEV LLC.</p>
    </div>

    <!-- THEME TOGGLE BUTTON -->
    <div style="max-width: 900px; width: 100%; margin: 0 auto; padding: 0 1rem; text-align: right; box-sizing: border-box;">
        <button type="button" id="themeToggleBtn" style="background: rgba(255,255,255,0.08); border: 1px solid var(--border); color: var(--white); padding: 0.6rem 1.2rem; font-family: var(--font-mono); font-size: 0.8rem; cursor: pointer; transition: all 0.3s; display: inline-flex; align-items: center; gap: 0.5rem; border-radius: 0;">
            <span id="themeToggleIcon">☀️</span> <span id="themeToggleText">Light Mode</span>
        </button>
    </div>

    <div class="section-container" style="display: flex; flex-direction: column; align-items: center; gap: 2.5rem; max-width: 900px; margin: 0 auto; padding: 1.5rem 1rem 4rem 1rem;">
        
        <!-- INTEGRATED FULL CONTRACT TEXT -->
        <div class="rc-glass contract-text-card" style="width: 100%; padding: 3.5rem 3rem; box-sizing: border-box; border: 1px solid var(--border); background: rgba(2, 12, 20, 0.9); box-shadow: 0 10px 40px rgba(0, 0, 0, 0.65); transition: all 0.3s;">
            <div class="contract-doc-body" style="font-family: var(--font-body); font-size: 0.95rem; line-height: 1.8; color: rgba(142, 207, 223, 0.85); font-weight: 300; letter-spacing: 0.02em; transition: color 0.3s;">
                <h2 class="contract-doc-header" style="color: var(--white); font-family: var(--font-display); font-size: 1.4rem; text-align: center; margin-bottom: 2rem; border-bottom: 1px solid rgba(0, 212, 255, 0.25); padding-bottom: 1rem; transition: all 0.3s;">SOFTWARE DEVELOPMENT SERVICES AGREEMENT</h2>
                
                <p style="margin-bottom: 1.5rem;">This Software Development Services Agreement ("Agreement") is entered into and made effective as of the date of signing, between Contractor: <strong>RC DEV LLC</strong> ("Contractor") and the undersigned <strong>Client</strong> ("Client").</p>
                
                <h3 class="contract-doc-subheader" style="color: var(--c); font-family: var(--font-display); font-size: 1rem; margin-top: 2rem; margin-bottom: 0.5rem; font-weight: 600; transition: color 0.3s;">1. SERVICES</h3>
                <p style="margin-bottom: 1.5rem;">The Contractor agrees to provide software development, web development, consulting, design, deployment, and related technical services as described in the approved project proposal, statement of work, quotation, or written scope document ("Project Scope"). Only work specifically described in the approved Project Scope is included in this Agreement. Any work requested outside the approved Project Scope shall be considered a Change Request and may require additional fees, revised timelines, and written approval before work begins.</p>
                
                <h3 class="contract-doc-subheader" style="color: var(--c); font-family: var(--font-display); font-size: 1rem; margin-top: 2rem; margin-bottom: 0.5rem; font-weight: 600; transition: color 0.3s;">2. FREE DISCOVERY CONSULTATION</h3>
                <p style="margin-bottom: 1.5rem;">The Contractor may provide one complimentary discovery consultation of up to thirty (30) minutes. The discovery consultation is intended solely for discussing project goals, requirements, budget, timeline, and general feasibility. The discovery consultation does not include: Custom software development, Custom coding, Database design, System architecture design, UI/UX design work, Wireframes, Prototypes, Technical specifications, or Project implementation. Any custom planning, architecture, design, or development services beyond the complimentary consultation may require a separate paid engagement.</p>
                
                <h3 class="contract-doc-subheader" style="color: var(--c); font-family: var(--font-display); font-size: 1rem; margin-top: 2rem; margin-bottom: 0.5rem; font-weight: 600; transition: color 0.3s;">3. PROJECT PRICING</h3>
                <p style="margin-bottom: 1.5rem;">All project pricing shall be stated in writing and approved by both parties before work begins. Project pricing may be provided as: Fixed-price project fees, Hourly consulting fees, or Separate change request quotations. No work shall begin until this Agreement is signed and the required deposit has been received.</p>
                
                <h3 class="contract-doc-subheader" style="color: var(--c); font-family: var(--font-display); font-size: 1rem; margin-top: 2rem; margin-bottom: 0.5rem; font-weight: 600; transition: color 0.3s;">4. DEPOSIT REQUIREMENT</h3>
                <p style="margin-bottom: 1.5rem;">A non-refundable deposit equal to fifty percent (50%) of the total project price is required before any work begins. The Contractor shall not reserve project scheduling, begin design work, begin development, planning, implementation, or deployment work until the deposit has been paid in full. The deposit compensates the Contractor for project scheduling, opportunity costs, administrative efforts, planning activities, and initial project execution.</p>
                
                <h3 class="contract-doc-subheader" style="color: var(--c); font-family: var(--font-display); font-size: 1rem; margin-top: 2rem; margin-bottom: 0.5rem; font-weight: 600; transition: color 0.3s;">5. FINAL PAYMENT</h3>
                <p style="margin-bottom: 1.5rem;">The remaining fifty percent (50%) balance shall be due upon substantial completion of the Project. Final payment must be received before final source code transfer, repository ownership transfer, production deployment, delivery of final project assets, or administrative account transfers. Failure to make final payment may result in delayed delivery until payment obligations are satisfied.</p>
                
                <h3 class="contract-doc-subheader" style="color: var(--c); font-family: var(--font-display); font-size: 1rem; margin-top: 2rem; margin-bottom: 0.5rem; font-weight: 600; transition: color 0.3s;">6. CLIENT COMMUNICATION</h3>
                <p style="margin-bottom: 1.5rem;">The Contractor shall provide regular project updates throughout development via Email, Telephone, Video conference, Google Meet, Microsoft Teams, or Written progress reports. Client agrees to provide timely feedback, approvals, content, and decisions necessary to maintain project timelines.</p>
                
                <h3 class="contract-doc-subheader" style="color: var(--c); font-family: var(--font-display); font-size: 1rem; margin-top: 2rem; margin-bottom: 0.5rem; font-weight: 600; transition: color 0.3s;">7. CLIENT RESPONSIBILITIES</h3>
                <p style="margin-bottom: 1.5rem;">The Client agrees to provide accurate project requirements, supply requested content and materials, respond to requests for information promptly, review deliverables in a timely manner, and maintain payment obligations under this Agreement.</p>
                
                <h3 class="contract-doc-subheader" style="color: var(--c); font-family: var(--font-display); font-size: 1rem; margin-top: 2rem; margin-bottom: 0.5rem; font-weight: 600; transition: color 0.3s;">8. PROJECT COMPLETION</h3>
                <p style="margin-bottom: 1.5rem;">A Project shall be considered substantially complete when: The approved scope has been delivered; or the Contractor has completed all agreed deliverables; or the Client approves the completed work; or the Client fails to provide feedback within fourteen (14) calendar days after delivery of the final review version. Upon substantial completion, the final invoice shall become immediately due.</p>
                
                <h3 class="contract-doc-subheader" style="color: var(--c); font-family: var(--font-display); font-size: 1rem; margin-top: 2rem; margin-bottom: 0.5rem; font-weight: 600; transition: color 0.3s;">9. CHANGE REQUESTS</h3>
                <p style="margin-bottom: 1.5rem;">Any request outside the approved Project Scope shall constitute a Change Request. Change Requests may require additional fees, revised schedules, or separate written approval. The Contractor is not obligated to perform Change Request work until approved in writing.</p>
                
                <h3 class="contract-doc-subheader" style="color: var(--c); font-family: var(--font-display); font-size: 1rem; margin-top: 2rem; margin-bottom: 0.5rem; font-weight: 600; transition: color 0.3s;">10. HOSTING AND INFRASTRUCTURE</h3>
                <p style="margin-bottom: 1.5rem;">Unless otherwise stated in writing, hosting fees are separate from development fees. Applications may be deployed to cloud providers including Microsoft Azure, Amazon Web Services (AWS), or Google Cloud Platform (GCP). The Client is responsible for all hosting costs, cloud usage fees, domain registration fees, SSL certificate fees, third-party software subscriptions, and API costs.</p>
                
                <h3 class="contract-doc-subheader" style="color: var(--c); font-family: var(--font-display); font-size: 1rem; margin-top: 2rem; margin-bottom: 0.5rem; font-weight: 600; transition: color 0.3s;">11. OWNERSHIP OF WORK</h3>
                <p style="margin-bottom: 1.5rem;">Upon receipt of full payment: Client shall own the completed source code, project-specific deliverables, and project assets created specifically for the Project. Client shall receive administrative access to repositories and systems under Client ownership. The Client may transfer the Project to another developer, agency, consultant, or internal team at any time after final payment.</p>
                
                <h3 class="contract-doc-subheader" style="color: var(--c); font-family: var(--font-display); font-size: 1rem; margin-top: 2rem; margin-bottom: 0.5rem; font-weight: 600; transition: color 0.3s;">12. CONTRACTOR RIGHTS PRIOR TO FINAL PAYMENT</h3>
                <p style="margin-bottom: 1.5rem;">Until all invoices are paid in full: All source code, development work, and repositories remain Contractor property. Delivery of project assets may be withheld, and ownership transfers only after all payment obligations are fully satisfied.</p>
                
                <h3 class="contract-doc-subheader" style="color: var(--c); font-family: var(--font-display); font-size: 1rem; margin-top: 2rem; margin-bottom: 0.5rem; font-weight: 600; transition: color 0.3s;">13. ONE-YEAR SUPPORT PERIOD</h3>
                <p style="margin-bottom: 1.5rem;">Beginning on the official launch date, the Contractor shall provide one (1) year of support. Included support consists of: Bug fixes, security updates, dependency updates, assistance with infrastructure issues, and minor content updates to existing pages. Support is limited to maintaining the Project as originally delivered.</p>
                
                <h3 class="contract-doc-subheader" style="color: var(--c); font-family: var(--font-display); font-size: 1rem; margin-top: 2rem; margin-bottom: 0.5rem; font-weight: 600; transition: color 0.3s;">14. EXCLUDED SUPPORT SERVICES</h3>
                <p style="margin-bottom: 1.5rem;">The following are not included within support: New pages, new features, new modules, redesign work, branding updates, marketing services, copywriting services, new third-party integrations, or major architectural changes. Such requests shall be treated as new work and quoted separately.</p>
                
                <h3 class="contract-doc-subheader" style="color: var(--c); font-family: var(--font-display); font-size: 1rem; margin-top: 2rem; margin-bottom: 0.5rem; font-weight: 600; transition: color 0.3s;">15. ANNUAL RENEWAL SERVICES</h3>
                <p style="margin-bottom: 1.5rem;">At the end of the initial one-year support period, support services automatically terminate unless renewed. The Client may purchase annual renewal services, which may include ongoing support, security updates, infrastructure management, domain renewal assistance, hosting administration, or technical maintenance. Renewal pricing shall be quoted separately. Failure to renew maintenance services shall not affect the Client's ownership rights.</p>
                
                <h3 class="contract-doc-subheader" style="color: var(--c); font-family: var(--font-display); font-size: 1rem; margin-top: 2rem; margin-bottom: 0.5rem; font-weight: 600; transition: color 0.3s;">16. LIMITATION OF LIABILITY</h3>
                <p style="margin-bottom: 1.5rem;">The Contractor shall not be liable for: Lost profits, lost business opportunities, indirect damages, consequential damages, third-party outages, cloud provider outages, domain registrar outages, or Client misuse of delivered software. Contractor liability shall not exceed the total amount paid by Client under this Agreement.</p>
                
                <h3 class="contract-doc-subheader" style="color: var(--c); font-family: var(--font-display); font-size: 1rem; margin-top: 2rem; margin-bottom: 0.5rem; font-weight: 600; transition: color 0.3s;">17. TERMINATION</h3>
                <p style="margin-bottom: 1.5rem;">Either party may terminate this Agreement in writing. Amounts already paid are non-refundable. Client shall remain responsible for payment for all completed work performed prior to termination.</p>
                
                <h3 class="contract-doc-subheader" style="color: var(--c); font-family: var(--font-display); font-size: 1rem; margin-top: 2rem; margin-bottom: 0.5rem; font-weight: 600; transition: color 0.3s;">18. GOVERNING LAW</h3>
                <p style="margin-bottom: 1.5rem;">This Agreement shall be governed by and construed in accordance with the laws of the State of Florida.</p>
                
                <h3 class="contract-doc-subheader" style="color: var(--c); font-family: var(--font-display); font-size: 1rem; margin-top: 2rem; margin-bottom: 0.5rem; font-weight: 600; transition: color 0.3s;">19. ENTIRE AGREEMENT</h3>
                <p style="margin-bottom: 0.5rem;">This Agreement, together with any approved proposal, statement of work, quotation, or change order, constitutes the entire agreement between the parties. No verbal statements shall modify this Agreement. All modifications must be made in writing and signed by both parties.</p>
            </div>
        </div>

        <!-- SIGNATURE FORM AND FIELDS -->
        <div class="rc-glass contract-form-card" style="width: 100%; padding: 2.5rem 2rem; box-sizing: border-box; transition: all 0.3s;">
            <form id="agreementForm" method="post" style="display: flex; flex-direction: column; gap: 1.8rem;">
                @Html.AntiForgeryToken()
                <input type="hidden" id="clientIpAddress" value="@Model.ClientIp" />
                
                <div class="rc-agreement-grid">
                    <div class="rc-form-group">
                        <label for="clientName" class="form-label" style="display: block; font-family: var(--font-mono); font-size: 0.8rem; color: var(--white); margin-bottom: 0.5rem; text-transform: uppercase; transition: color 0.3s;">Client Name (Signer)</label>
                        <input type="text" id="clientName" name="Input.ClientName" required style="width: 100%; background: rgba(0,0,0,0.4); border: 1px solid var(--border); padding: 0.8rem; color: var(--white); font-family: var(--font-body); border-radius: 0; outline: none; transition: all 0.3s; -webkit-appearance: none;" />
                    </div>
                    <div class="rc-form-group">
                        <label for="clientCompany" class="form-label" style="display: block; font-family: var(--font-mono); font-size: 0.8rem; color: var(--white); margin-bottom: 0.5rem; text-transform: uppercase; transition: color 0.3s;">Company Name</label>
                        <input type="text" id="clientCompany" name="Input.ClientCompany" required style="width: 100%; background: rgba(0,0,0,0.4); border: 1px solid var(--border); padding: 0.8rem; color: var(--white); font-family: var(--font-body); border-radius: 0; outline: none; transition: all 0.3s; -webkit-appearance: none;" />
                    </div>
                </div>

                <div class="rc-form-group">
                    <label for="clientEmail" class="form-label" style="display: block; font-family: var(--font-mono); font-size: 0.8rem; color: var(--white); margin-bottom: 0.5rem; text-transform: uppercase; transition: color 0.3s;">Email Address (For PDF copy)</label>
                    <input type="email" id="clientEmail" name="Input.ClientEmail" required style="width: 100%; background: rgba(0,0,0,0.4); border: 1px solid var(--border); padding: 0.8rem; color: var(--white); font-family: var(--font-body); border-radius: 0; outline: none; transition: all 0.3s; -webkit-appearance: none;" />
                </div>

                <!-- HTML5 SIGNATURE CANVAS -->
                <div class="rc-form-group">
                    <label class="form-label" style="display: block; font-family: var(--font-mono); font-size: 0.8rem; color: var(--white); margin-bottom: 0.5rem; text-transform: uppercase; transition: color 0.3s;">
                        Draw Client Signature Below
                        <span style="color: rgba(142,207,223,0.5); font-family: var(--font-mono); font-size: 0.75rem; text-transform: none; float: right;">Logged IP: @Model.ClientIp</span>
                    </label>
                    <div id="sigWrapper" style="position: relative; width: 100%; background: rgba(0,0,0,0.6); border: 1px solid var(--border); height: 180px; box-sizing: border-box; transition: all 0.3s;">
                        <canvas id="signatureCanvas" style="position: absolute; top:0; left:0; width:100%; height:100%; cursor: crosshair; touch-action: none;"></canvas>
                        <button type="button" id="clearBtn" style="position: absolute; bottom: 10px; right: 10px; background: rgba(255,255,255,0.15); border: 1px solid rgba(255,255,255,0.3); color: var(--white); padding: 0.3rem 0.8rem; font-size: 0.7rem; font-family: var(--font-mono); cursor: pointer; transition: all 0.3s; z-index: 10; border-radius: 0;">Clear Signature</button>
                    </div>
                </div>

                <div id="errorAlert" style="display: none; padding: 1rem; border: 1px solid rgba(255,0,0,0.3); background: rgba(255,0,0,0.05); color: #ff5555; font-family: var(--font-mono); font-size: 0.85rem;"></div>
                <div id="successAlert" style="display: none; padding: 1rem; border: 1px solid rgba(0,255,0,0.3); background: rgba(0,255,0,0.05); color: #00ffaa; font-family: var(--font-mono); font-size: 0.85rem;"></div>

                <button type="button" id="submitBtn" class="btn btn-outline-dark submit-button" style="width: 100%; padding: 1.2rem; font-family: var(--font-display); text-transform: uppercase; font-weight: 600; letter-spacing: 0.15em; background: transparent; transition: all 0.3s; font-size: 0.9rem; border-radius: 0;">Sign &amp; Submit Agreement</button>
            </form>
        </div>
    </div>
</div>

<!-- SPINNER LOADER -->
<div id="loadingOverlay" style="display: none; position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(2, 12, 20, 0.95); z-index: 9999; flex-direction: column; align-items: center; justify-content: center; gap: 1.5rem;">
    <div style="width: 50px; height: 50px; border: 3px solid rgba(0, 212, 255, 0.2); border-top-color: var(--c); border-radius: 50%; animation: spin 1s linear infinite;"></div>
    <div id="loadingText" style="color: var(--white); font-family: var(--font-mono); font-size: 0.9rem; letter-spacing: 0.05em; text-transform: uppercase;">Generating Contract PDF...</div>
</div>

