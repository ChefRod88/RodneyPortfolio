</div>

@section Scripts {
    <!-- HTML2PDF CDN -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/html2pdf.js/0.10.1/html2pdf.bundle.min.js"></script>
    
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            // Theme Toggle logic
            const themeToggleBtn = document.getElementById("themeToggleBtn");
            const themeToggleIcon = document.getElementById("themeToggleIcon");
            const themeToggleText = document.getElementById("themeToggleText");
            const pageWrapper = document.querySelector(".agreement-page-wrapper");
            let isLightMode = false;

            themeToggleBtn.addEventListener("click", function () {
                isLightMode = !isLightMode;
                if (isLightMode) {
                    pageWrapper.classList.add("light-mode");
                    themeToggleIcon.innerText = "🌙";
                    themeToggleText.innerText = "Dark Mode";
                    themeToggleBtn.style.color = "#111827";
                    themeToggleBtn.style.borderColor = "#111827";
                    themeToggleBtn.style.background = "rgba(0,0,0,0.05)";
                } else {
                    pageWrapper.classList.remove("light-mode");
                    themeToggleIcon.innerText = "☀️";
                    themeToggleText.innerText = "Light Mode";
                    themeToggleBtn.style.color = "var(--white)";
                    themeToggleBtn.style.borderColor = "var(--border)";
                    themeToggleBtn.style.background = "rgba(255,255,255,0.08)";
                }
                // Refresh canvas stroke color
                ctx.strokeStyle = isLightMode ? "#000000" : "#00ffaa";
            });

            // Setup canvas signature drawing
            const canvas = document.getElementById("signatureCanvas");
            const ctx = canvas.getContext("2d");
            let isDrawing = false;
            let hasSigned = false;

            let lastWidth = canvas.offsetWidth;
            let lastHeight = canvas.offsetHeight;

            // Scale canvas context for sharp retina screens
            function resizeCanvas() {
                // Prevent iOS scroll address-bar resizing from resetting canvas
                if (canvas.offsetWidth === lastWidth && canvas.offsetHeight === lastHeight && hasSigned) {
                    return;
                }

                lastWidth = canvas.offsetWidth;
                lastHeight = canvas.offsetHeight;

                const ratio = Math.max(window.devicePixelRatio || 1, 1);
                canvas.width = canvas.offsetWidth * ratio;
                canvas.height = canvas.offsetHeight * ratio;
                ctx.scale(ratio, ratio);
                ctx.strokeStyle = isLightMode ? "#000000" : "#00ffaa"; // Dark ink for light mode, neon for dark
                ctx.lineWidth = 2.5;
                ctx.lineCap = "round";
                ctx.lineJoin = "round";
                if (!hasSigned) {
                    ctx.clearRect(0, 0, canvas.width, canvas.height);
                }
            }
            
            // Sizing
            resizeCanvas();
            window.addEventListener("resize", resizeCanvas);

            // Drawing coordinates mapping
            function getCoords(e) {
                const rect = canvas.getBoundingClientRect();
                if (e.touches && e.touches.length > 0) {
                    return {
                        x: e.touches[0].clientX - rect.left,
                        y: e.touches[0].clientY - rect.top
                    };
                }
                return {
                    x: e.clientX - rect.left,
                    y: e.clientY - rect.top
                };
            }

            // Start Drawing
            function startDrawing(e) {
                isDrawing = true;
                hasSigned = true;
                const coords = getCoords(e);
                ctx.beginPath();
                ctx.moveTo(coords.x, coords.y);
                e.preventDefault();
            }

            // Draw Line
            function draw(e) {
                if (!isDrawing) return;
                const coords = getCoords(e);
                ctx.lineTo(coords.x, coords.y);
                ctx.stroke();
                e.preventDefault();
            }

            // Stop Drawing
            function stopDrawing() {
                isDrawing = false;
            }

            // Wire events (Mouse and Touch)
            canvas.addEventListener("mousedown", startDrawing);
            canvas.addEventListener("mousemove", draw);
            canvas.addEventListener("mouseup", stopDrawing);
            canvas.addEventListener("mouseleave", stopDrawing);

            canvas.addEventListener("touchstart", startDrawing, { passive: false });
            canvas.addEventListener("touchmove", draw, { passive: false });
            canvas.addEventListener("touchend", stopDrawing);

            // Clear Button handler
            document.getElementById("clearBtn").addEventListener("click", function () {
                ctx.clearRect(0, 0, canvas.width, canvas.height);
                hasSigned = false;
                document.getElementById("pdfSignatureImg").style.display = "none";
            });

            // Submit Button handler (generates PDF on client, sends to server)
            document.getElementById("submitBtn").addEventListener("click", function (e) {
                e.preventDefault();
                
                const clientName = document.getElementById("clientName").value.trim();
                const clientCompany = document.getElementById("clientCompany").value.trim();
                const clientEmail = document.getElementById("clientEmail").value.trim();
                const clientIp = document.getElementById("clientIpAddress").value;
                const errorAlert = document.getElementById("errorAlert");
                const successAlert = document.getElementById("successAlert");

                errorAlert.style.display = "none";
                successAlert.style.display = "none";

                // Simple validation
                if (!clientName || !clientCompany || !clientEmail) {
                    errorAlert.innerText = "Please fill out your Name, Company, and Email Address.";
                    errorAlert.style.display = "block";
                    return;
                }

                if (!hasSigned) {
                    errorAlert.innerText = "Please sign in the signature pad box before submitting.";
                    errorAlert.style.display = "block";
                    return;
                }

                // Show spinner loading overlay
                const loadingOverlay = document.getElementById("loadingOverlay");
                const loadingText = document.getElementById("loadingText");
                loadingOverlay.style.display = "flex";

                try {
                    // 1) Prepare signature image
                    // Create an temporary canvas to copy drawing with a black stroke (for standard black/white printable PDF)
                    const printCanvas = document.createElement("canvas");
                    printCanvas.width = canvas.width;
                    printCanvas.height = canvas.height;
                    const pCtx = printCanvas.getContext("2d");
                    
                    // Draw original canvas content to printCanvas (matches ratios)
                    pCtx.drawImage(canvas, 0, 0);
                    
                    // Convert all non-transparent drawing pixels to solid black (#000000) using source-in!
                    pCtx.globalCompositeOperation = 'source-in';
                    pCtx.fillStyle = '#000000';
                    pCtx.fillRect(0, 0, printCanvas.width, printCanvas.height);
                    
                    const signatureDataUrl = printCanvas.toDataURL("image/png");

                    // 2) Populate PDF template
                    const todayStr = new Date().toLocaleDateString("en-US", { year: 'numeric', month: 'long', day: 'numeric' });
                    document.getElementById("pdfDateText").innerText = todayStr;
                    document.getElementById("pdfDateTextContractor").innerText = todayStr;
                    document.getElementById("pdfClientCompanyText").innerText = clientCompany;
                    document.getElementById("pdfClientNameText").innerText = clientName;
                    
                    document.getElementById("pdfClientCompanyLabel").innerText = clientCompany;
                    document.getElementById("pdfClientNameLabel").innerText = clientName;
                    document.getElementById("pdfClientDateLabel").innerText = todayStr;
                    document.getElementById("pdfClientIpLabel").innerText = clientIp;

                    const pdfSigImg = document.getElementById("pdfSignatureImg");
                    
                    // Generate PDF ONLY after the signature image has fully loaded in the DOM (prevents race condition / missing images)
                    pdfSigImg.onload = function() {
                        loadingText.innerText = "Formatting PDF Document...";
                        const pdfElement = document.getElementById("printableContract");
                        
                        const pdfOptions = {
                            margin:       [0.5, 0.5, 0.5, 0.5],
                            filename:     `Services_Agreement_${clientCompany.replace(/\s+/g, '_')}.pdf`,
                            image:        { type: 'jpeg', quality: 0.95 },
                            html2canvas:  { scale: 2, useCORS: true, logging: false },
                            jsPDF:        { unit: 'in', format: 'letter', orientation: 'portrait' }
                        };

                        html2pdf().from(pdfElement).set(pdfOptions).outputPdf('datauristring').then(async function (pdfDataUri) {
                            try {
                                const pdfBase64 = pdfDataUri.split(',')[1];

                                // 4) POST PDF base64 and details to Razor Page
                                loadingText.innerText = "Transmitting to Server...";
                                const formData = new FormData();
                                formData.append("Input.ClientName", clientName);
                                formData.append("Input.ClientCompany", clientCompany);
                                formData.append("Input.ClientEmail", clientEmail);
                                formData.append("Input.ClientIp", clientIp);
                                formData.append("Input.PdfBase64", pdfBase64);

                                const verificationToken = document.querySelector('input[name="__RequestVerificationToken"]').value;

                                const response = await fetch("?handler=Sign", {
                                    method: "POST",
                                    headers: {
                                        "RequestVerificationToken": verificationToken
                                    },
                                    body: formData
                                });

                                const result = await response.json();
                                loadingOverlay.style.display = "none";

                                if (result.success) {
                                    successAlert.innerText = result.message;
                                    successAlert.style.display = "block";
                                    document.getElementById("agreementForm").reset();
                                    ctx.clearRect(0, 0, canvas.width, canvas.height);
                                    hasSigned = false;
                                    pdfSigImg.style.display = "none";
                                } else {
                                    errorAlert.innerText = result.message;
                                    errorAlert.style.display = "block";
                                }
                            } catch (postErr) {
                                console.error("Transmission error:", postErr);
                                loadingOverlay.style.display = "none";
                                errorAlert.innerText = "Connection lost. Failed to send signed contract to server.";
                                errorAlert.style.display = "block";
                            }
                        }).catch(function (pdfErr) {
                            console.error("PDF Engine error:", pdfErr);
                            loadingOverlay.style.display = "none";
                            errorAlert.innerText = "PDF Generation failed. Please clear your signature, draw again, and retry.";
                            errorAlert.style.display = "block";
                        });
                    };

                    pdfSigImg.onerror = function() {
                        loadingOverlay.style.display = "none";
                        errorAlert.innerText = "Failed to render signature format image. Please retry.";
                        errorAlert.style.display = "block";
                    };

                    pdfSigImg.src = signatureDataUrl;
                    pdfSigImg.style.display = "block";
                } catch (err) {
                    console.error("General submission error: ", err);
                    loadingOverlay.style.display = "none";
                    errorAlert.innerText = "An unexpected error occurred during submission. Please try again.";
                    errorAlert.style.display = "block";
                }
            });
        });
    </script>
    
