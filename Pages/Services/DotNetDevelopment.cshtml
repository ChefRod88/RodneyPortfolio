@page
@{
    ViewData["Title"] = "ASP.NET Core Development | Rodney Chery";
    ViewData["SeoMetadata"] = new RodneyPortfolio.Models.SeoMetadata
    {
        Title = "ASP.NET Core Development | Rodney Chery",
        Description = "Expert ASP.NET Core and .NET 10 development services. Build high-performance, cross-platform enterprise web applications and APIs.",
        Keywords = "ASP.NET Core, .NET Development, C# Developer, Enterprise Backend, .NET 10, Web API",
        SchemaJson = @"
        {
          ""@context"": ""https://schema.org"",
          ""@type"": ""Service"",
          ""name"": ""ASP.NET Core Development"",
          ""provider"": {
            ""@type"": ""Person"",
            ""name"": ""Rodney Chery""
          },
          ""description"": ""Expert ASP.NET Core and .NET development services for high-performance enterprise web applications.""
        }"
    };
}

<div class="service-page rc-fade">
    <div class="faq-hero">
        <p class="section__text__p1">Backend Engineering</p>
        <h1 class="title">ASP.NET Core Development</h1>
        <p class="faq-hero-sub">Leveraging the power and performance of Microsoft's modern web framework to build scalable enterprise solutions.</p>
    </div>

    <div class="section-container" style="max-width: 1000px; margin: 0 auto; padding: 2rem 1rem;">
        <div class="text-container">
            <h2>The Foundation for Enterprise Scale</h2>
            <p>
                ASP.NET Core is the premier framework for building modern, cloud-optimized, and high-performance web applications. With deep expertise in C# and the .NET ecosystem, I architect solutions that are robust, secure, and maintainable.
            </p>
            
            <h3 style="margin-top: 2rem; color: var(--c);">.NET Expertise</h3>
            <ul>
                <li><strong>Web API Development:</strong> RESTful and GraphQL APIs built with minimal APIs or MVC controllers, featuring built-in Swagger/OpenAPI documentation.</li>
                <li><strong>Entity Framework Core:</strong> High-performance ORM integration with SQL Server, PostgreSQL, and CosmosDB, utilizing optimized queries and migrations.</li>
                <li><strong>Identity & Security:</strong> Implementing ASP.NET Core Identity, OAuth2, OpenID Connect, and Role-Based Access Control (RBAC).</li>
                <li><strong>Clean Architecture:</strong> Structuring solutions with Domain-Driven Design (DDD) principles, MediatR (CQRS), and robust Dependency Injection.</li>
            </ul>

            <div class="rc-cta-box rc-glass" style="margin-top: 3rem; padding: 2rem; text-align: center;">
                <h3>Need a senior .NET engineer for your project?</h3>
                <a href="/#quote" class="btn btn-outline-dark" style="margin-top: 1rem;">Contact Me</a>
            </div>
        </div>
    </div>
</div>
