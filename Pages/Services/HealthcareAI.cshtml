    ViewData["Title"] = "Healthcare AI Integration | Rodney Chery";
    ViewData["SeoMetadata"] = new RodneyPortfolio.Models.SeoMetadata
    {
        Title = "Healthcare AI Integration | Rodney Chery",
        Description = "Integrating intelligent capabilities into healthcare systems. RAG pipelines, intelligent document processing, and AI assistants for medical applications.",
        Keywords = "Healthcare AI, Generative AI in Healthcare, Medical AI Integration, RAG Pipelines, Intelligent Document Processing",
        SchemaJson = @"
        {
          ""@context"": ""https://schema.org"",
          ""@type"": ""Service"",
          ""name"": ""Healthcare AI Integration"",
          ""provider"": {
            ""@type"": ""Person"",
            ""name"": ""Rodney Chery""
          },
          ""description"": ""Integrating intelligent AI capabilities into healthcare systems, including RAG pipelines and intelligent document processing.""
        }"
