@page
@{
    ViewData["Title"] = "Patient Portal Development | Rodney Chery";
    ViewData["SeoMetadata"] = new RodneyPortfolio.Models.SeoMetadata
    {
        Title = "Patient Portal Development | Rodney Chery",
        Description = "Custom patient portal development for healthcare practices. Improve patient engagement, scheduling, and billing with secure web applications.",
        Keywords = "Patient Portal Development, Healthcare Portals, Patient Engagement Software, Custom Medical Software, Secure Health Portals",
        SchemaJson = @"
        {
          ""@context"": ""https://schema.org"",
          ""@type"": ""Service"",
          ""name"": ""Patient Portal Development"",
          ""provider"": {
            ""@type"": ""Person"",
            ""name"": ""Rodney Chery""
          },
          ""description"": ""Custom patient portal development for healthcare practices to improve patient engagement.""
        }"
    };
}

<div class="service-page rc-fade">
    <div class="faq-hero">
        <p class="section__text__p1">Healthcare Solutions</p>
        <h1 class="title">Patient Portal Development</h1>
        <p class="faq-hero-sub">Empower your patients with secure, accessible, and intuitive digital healthcare experiences.</p>
    </div>

    <div class="section-container" style="max-width: 1000px; margin: 0 auto; padding: 2rem 1rem;">
        <div class="text-container">
            <h2>Transforming Patient Engagement</h2>
            <p>
                A well-designed patient portal is critical for modern medical practices. It reduces administrative burden, improves patient satisfaction, and ensures secure communication of sensitive health information.
            </p>
            
            <h3 style="margin-top: 2rem; color: var(--c);">Features We Build</h3>
            <ul>
                <li><strong>Secure Messaging:</strong> Encrypted, HIPAA-compliant communication channels between patients and providers.</li>
                <li><strong>Online Scheduling:</strong> Real-time appointment booking integrated with your practice management software.</li>
                <li><strong>Lab Results & Records:</strong> Secure access to test results, visit summaries, and medical history.</li>
                <li><strong>Billing & Payments:</strong> PCI-compliant payment gateways for easy online bill pay and invoice management.</li>
                <li><strong>Accessibility First:</strong> WCAG AA compliant interfaces ensuring all patients, regardless of ability, can manage their health.</li>
            </ul>

            <div class="rc-cta-box rc-glass" style="margin-top: 3rem; padding: 2rem; text-align: center;">
                <h3>Need a custom portal for your practice?</h3>
                <a href="/#quote" class="btn btn-outline-dark" style="margin-top: 1rem;">Request a Consultation</a>
            </div>
        </div>
    </div>
</div>
