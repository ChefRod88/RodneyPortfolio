@page "{slug}"
@model RodneyPortfolio.Pages.Articles.DetailModel
@{
    Layout = "_Layout";
}

@if (Model.Article == null)
{
    <section class="rc-fade" style="padding-top:120px; min-height:60vh;">
        <div class="container text-center">
            <h1>Article Not Found</h1>
            <p>The article you are looking for does not exist or has been removed.</p>
            <a href="/Articles" class="btn btn-outline-info">Back to Articles</a>
        </div>
    </section>
}
else
{
    <article class="rc-fade" style="padding-top:120px; max-width:800px; margin:0 auto; padding-bottom:100px;">
        <div class="container">
            @if (!string.IsNullOrEmpty(Model.Article.HeaderImageUrl))
            {
                <img src="@Model.Article.HeaderImageUrl" alt="@Model.Article.Title" class="img-fluid rounded mb-4" />
            }
            <h1 style="color:var(--c); font-family:var(--font-display); margin-bottom:0.5rem;">@Model.Article.Title</h1>
            <div class="mb-4" style="font-size:0.9rem; color:rgba(255,255,255,0.6);">
                Published on @Model.Article.DatePublished.ToString("MMMM dd, yyyy")
                @if (Model.Article.DateModified.HasValue)
                {
                    <span style="margin-left:1rem;">(Updated: @Model.Article.DateModified.Value.ToString("MMM dd, yyyy"))</span>
                }
            </div>
            
            <div class="rc-tags mb-5">
                @foreach(var tag in Model.Article.Tags)
                {
                    <span class="rc-tag">@tag</span>
                }
            </div>

            <div class="article-content" style="line-height:1.8; font-size:1.05rem;">
                @Html.Raw(Model.Article.ContentHtml)
            </div>
        </div>
    </article>
}
