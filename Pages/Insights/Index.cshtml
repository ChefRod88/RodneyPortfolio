@page
@model RodneyPortfolio.Pages.Insights.IndexModel
@{
    ViewData["Title"] = "Insights & Articles | Rodney Chery";
    ViewData["SeoMetadata"] = new RodneyPortfolio.Models.SeoMetadata
    {
        Title = "Insights & Articles | Rodney Chery",
        Description = "Technical articles, engineering guides, and thoughts on healthcare software development, AI integration, and ASP.NET Core.",
        Keywords = "Software Engineering Blog, Healthcare Tech Articles, ASP.NET Core Guides, AI Integration Tutorials"
    };
}

<div class="insights-page rc-fade">
    <div class="faq-hero">
        <p class="section__text__p1">Knowledge Base</p>
        <h1 class="title">Engineering Insights</h1>
        <p class="faq-hero-sub">Technical guides, architectural patterns, and thoughts on building scalable software.</p>
    </div>

    <div class="section-container" style="max-width: 1000px; margin: 0 auto; padding: 2rem 1rem;">
        @if (Model.Articles.Any())
        {
            <div class="rc-grid" style="display: grid; grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); gap: 2rem;">
                @foreach (var article in Model.Articles)
                {
                    <div class="rc-card rc-glass" style="padding: 1.5rem; display: flex; flex-direction: column;">
                        <span style="font-size: 0.8rem; color: var(--c); font-family: var(--font-mono);">
                            @article.PublishedDate.ToString("MMMM dd, yyyy") // @article.ReadingTimeMinutes min read
                        </span>
                        <h3 style="margin: 1rem 0; font-size: 1.3rem;">
                            <a href="/Insights/Article/@article.Slug" style="color: var(--text); text-decoration: none;">@article.Title</a>
                        </h3>
                        <p style="font-size: 0.95rem; opacity: 0.8; flex-grow: 1;">@article.Description</p>
                        <div style="margin-top: 1.5rem;">
                            <a href="/Insights/Article/@article.Slug" class="btn btn-outline-dark" style="width: 100%; text-align: center;">Read Article</a>
                        </div>
                    </div>
                }
            </div>
        }
        else
        {
            <div class="text-center rc-glass" style="padding: 3rem;">
                <p>No articles published yet. Check back soon for technical guides and insights.</p>
            </div>
        }
    </div>
</div>
