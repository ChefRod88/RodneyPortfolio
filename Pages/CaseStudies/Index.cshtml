@page
@model RodneyPortfolio.Pages.CaseStudies.IndexModel
@{
    ViewData["Title"] = "Case Studies | Rodney Chery";
    ViewData["SeoMetadata"] = new RodneyPortfolio.Models.SeoMetadata
    {
        Title = "Enterprise Case Studies | Rodney Chery",
        Description = "In-depth case studies of enterprise software, healthcare applications, and AI integrations engineered by Rodney Chery.",
        Keywords = "Software Engineering Case Studies, Healthcare Software Portfolio, ASP.NET Core Projects"
    };
}

<div class="insights-page rc-fade">
    <div class="faq-hero">
        <p class="section__text__p1">Portfolio</p>
        <h1 class="title">Case Studies</h1>
        <p class="faq-hero-sub">Deep dives into the architecture, challenges, and solutions of my enterprise projects.</p>
    </div>

    <div class="section-container" style="max-width: 1000px; margin: 0 auto; padding: 2rem 1rem;">
        @if (Model.CaseStudies.Any())
        {
            <div class="rc-grid" style="display: grid; grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); gap: 2rem;">
                @foreach (var article in Model.CaseStudies)
                {
                    <div class="rc-card rc-glass" style="padding: 1.5rem; display: flex; flex-direction: column;">
                        <span style="font-size: 0.8rem; color: var(--c); font-family: var(--font-mono);">
                            @article.PublishedDate.ToString("MMMM yyyy")
                        </span>
                        <h3 style="margin: 1rem 0; font-size: 1.3rem;">
                            <a href="/CaseStudies/Detail/@article.Slug" style="color: var(--text); text-decoration: none;">@article.Title</a>
                        </h3>
                        <p style="font-size: 0.95rem; opacity: 0.8; flex-grow: 1;">@article.Description</p>
                        <div style="margin-top: 1.5rem;">
                            <a href="/CaseStudies/Detail/@article.Slug" class="btn btn-outline-dark" style="width: 100%; text-align: center;">Read Case Study</a>
                        </div>
                    </div>
                }
            </div>
        }
        else
        {
            <div class="text-center rc-glass" style="padding: 3rem;">
                <p>Detailed case studies are currently being migrated to this format. Check out the <a href="/Projects" style="color:var(--c)">Projects Directory</a> in the meantime.</p>
            </div>
        }
    </div>
</div>
