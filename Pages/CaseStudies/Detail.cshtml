@page "{slug}"
@model RodneyPortfolio.Pages.CaseStudies.DetailModel
@{
    if (Model.CaseStudy != null)
    {
        ViewData["Title"] = $"{Model.CaseStudy.Title} | Rodney Chery";
        ViewData["SeoMetadata"] = new RodneyPortfolio.Models.SeoMetadata
        {
            Title = $"{Model.CaseStudy.Title} | Case Study",
            Description = Model.CaseStudy.Description,
            Keywords = string.Join(", ", Model.CaseStudy.Tags),
            Author = Model.CaseStudy.Author,
            PublishedDate = Model.CaseStudy.PublishedDate.ToString("yyyy-MM-ddTHH:mm:ssZ"),
            OpenGraphType = "article",
            SchemaJson = string.Format(@"
            {{
              ""@context"": ""https://schema.org"",
              ""@type"": ""Article"",
              ""headline"": ""{0}"",
              ""description"": ""{1}"",
              ""author"": {{
                ""@type"": ""Person"",
                ""name"": ""{2}""
              }},
              ""datePublished"": ""{3}"",
              ""publisher"": {{
                ""@type"": ""Organization"",
                ""name"": ""Rodney Chery Software Engineering"",
                ""logo"": {{
                  ""@type"": ""ImageObject"",
                  ""url"": ""https://www.rodneyachery.com/assets/images/icon-192.webp""
                }}
              }}
            }}", Model.CaseStudy.Title, Model.CaseStudy.Description, Model.CaseStudy.Author, Model.CaseStudy.PublishedDate.ToString("yyyy-MM-dd"))
        };
    }
}

@if (Model.CaseStudy != null)
{
    <div class="article-page rc-fade">
        <div class="faq-hero" style="padding-bottom: 2rem;">
            <p class="section__text__p1">
                <a href="/CaseStudies/Index" style="color: var(--c); text-decoration: none;">&larr; Back to Case Studies</a>
            </p>
            <h1 class="title" style="margin-top: 1rem;">@Model.CaseStudy.Title</h1>
            <div style="font-family: var(--font-mono); font-size: 0.9rem; margin-top: 1rem; color: var(--text); opacity: 0.8;">
                @Model.CaseStudy.PublishedDate.ToString("MMMM yyyy") 
                <span style="margin: 0 10px; color: var(--c);">//</span> 
                @Model.CaseStudy.ReadingTimeMinutes min read
            </div>
        </div>

        <div class="section-container" style="max-width: 800px; margin: 0 auto; padding: 2rem 1rem;">
            <article class="markdown-content" style="font-size: 1.1rem; line-height: 1.8;">
                @Html.Raw(Model.CaseStudy.HtmlContent)
            </article>

            <div class="rc-cta-box rc-glass" style="margin-top: 4rem; padding: 2rem; text-align: center;">
                <h3>Need a similar solution for your enterprise?</h3>
                <a href="/#quote" class="btn btn-outline-dark" style="margin-top: 1rem;">Let's Talk</a>
            </div>
        </div>
    </div>
}
else
{
    <div class="text-center" style="padding: 5rem 1rem;">
        <h1>Case Study Not Found</h1>
        <p>The case study you are looking for does not exist or has been moved.</p>
        <a href="/CaseStudies/Index" class="btn btn-outline-dark">Return to Case Studies</a>
    </div>
}

<style>
    .markdown-content h1, .markdown-content h2, .markdown-content h3 {
        color: var(--c);
        font-family: var(--font-display);
        margin-top: 2.5rem;
        margin-bottom: 1rem;
    }
    .markdown-content h2 { font-size: 2rem; }
    .markdown-content h3 { font-size: 1.5rem; }
    .markdown-content p { margin-bottom: 1.5rem; }
    .markdown-content ul, .markdown-content ol {
        margin-bottom: 1.5rem;
        padding-left: 2rem;
    }
    .markdown-content li { margin-bottom: 0.5rem; }
    .markdown-content pre {
        background-color: rgba(2, 12, 20, 0.8);
        border: 1px solid rgba(142, 207, 223, 0.2);
        padding: 1rem;
        border-radius: 4px;
        overflow-x: auto;
        margin-bottom: 1.5rem;
    }
    .markdown-content code {
        font-family: var(--font-mono);
        color: #00ff88;
        font-size: 0.9em;
    }
    .markdown-content blockquote {
        border-left: 4px solid var(--c);
        padding-left: 1rem;
        margin-left: 0;
        color: rgba(255, 255, 255, 0.8);
        font-style: italic;
    }
    .markdown-content a {
        color: var(--c);
        text-decoration: underline;
    }
    .markdown-content img {
        max-width: 100%;
        height: auto;
        border-radius: 4px;
        margin: 1.5rem 0;
        border: 1px solid rgba(142, 207, 223, 0.2);
    }
</style>
