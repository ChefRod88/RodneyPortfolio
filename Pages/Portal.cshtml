@page
@model RodneyPortfolio.Pages.Portal.PortalModel
@{
    ViewData["Title"] = "Client Portal";
    Layout = "_Layout";
}

<div class="portal-landing rc-fade">

    <!-- HERO -->
    <div class="portal-hero">
        <div class="portal-hero-badge">// Secure Client Access</div>
        <h1 class="title">RC Dev Portal</h1>
        <p class="portal-hero-sub">Manage your invoices, track payments, and connect with support — all in one place.</p>
    </div>

    <!-- TWO BUTTONS -->
    <div class="portal-entry-grid rc-fade">

        <div class="portal-entry-card rc-glass portal-card-register">
            <div class="portal-entry-icon">⬡</div>
            <div class="portal-entry-label">// New Client</div>
            <h2 class="portal-entry-title">Register</h2>
            <p class="portal-entry-desc">Create your secure RC Dev client account. Provide your business details and choose your service tier to get started.</p>
            <ul class="portal-entry-features">
                <li>Secure email verification</li>
                <li>Invoice &amp; payment access</li>
                <li>Direct support channel</li>
            </ul>
            <a href="/Portal/Register" class="btn btn-outline-dark portal-btn-primary">Create Account →</a>
        </div>

        <div class="portal-entry-card rc-glass portal-card-login">
            <div class="portal-entry-icon">◈</div>
            <div class="portal-entry-label">// Existing Client</div>
            <h2 class="portal-entry-title">Sign In</h2>
            <p class="portal-entry-desc">Access your dashboard to view open invoices, payment history, your service tier, and submit support requests.</p>
            <ul class="portal-entry-features">
                <li>One-time email code</li>
                <li>No password needed</li>
                <li>Session expires in 24 hrs</li>
            </ul>
            <a href="/Portal/Login" class="btn btn-outline-dark portal-btn-ghost">Sign In →</a>
        </div>

    </div>

    <!-- SECURITY CALLOUT -->
    <div class="portal-security rc-glass rc-fade">
        <span class="portal-security-icon">🔒</span>
        <div>
            <div class="portal-security-title">// Enterprise-Grade Security</div>
            <p class="portal-security-text">All portal access is protected by email-based multi-factor authentication. No passwords stored. Sessions expire automatically. Your data never leaves the RC Dev secure environment.</p>
        </div>
    </div>

</div>

<style>
.portal-landing { max-width: 860px; margin: 0 auto; padding: 4rem 3rem 6rem; }
.portal-hero { text-align: center; padding: 3rem 0 3rem; }
.portal-hero-badge { font-family: var(--font-mono); font-size: 0.6rem; color: var(--c); letter-spacing: 0.25em; text-transform: uppercase; margin-bottom: 1rem; }
.portal-hero-sub { font-size: 1.05rem; color: rgba(142,207,223,0.55); font-weight: 300; font-family: var(--font-body); max-width: 520px; margin: 0 auto; line-height: 1.8; }

.portal-entry-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 1.5rem; margin-bottom: 2rem; }
.portal-entry-card { padding: 2.5rem 2rem; display: flex; flex-direction: column; gap: 0.8rem; }
.portal-card-register { border-color: rgba(0,212,255,0.25) !important; }
.portal-card-login { border-color: rgba(142,207,223,0.12) !important; }
.portal-entry-icon { font-size: 2rem; color: var(--c); line-height: 1; opacity: 0.6; }
.portal-entry-label { font-family: var(--font-mono); font-size: 0.58rem; color: rgba(0,212,255,0.4); letter-spacing: 0.2em; text-transform: uppercase; }
.portal-entry-title { font-family: var(--font-display); font-size: 1.6rem; font-weight: 700; color: var(--white); letter-spacing: 0.06em; margin: 0; }
.portal-entry-desc { font-family: var(--font-body); font-size: 0.92rem; line-height: 1.78; color: rgba(142,207,223,0.58); font-weight: 300; flex: 1; }
.portal-entry-features { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 0.35rem; }
.portal-entry-features li { font-family: var(--font-mono); font-size: 0.62rem; color: rgba(142,207,223,0.45); letter-spacing: 0.08em; padding-left: 1rem; position: relative; }
.portal-entry-features li::before { content: '›'; position: absolute; left: 0; color: var(--c); }
.portal-btn-primary { margin-top: 0.5rem; align-self: flex-start; }
.portal-btn-ghost { margin-top: 0.5rem; align-self: flex-start; background: transparent !important; border-color: rgba(0,212,255,0.2) !important; color: rgba(142,207,223,0.55) !important; }
.portal-btn-ghost:hover { background: rgba(0,212,255,0.06) !important; color: var(--c) !important; }

.portal-security { display: flex; gap: 1.2rem; padding: 1.5rem 2rem; align-items: flex-start; }
.portal-security-icon { font-size: 1.4rem; flex-shrink: 0; }
.portal-security-title { font-family: var(--font-mono); font-size: 0.58rem; color: var(--c); letter-spacing: 0.2em; text-transform: uppercase; margin-bottom: 0.4rem; }
.portal-security-text { font-family: var(--font-body); font-size: 0.88rem; line-height: 1.78; color: rgba(142,207,223,0.5); font-weight: 300; margin: 0; }

@@media (max-width: 640px) {
    .portal-landing { padding: 3rem 1.5rem 5rem; }
    .portal-entry-grid { grid-template-columns: 1fr; }
}
</style>