@page "/Portal/Login"
@model RodneyPortfolio.Pages.Portal.LoginModel
@{
    ViewData["Title"] = "Sign In -- RC Dev Portal";
    Layout = "_Layout";
}

<div class="portal-form-page rc-fade">
    <div class="portal-form-hero">
        <a href="/Portal" class="portal-back">&#8249; Back to Portal</a>
        <div class="portal-hero-badge">// Client Sign In</div>
        <h1 class="title">Welcome Back</h1>
        <p class="portal-hero-sub">Enter your email address. We will send a 6-digit code to verify your identity.</p>
    </div>

    @if (!string.IsNullOrEmpty(Model.ErrorMessage))
    {
        <div class="portal-alert portal-alert-error rc-glass">&#9888; @Model.ErrorMessage</div>
    }

    <div class="portal-form-card rc-glass rc-fade" style="max-width:460px;margin:0 auto">
        <form method="post" asp-page-handler="Login" class="portal-form">
            @Html.AntiForgeryToken()
            <div class="portal-form-section">
                <div class="portal-form-section-label">// Enter your account email</div>
                <div class="portal-field portal-field-full">
                    <label class="portal-label">Email Address *</label>
                    <input asp-for="Input.Email" class="portal-input" placeholder="you@company.com" autofocus />
                    <span asp-validation-for="Input.Email" class="portal-field-error"></span>
                </div>
            </div>
            <button type="submit" class="btn btn-outline-dark portal-submit-btn">Send Code &rarr;</button>
        </form>
    </div>
    <p class="portal-switch-link">New client? <a href="/Portal/Register" class="faq-link">Create an account &rarr;</a></p>
</div>
