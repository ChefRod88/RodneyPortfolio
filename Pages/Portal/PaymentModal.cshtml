@* _PaymentModal.cshtml — Drop into Pages/Portal/ *@
@* Requires: Stripe.js loaded in _Layout.cshtml (see StripeScriptSnippet.txt) *@
<link rel="stylesheet" href="~/css/invoice-payment-modal.css" asp-append-version="true" />

<div id="paymentModal" class="pm-overlay" style="display:none;">
    <div class="pm-container">
        <!-- Header -->
        <div class="pm-header">
            <div class="pm-header-left">
                <div class="pm-icon">⚡</div>
                <div>
                    <div class="pm-title">Complete Payment</div>
                    <div class="pm-subtitle" id="pm-invoice-label">Invoice #—</div>
                </div>
            </div>
            <div class="pm-amount-badge">
                <span class="pm-amount-label">DUE</span>
                <span class="pm-amount-value" id="pm-amount-display">$0.00</span>
            </div>
        </div>

        <!-- Method Tabs -->
        <div class="pm-tabs">
            <button class="pm-tab active" onclick="switchTab('stripe')" id="tab-stripe">
                <span class="pm-tab-icon">💳</span>
                <span>Pay by Card</span>
            </button>
            <button class="pm-tab" onclick="switchTab('cashapp')" id="tab-cashapp">
                <span class="pm-tab-icon">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
                        <path d="M12 0C5.373 0 0 5.373 0 12s5.373 12 12 12 12-5.373 12-12S18.627 0 12 0zm1.25 17.5h-2.5v-1.25c-1.657-.276-2.75-1.324-2.75-2.75h1.75c0 .69.56 1.25 1.25 1.25h1.25c.69 0 1.25-.56 1.25-1.25 0-.552-.358-.973-1.134-1.214l-2.116-.635C9.069 11.22 8.25 10.18 8.25 9c0-1.38 1.007-2.474 2.5-2.75V5h2.5v1.25c1.493.276 2.5 1.37 2.5 2.75h-1.75c0-.69-.56-1.25-1.25-1.25h-1.25c-.69 0-1.25.56-1.25 1.25 0 .552.358.973 1.134 1.214l2.116.635C14.931 11.28 15.75 12.32 15.75 13.5c0 1.38-1.007 2.474-2.5 2.75V17.5z"/>
                    </svg>
                </span>
                <span>Cash App</span>
            </button>
        </div>

        <!-- Stripe Panel -->
        <div id="panel-stripe" class="pm-panel">
            <div class="pm-secure-badge">
                <span>🔒</span>
                <span>Secured by Stripe · 256-bit encryption</span>
            </div>
            <div id="stripe-card-element" class="pm-card-element"></div>
            <div id="stripe-card-errors" class="pm-error" role="alert"></div>
            <button class="pm-pay-btn" id="stripe-pay-btn" onclick="handleStripePayment()">
                <span id="stripe-btn-text">Pay Now</span>
                <span id="stripe-spinner" class="pm-spinner" style="display:none;">⟳</span>
            </button>
        </div>

        <!-- Cash App Panel -->
        <div id="panel-cashapp" class="pm-panel" style="display:none;">
            <div class="pm-cashapp-inner">
                <div class="pm-cashapp-header">
                    <div class="pm-cashapp-logo">$</div>
                    <div>
                        <div class="pm-cashapp-handle">$ChefRodneyChery</div>
                        <div class="pm-cashapp-note">Send payment directly via Cash App</div>
                    </div>
                </div>

                <div class="pm-qr-wrapper">
                    <img src="/images/cashapp-qr.png" alt="Cash App QR Code" class="pm-qr-img"
                         onerror="this.style.display='none'; document.getElementById('qr-fallback').style.display='flex';" />
                    <div id="qr-fallback" class="pm-qr-fallback" style="display:none;">
                        <div class="pm-qr-placeholder">
                            <div style="font-size:2rem;">📱</div>
                            <div>QR code coming soon</div>
                            <div style="font-size:0.75rem;opacity:0.6;">Place cashapp-qr.png in /wwwroot/images/</div>
                        </div>
                    </div>
                </div>

                <a href="https://cash.app/$ChefRodneyChery" target="_blank" class="pm-cashapp-btn">
                    Open Cash App →
                </a>

                <div class="pm-cashapp-steps">
                    <div class="pm-step"><span class="pm-step-num">1</span> Open Cash App on your phone</div>
                    <div class="pm-step"><span class="pm-step-num">2</span> Scan QR code or tap the button above</div>
                    <div class="pm-step"><span class="pm-step-num">3</span> Send <strong id="cashapp-amount">$0.00</strong> with your invoice number in the note</div>
                    <div class="pm-step"><span class="pm-step-num">4</span> Click confirm below once sent</div>
                </div>

                <button class="pm-confirm-btn" onclick="handleCashAppConfirm()">
                    I've Sent the Payment
                </button>
            </div>
        </div>

        <!-- Close -->
        <button class="pm-close" onclick="closePaymentModal()">✕ Cancel</button>
    </div>
</div>

<script src="~/js/invoice-payment-modal.js" asp-append-version="true"></script>