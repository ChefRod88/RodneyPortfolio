@* _PaymentModal.cshtml — Drop into Pages/Portal/ *@
@* Requires: Stripe.js loaded in _Layout.cshtml (see StripeScriptSnippet.txt) *@

<div id="paymentModal" class="pm-overlay" style="display:none;">
    <div class="pm-container">
        <!-- Header -->
        <div class="pm-header">
            <div class="pm-header-left">
                <div class="pm-icon">⚡</div>
                <div>
                    <div class="pm-title">Complete Payment</div>
                    <div class="pm-subtitle" id="pm-invoice-label">Invoice #—</div>
                </div>
            </div>
            <div class="pm-amount-badge">
                <span class="pm-amount-label">DUE</span>
                <span class="pm-amount-value" id="pm-amount-display">$0.00</span>
            </div>
        </div>

        <!-- Method Tabs -->
        <div class="pm-tabs">
            <button class="pm-tab active" onclick="switchTab('stripe')" id="tab-stripe">
                <span class="pm-tab-icon">💳</span>
                <span>Pay by Card</span>
            </button>
            <button class="pm-tab" onclick="switchTab('cashapp')" id="tab-cashapp">
                <span class="pm-tab-icon">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
                        <path d="M12 0C5.373 0 0 5.373 0 12s5.373 12 12 12 12-5.373 12-12S18.627 0 12 0zm1.25 17.5h-2.5v-1.25c-1.657-.276-2.75-1.324-2.75-2.75h1.75c0 .69.56 1.25 1.25 1.25h1.25c.69 0 1.25-.56 1.25-1.25 0-.552-.358-.973-1.134-1.214l-2.116-.635C9.069 11.22 8.25 10.18 8.25 9c0-1.38 1.007-2.474 2.5-2.75V5h2.5v1.25c1.493.276 2.5 1.37 2.5 2.75h-1.75c0-.69-.56-1.25-1.25-1.25h-1.25c-.69 0-1.25.56-1.25 1.25 0 .552.358.973 1.134 1.214l2.116.635C14.931 11.28 15.75 12.32 15.75 13.5c0 1.38-1.007 2.474-2.5 2.75V17.5z"/>
                    </svg>
                </span>
                <span>Cash App</span>
            </button>
        </div>

        <!-- Stripe Panel -->
        <div id="panel-stripe" class="pm-panel">
            <div class="pm-secure-badge">
                <span>🔒</span>
                <span>Secured by Stripe · 256-bit encryption</span>
            </div>
            <div id="stripe-card-element" class="pm-card-element"></div>
            <div id="stripe-card-errors" class="pm-error" role="alert"></div>
            <button class="pm-pay-btn" id="stripe-pay-btn" onclick="handleStripePayment()">
                <span id="stripe-btn-text">Pay Now</span>
                <span id="stripe-spinner" class="pm-spinner" style="display:none;">⟳</span>
            </button>
        </div>

        <!-- Cash App Panel -->
        <div id="panel-cashapp" class="pm-panel" style="display:none;">
            <div class="pm-cashapp-inner">
                <div class="pm-cashapp-header">
                    <div class="pm-cashapp-logo">$</div>
                    <div>
                        <div class="pm-cashapp-handle">$ChefRodneyChery</div>
                        <div class="pm-cashapp-note">Send payment directly via Cash App</div>
                    </div>
                </div>

                <div class="pm-qr-wrapper">
                    <img src="/images/cashapp-qr.png" alt="Cash App QR Code" class="pm-qr-img"
                         onerror="this.style.display='none'; document.getElementById('qr-fallback').style.display='flex';" />
                    <div id="qr-fallback" class="pm-qr-fallback" style="display:none;">
                        <div class="pm-qr-placeholder">
                            <div style="font-size:2rem;">📱</div>
                            <div>QR code coming soon</div>
                            <div style="font-size:0.75rem;opacity:0.6;">Place cashapp-qr.png in /wwwroot/images/</div>
                        </div>
                    </div>
                </div>

                <a href="https://cash.app/$ChefRodneyChery" target="_blank" class="pm-cashapp-btn">
                    Open Cash App →
                </a>

                <div class="pm-cashapp-steps">
                    <div class="pm-step"><span class="pm-step-num">1</span> Open Cash App on your phone</div>
                    <div class="pm-step"><span class="pm-step-num">2</span> Scan QR code or tap the button above</div>
                    <div class="pm-step"><span class="pm-step-num">3</span> Send <strong id="cashapp-amount">$0.00</strong> with your invoice number in the note</div>
                    <div class="pm-step"><span class="pm-step-num">4</span> Click confirm below once sent</div>
                </div>

                <button class="pm-confirm-btn" onclick="handleCashAppConfirm()">
                    I've Sent the Payment
                </button>
            </div>
        </div>

        <!-- Close -->
        <button class="pm-close" onclick="closePaymentModal()">✕ Cancel</button>
    </div>
</div>

<style>
/* ── Payment Modal Styles ─────────────────────────────── */
.pm-overlay {
    position: fixed; inset: 0; z-index: 9999;
    background: rgba(0,0,0,0.85);
    display: flex; align-items: center; justify-content: center;
    backdrop-filter: blur(4px);
    animation: pm-fade-in 0.2s ease;
}
@@keyframes pm-fade-in { from { opacity: 0; } to { opacity: 1; } }

.pm-container {
    background: #0d1117;
    border: 1px solid #00ff4130;
    border-radius: 16px;
    width: min(480px, 95vw);
    overflow: hidden;
    box-shadow: 0 0 60px #00ff4115, 0 20px 60px rgba(0,0,0,0.6);
    animation: pm-slide-up 0.25s ease;
}
@@keyframes pm-slide-up { from { transform: translateY(24px); opacity: 0; } to { transform: translateY(0); opacity: 1; } }

.pm-header {
    background: linear-gradient(135deg, #00ff4108, #00ff4103);
    border-bottom: 1px solid #00ff4120;
    padding: 20px 24px;
    display: flex; align-items: center; justify-content: space-between;
}
.pm-header-left { display: flex; align-items: center; gap: 14px; }
.pm-icon { font-size: 1.6rem; }
.pm-title { color: #00ff41; font-weight: 700; font-size: 1rem; font-family: 'Courier New', monospace; }
.pm-subtitle { color: #888; font-size: 0.8rem; margin-top: 2px; }
.pm-amount-badge {
    background: #00ff4115;
    border: 1px solid #00ff4130;
    border-radius: 10px;
    padding: 8px 14px;
    text-align: right;
}
.pm-amount-label { display: block; font-size: 0.65rem; color: #00ff4190; letter-spacing: 0.1em; }
.pm-amount-value { display: block; font-size: 1.3rem; font-weight: 700; color: #00ff41; font-family: 'Courier New', monospace; }

/* Tabs */
.pm-tabs {
    display: grid; grid-template-columns: 1fr 1fr;
    border-bottom: 1px solid #00ff4115;
}
.pm-tab {
    background: none; border: none; cursor: pointer;
    padding: 14px; color: #666;
    display: flex; align-items: center; justify-content: center; gap: 8px;
    font-size: 0.85rem; transition: all 0.2s;
    border-bottom: 2px solid transparent;
}
.pm-tab:hover { color: #aaa; background: #ffffff05; }
.pm-tab.active { color: #00ff41; border-bottom-color: #00ff41; background: #00ff4108; }
.pm-tab-icon { display: flex; align-items: center; }

/* Panels */
.pm-panel { padding: 24px; }

.pm-secure-badge {
    display: flex; align-items: center; gap: 8px;
    color: #4a9; font-size: 0.75rem; margin-bottom: 16px;
    background: #00ff4108; border-radius: 6px; padding: 8px 12px;
}
.pm-card-element {
    background: #161b22;
    border: 1px solid #00ff4130;
    border-radius: 8px;
    padding: 14px;
    margin-bottom: 12px;
    transition: border-color 0.2s;
}
.pm-card-element:focus-within { border-color: #00ff4160; }
.pm-error { color: #ff4444; font-size: 0.8rem; min-height: 20px; margin-bottom: 8px; }

.pm-pay-btn {
    width: 100%; padding: 14px;
    background: linear-gradient(135deg, #00ff41, #00cc33);
    color: #000; font-weight: 700; font-size: 0.95rem;
    border: none; border-radius: 8px; cursor: pointer;
    font-family: 'Courier New', monospace; letter-spacing: 0.05em;
    transition: all 0.2s; display: flex; align-items: center; justify-content: center; gap: 8px;
}
.pm-pay-btn:hover { transform: translateY(-1px); box-shadow: 0 4px 20px #00ff4140; }
.pm-pay-btn:disabled { opacity: 0.6; cursor: not-allowed; transform: none; }
.pm-spinner { animation: spin 0.8s linear infinite; display: inline-block; }
@@keyframes spin { to { transform: rotate(360deg); } }

/* Cash App */
.pm-cashapp-inner { display: flex; flex-direction: column; gap: 16px; }
.pm-cashapp-header { display: flex; align-items: center; gap: 14px; }
.pm-cashapp-logo {
    width: 44px; height: 44px; border-radius: 12px;
    background: linear-gradient(135deg, #00d632, #00a825);
    display: flex; align-items: center; justify-content: center;
    font-size: 1.4rem; font-weight: 900; color: #fff;
}
.pm-cashapp-handle { color: #00d632; font-weight: 700; font-size: 1.1rem; }
.pm-cashapp-note { color: #666; font-size: 0.8rem; }

.pm-qr-wrapper {
    background: #fff; border-radius: 12px; padding: 12px;
    display: flex; justify-content: center; align-items: center;
    min-height: 160px;
}
.pm-qr-img { width: 140px; height: 140px; display: block; }
.pm-qr-fallback {
    display: flex; align-items: center; justify-content: center; width: 100%;
}
.pm-qr-placeholder {
    text-align: center; color: #888; font-size: 0.85rem; padding: 20px;
    display: flex; flex-direction: column; gap: 6px; align-items: center;
}

.pm-cashapp-btn {
    display: block; text-align: center; padding: 12px;
    background: linear-gradient(135deg, #00d632, #00a825);
    color: #fff; font-weight: 700; border-radius: 8px;
    text-decoration: none; font-size: 0.9rem;
    transition: all 0.2s;
}
.pm-cashapp-btn:hover { transform: translateY(-1px); box-shadow: 0 4px 20px #00d63240; }

.pm-cashapp-steps { display: flex; flex-direction: column; gap: 10px; }
.pm-step {
    display: flex; align-items: flex-start; gap: 10px;
    color: #aaa; font-size: 0.82rem; line-height: 1.4;
}
.pm-step-num {
    min-width: 22px; height: 22px; border-radius: 50%;
    background: #00ff4115; border: 1px solid #00ff4130;
    color: #00ff41; font-size: 0.7rem; font-weight: 700;
    display: flex; align-items: center; justify-content: center;
    margin-top: 1px;
}

.pm-confirm-btn {
    width: 100%; padding: 14px;
    background: transparent;
    border: 1px solid #00d63260;
    color: #00d632; font-weight: 700; font-size: 0.9rem;
    border-radius: 8px; cursor: pointer;
    transition: all 0.2s;
}
.pm-confirm-btn:hover { background: #00d63210; border-color: #00d632; }

.pm-close {
    width: 100%; padding: 12px;
    background: none; border: none; border-top: 1px solid #00ff4110;
    color: #555; cursor: pointer; font-size: 0.8rem;
    transition: color 0.2s;
}
.pm-close:hover { color: #888; }
</style>

<script>
// ── State ─────────────────────────────────────────────────────
let stripeInstance = null;
let stripeElements = null;
let stripeCardElement = null;
let currentInvoiceId = null;
let currentAmount = 0;

// ── Open Modal ────────────────────────────────────────────────
function openPaymentModal(invoiceId, amount, invoiceNumber) {
    currentInvoiceId = invoiceId;
    currentAmount = amount;

    document.getElementById('pm-amount-display').textContent = '$' + parseFloat(amount).toFixed(2);
    document.getElementById('pm-invoice-label').textContent = 'Invoice #' + invoiceNumber;
    document.getElementById('cashapp-amount').textContent = '$' + parseFloat(amount).toFixed(2);
    document.getElementById('paymentModal').style.display = 'flex';

    initStripe();
    switchTab('stripe');
}

function closePaymentModal() {
    document.getElementById('paymentModal').style.display = 'none';
    stripeCardElement = null; stripeElements = null;
}

// ── Tab Switch ────────────────────────────────────────────────
function switchTab(tab) {
    document.querySelectorAll('.pm-tab').forEach(t => t.classList.remove('active'));
    document.querySelectorAll('.pm-panel').forEach(p => p.style.display = 'none');
    document.getElementById('tab-' + tab).classList.add('active');
    document.getElementById('panel-' + tab).style.display = 'block';
    if (tab === 'stripe') initStripe();
}

// ── Stripe ────────────────────────────────────────────────────
function initStripe() {
    if (stripeCardElement) return;
    const pubKey = document.getElementById('stripe-pub-key')?.value;
    if (!pubKey || !window.Stripe) return;

    stripeInstance = Stripe(pubKey);
    stripeElements = stripeInstance.elements();
    stripeCardElement = stripeElements.create('card', {
        style: {
            base: {
                color: '#e0e0e0', fontFamily: 'Courier New, monospace',
                fontSize: '15px', '::placeholder': { color: '#555' }
            },
            invalid: { color: '#ff4444' }
        }
    });
    stripeCardElement.mount('#stripe-card-element');
    stripeCardElement.on('change', e => {
        document.getElementById('stripe-card-errors').textContent = e.error ? e.error.message : '';
    });
}

async function handleStripePayment() {
    if (!stripeCardElement) return;
    const btn = document.getElementById('stripe-pay-btn');
    const btnText = document.getElementById('stripe-btn-text');
    const spinner = document.getElementById('stripe-spinner');

    btn.disabled = true;
    btnText.textContent = 'Processing...';
    spinner.style.display = 'inline-block';

    try {
        // 1. Get PaymentIntent client secret from server
        const res = await fetch('/Portal/CreatePaymentIntent', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ invoiceId: currentInvoiceId })
        });
        const data = await res.json();

        if (!res.ok) throw new Error(data.error || 'Could not initiate payment.');

        // 2. Confirm card payment with Stripe
        const { error, paymentIntent } = await stripeInstance.confirmCardPayment(data.clientSecret, {
            payment_method: { card: stripeCardElement }
        });

        if (error) throw new Error(error.message);

        // 3. Confirm with server
        await fetch('/Portal/ConfirmPayment', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ invoiceId: currentInvoiceId, paymentIntentId: paymentIntent.id })
        });

        closePaymentModal();
        showPaymentSuccess('stripe');
        setTimeout(() => location.reload(), 2500);

    } catch (err) {
        document.getElementById('stripe-card-errors').textContent = err.message;
        btn.disabled = false;
        btnText.textContent = 'Pay Now';
        spinner.style.display = 'none';
    }
}

async function handleCashAppConfirm() {
    // Mark invoice as pending Cash App confirmation
    await fetch('/Portal/CashAppPending', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ invoiceId: currentInvoiceId })
    });
    closePaymentModal();
    showPaymentSuccess('cashapp');
    setTimeout(() => location.reload(), 3000);
}

function showPaymentSuccess(method) {
    const msg = method === 'stripe'
        ? '✅ Payment successful! Your receipt is on its way.'
        : '📱 Thanks! We\'ll confirm your Cash App payment shortly.';
    const toast = document.createElement('div');
    toast.style.cssText = 'position:fixed;bottom:24px;right:24px;background:#0d1117;border:1px solid #00ff4150;color:#00ff41;padding:16px 22px;border-radius:10px;font-family:Courier New,monospace;font-size:0.85rem;z-index:99999;box-shadow:0 4px 30px #00ff4120;animation:pm-fade-in 0.3s ease;max-width:300px;line-height:1.5;';
    toast.textContent = msg;
    document.body.appendChild(toast);
    setTimeout(() => toast.remove(), 3000);
}
</script>