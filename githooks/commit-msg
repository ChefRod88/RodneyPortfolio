#!/bin/sh
# Strips Co-authored-by lines; single author only.
# Enable: git config core.hooksPath githooks  (from repo root)

msg_file=$1
[ -n "$msg_file" ] && [ -f "$msg_file" ] || exit 0

# Resolve repo root so the hook works from any worktree state
root=$(git -C "$(dirname "$0")/.." rev-parse --show-toplevel 2>/dev/null) || \
root=$(git rev-parse --show-toplevel 2>/dev/null) || \
exit 0
stripper="$root/scripts/git-msg-strip-coauthor-lines.py"

if [ -f "$stripper" ] && command -v python3 >/dev/null 2>&1; then
  tmp=$(mktemp) || exit 0
  if ! python3 "$stripper" < "$msg_file" > "$tmp" 2>/dev/null; then
    rm -f "$tmp"
    exit 0
  fi
  mv "$tmp" "$msg_file" || { rm -f "$tmp"; exit 0; }
  exit 0
fi

# Fallback: grep (older clones without the script)
tmp=$(mktemp) || exit 0
if ! grep -viE '^[[:space:]]*co-authored-by:' "$msg_file" > "$tmp" 2>/dev/null; then
  rm -f "$tmp"
  exit 0
fi
mv "$tmp" "$msg_file" || { rm -f "$tmp"; exit 0; }
exit 0
