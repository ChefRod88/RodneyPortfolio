@page
@model ChurchWebsite.Pages.LocationModel
@{
    ViewData["Title"] = "Location";
    var googleMapsUrl = "https://www.google.com/maps?um=1&ie=UTF-8&fb=1&gl=us&sa=X&geocode=KZf_NdbSEt2IMX5147rUXvkm&daddr=123+Ave+Y+NE,+Winter+Haven,+FL+33881";
    var appleMapsUrl = "https://maps.apple.com/?daddr=123+Ave+Y+NE,+Winter+Haven,+FL+33881&dirflg=d";
}

@section Head {
<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css"
      integrity="sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY=" crossorigin="" />
<style>
/* ═══════════════════════════════════════════════════
   LOCATION — FUTURISTIC HUD REDESIGN
   Tech: CSS Grid · Glassmorphism · Custom Properties
         CSS Animations · Leaflet.js · Dark Map Theme
   ═══════════════════════════════════════════════════ */
:root {
  --g:#C9A84C; --gl:#F0D080; --gg:rgba(201,168,76,.35);
  --d:#070710; --s1:#0A0A18; --s2:#0E0E1E; --s3:#13132A;
  --tp:#F0EDE6; --tm:#9A9485; --gb:rgba(201,168,76,.18);
  --panel-w:420px; --nav-h:64px;
}

/* Kill body scroll on desktop — page fills viewport */
body { background:var(--d); color:var(--tp); overflow-x:hidden; }

/* ─── PAGE SHELL ─── */
.loc-host {
  height: calc(100vh - var(--nav-h));
  display: flex; flex-direction: column; overflow: hidden;
}

/* ─── SPLIT GRID: MAP | HUD PANEL ─── */
.loc-shell {
  display: grid;
  grid-template-columns: 1fr var(--panel-w);
  flex: 1; min-height: 0; overflow: hidden;
}

/* ═══════════════════════
   MAP COLUMN
   ═══════════════════════ */
.loc-map-col { position: relative; min-height: 0; overflow: hidden; }
#location-map { width: 100%; height: 100%; display: block; }

/* CartoDB Dark Matter — no filter needed, already a professional dark map */
.leaflet-container { background:#0d0d17; }

/* Leaflet UI overrides */
.leaflet-popup-content-wrapper {
  background:rgba(8,8,20,.95); border:1px solid var(--gb);
  border-radius:14px; color:var(--tp);
  box-shadow:0 24px 60px rgba(0,0,0,.8), 0 0 40px var(--gg);
  backdrop-filter:blur(16px);
}
.leaflet-popup-content { font-size:.88rem; line-height:1.6; color:var(--tp); }
.leaflet-popup-tip { background:rgba(8,8,20,.95); }
.leaflet-popup-close-button { color:var(--tm) !important; }
.leaflet-control-zoom a {
  background:rgba(10,10,24,.92) !important; color:var(--g) !important;
  border-color:var(--gb) !important; backdrop-filter:blur(10px);
  font-weight:700;
}
.leaflet-control-zoom a:hover { background:rgba(20,20,42,.96) !important; color:var(--gl) !important; }
.leaflet-control-attribution { background:rgba(7,7,16,.8) !important; color:var(--tm) !important; font-size:.6rem; }

/* ── Scan-line sweep across map ── */
.loc-scan { position:absolute; inset:0; pointer-events:none; z-index:400; overflow:hidden; }
.loc-scan::before {
  content:''; position:absolute; left:0; right:0; top:-2px;
  height:2px;
  background:linear-gradient(90deg,transparent 0%,var(--g) 30%,var(--gl) 50%,var(--g) 70%,transparent 100%);
  opacity:.4; animation:scanline 7s linear infinite;
}
@@keyframes scanline { 0%{top:-2px} 100%{top:100%} }

/* ── HUD corner brackets ── */
.loc-corner { position:absolute; z-index:400; pointer-events:none; width:32px; height:32px; border-color:var(--g); border-style:solid; opacity:.5; }
.loc-corner-tl { top:1.1rem; left:1.1rem; border-width:2px 0 0 2px; }
.loc-corner-tr { top:1.1rem; right:1.1rem; border-width:2px 2px 0 0; }
.loc-corner-bl { bottom:1.1rem; left:1.1rem; border-width:0 0 2px 2px; }
.loc-corner-br { bottom:1.1rem; right:1.1rem; border-width:0 2px 2px 0; }

/* ── Floating destination badge ── */
.loc-map-badge {
  position:absolute; top:1.1rem; left:50%; transform:translateX(-50%);
  z-index:500; display:flex; align-items:center; gap:.65rem;
  background:rgba(7,7,16,.9); border:1px solid var(--gb); border-radius:100px;
  padding:.45rem 1.1rem; white-space:nowrap; backdrop-filter:blur(18px);
  box-shadow:0 8px 32px rgba(0,0,0,.6),0 0 24px var(--gg);
  animation:badgeSlide .7s cubic-bezier(.23,1,.32,1) both;
}
@@keyframes badgeSlide { from{opacity:0;transform:translateX(-50%) translateY(-14px)} to{opacity:1;transform:translateX(-50%) translateY(0)} }
.loc-badge-pulse {
  width:8px; height:8px; border-radius:50%; background:var(--g);
  box-shadow:0 0 10px var(--g); flex-shrink:0; position:relative;
}
.loc-badge-pulse::before {
  content:''; position:absolute; inset:-4px; border-radius:50%;
  border:1px solid var(--g); animation:badgePulse 2s ease-out infinite; opacity:.7;
}
@@keyframes badgePulse { 0%{transform:scale(.8);opacity:.7} 100%{transform:scale(1.8);opacity:0} }
.loc-badge-txt { font-size:.68rem; font-weight:700; letter-spacing:.08em; text-transform:uppercase; color:var(--gl); }

/* ─── Map grid overlay ─── */
.loc-map-grid {
  position:absolute; inset:0; pointer-events:none; z-index:399;
  background-image:linear-gradient(rgba(201,168,76,.03) 1px,transparent 1px),
                   linear-gradient(90deg,rgba(201,168,76,.03) 1px,transparent 1px);
  background-size:48px 48px;
}

/* ═══════════════════════
   HUD PANEL
   ═══════════════════════ */
.loc-panel {
  background:linear-gradient(180deg,rgba(8,8,20,.98) 0%,rgba(6,6,16,.99) 100%);
  border-left:1px solid var(--gb);
  display:flex; flex-direction:column; overflow-y:auto; overflow-x:hidden; min-height:0;
  position:relative;
  scrollbar-width:thin; scrollbar-color:rgba(201,168,76,.18) transparent;
}
.loc-panel::-webkit-scrollbar { width:3px; }
.loc-panel::-webkit-scrollbar-thumb { background:rgba(201,168,76,.2); border-radius:3px; }

/* Top gold accent bar */
.loc-panel-bar {
  height:3px; flex-shrink:0;
  background:linear-gradient(90deg,transparent,var(--g),var(--gl),var(--g),transparent);
  position:relative;
}
.loc-panel-bar::after {
  content:''; position:absolute; inset:0;
  background:inherit; filter:blur(4px); opacity:.6;
}

/* Subtle grid texture on panel */
.loc-panel-bg {
  position:absolute; inset:0; pointer-events:none;
  background-image:linear-gradient(rgba(201,168,76,.018) 1px,transparent 1px),
                   linear-gradient(90deg,rgba(201,168,76,.018) 1px,transparent 1px);
  background-size:22px 22px;
}

/* All panel content sits above the bg texture */
.loc-panel > *:not(.loc-panel-bg) { position:relative; z-index:1; }

/* ── Panel header ── */
.loc-head {
  padding:1.4rem 1.5rem 1.1rem; border-bottom:1px solid rgba(201,168,76,.1); flex-shrink:0;
}
.loc-head-top { display:flex; align-items:center; justify-content:space-between; margin-bottom:.65rem; }
.loc-head-label {
  font-size:.55rem; letter-spacing:.28em; text-transform:uppercase; color:var(--g);
  display:flex; align-items:center; gap:.5rem;
}
.loc-head-label::after { content:''; display:block; width:28px; height:1px; background:var(--gb); }
.loc-live {
  display:flex; align-items:center; gap:.4rem;
  font-size:.55rem; letter-spacing:.14em; text-transform:uppercase; color:rgba(154,148,133,.6);
}
.loc-live-dot {
  width:6px; height:6px; border-radius:50%;
  background:#4ade80; box-shadow:0 0 8px rgba(74,222,128,.7); animation:livePulse 2s infinite;
}
@@keyframes livePulse { 0%,100%{opacity:1}50%{opacity:.25} }
.loc-head h2 {
  font-size:1.35rem; font-weight:800; line-height:1.15; margin-bottom:.25rem;
  background:linear-gradient(135deg,#fff 0%,var(--gl) 55%,var(--g) 100%);
  -webkit-background-clip:text; -webkit-text-fill-color:transparent; background-clip:text;
}
.loc-head p { font-size:.78rem; color:var(--tm); line-height:1.5; margin:0; }

/* ── Coordinates HUD ── */
.loc-coords {
  padding:.85rem 1.5rem; border-bottom:1px solid rgba(201,168,76,.07);
  flex-shrink:0; display:flex; gap:0;
}
.loc-coord {
  flex:1; padding:.3rem .5rem; border-right:1px solid rgba(201,168,76,.08);
  text-align:center;
}
.loc-coord:first-child { padding-left:0; }
.loc-coord:last-child { border-right:none; padding-right:0; }
.loc-coord-lbl { font-size:.48rem; letter-spacing:.18em; text-transform:uppercase; color:var(--tm); margin-bottom:.18rem; }
.loc-coord-val { font-size:.78rem; font-weight:700; color:var(--g); font-variant-numeric:tabular-nums; letter-spacing:.04em; }

/* ── Status card ── */
.loc-status-wrap { padding:.9rem 1.5rem; border-bottom:1px solid rgba(201,168,76,.07); flex-shrink:0; }
#location-status-card {
  background:rgba(201,168,76,.035); border:1px solid rgba(201,168,76,.15);
  border-radius:14px; padding:.9rem 1rem; position:relative; overflow:hidden;
}
#location-status-card::before {
  content:''; position:absolute; top:0; left:0; right:0; height:1px;
  background:linear-gradient(90deg,transparent,rgba(201,168,76,.5),transparent);
}
.location-status-header { display:flex; align-items:center; gap:.45rem; margin-bottom:.4rem; }
.location-status-dot { width:8px; height:8px; border-radius:50%; flex-shrink:0; }
.dot-online  { background:#4ade80; box-shadow:0 0 10px rgba(74,222,128,.7); animation:livePulse 1.8s infinite; }
.dot-offline { background:#f87171; box-shadow:0 0 10px rgba(248,113,113,.6); animation:livePulse 1.8s infinite; }
.location-status-title { font-size:.6rem; letter-spacing:.16em; text-transform:uppercase; color:var(--tp); font-weight:700; }
#location-status-text { font-size:.8rem; color:var(--tm); margin-bottom:.1rem; line-height:1.4; }
#location-status-meta { font-size:.6rem; color:rgba(154,148,133,.4); margin:0; }
.location-refresh-btn {
  margin-top:.75rem; background:transparent;
  border:1px solid rgba(201,168,76,.3); color:var(--g); border-radius:100px;
  padding:5px 14px; font-size:.65rem; cursor:pointer; transition:all .3s;
  letter-spacing:.06em; font-family:inherit;
  display:inline-flex; align-items:center; gap:5px;
}
.location-refresh-btn:hover { background:rgba(201,168,76,.1); border-color:var(--g); box-shadow:0 0 16px var(--gg); }
.location-refresh-btn:disabled { opacity:.5; cursor:wait; }

/* ── ETA / Route summary ── */
.loc-eta {
  padding:.85rem 1.5rem; border-bottom:1px solid rgba(201,168,76,.07); flex-shrink:0;
}
.loc-eta-lbl { font-size:.55rem; letter-spacing:.22em; text-transform:uppercase; color:var(--tm); margin-bottom:.3rem; }
#location-directions-meta { font-size:.9rem; color:var(--gl); font-weight:600; line-height:1.4; margin:0; letter-spacing:.02em; }

/* ── Turn-by-turn directions ── */
.loc-dirs { padding:1rem 1.5rem; flex:1 0 auto; }
.loc-dirs-eye {
  font-size:.55rem; letter-spacing:.24em; text-transform:uppercase; color:var(--g);
  margin-bottom:.85rem; display:flex; align-items:center; gap:.6rem;
}
.loc-dirs-eye::after { content:''; flex:1; height:1px; background:linear-gradient(90deg,var(--gb),transparent); }
.location-directions-steps { list-style:none; padding:0; margin:0; counter-reset:step; }
.location-directions-steps li {
  font-size:.78rem; color:var(--tp); padding:.6rem 0;
  border-bottom:1px solid rgba(201,168,76,.06); line-height:1.5;
  display:flex; gap:.65rem; align-items:flex-start; counter-increment:step;
  transition:padding-left .2s, color .2s; cursor:default;
}
.location-directions-steps li:hover { padding-left:.35rem; color:#fff; }
.location-directions-steps li:last-child { border-bottom:none; }
.location-directions-steps li::before {
  content:counter(step); min-width:22px; height:22px; border-radius:50%;
  background:rgba(201,168,76,.07); border:1px solid rgba(201,168,76,.25);
  display:flex; align-items:center; justify-content:center;
  font-size:.58rem; font-weight:800; color:var(--g); flex-shrink:0;
  margin-top:.1rem; font-variant-numeric:tabular-nums;
}

/* ── Map app buttons ── */
.loc-btns {
  padding:.9rem 1.5rem 1rem; flex-shrink:0;
  display:flex; flex-direction:column; gap:.55rem;
  border-top:1px solid rgba(201,168,76,.08);
}
.loc-btn {
  display:flex; align-items:center; gap:.75rem;
  padding:.75rem 1rem; border-radius:14px; font-size:.82rem; font-weight:600;
  text-decoration:none; transition:all .3s cubic-bezier(.23,1,.32,1);
  letter-spacing:.02em; width:100%; border:1px solid transparent; flex-shrink:0; overflow:hidden; position:relative;
}
.loc-btn::after { content:''; position:absolute; inset:0; opacity:0; transition:opacity .3s; background:linear-gradient(135deg,rgba(255,255,255,.07),transparent); }
.loc-btn:hover::after { opacity:1; }
.loc-btn-google { background:rgba(255,255,255,.96); border-color:rgba(0,0,0,.1); color:#111; }
.loc-btn-google:hover { background:#fff; box-shadow:0 8px 28px rgba(0,0,0,.35); transform:translateY(-2px); color:#111; }
.loc-btn-apple { background:rgba(24,24,26,.96); border-color:rgba(255,255,255,.1); color:#fff; }
.loc-btn-apple:hover { background:#2c2c2e; box-shadow:0 8px 28px rgba(0,0,0,.5); transform:translateY(-2px); color:#fff; }
.loc-btn-logo { flex-shrink:0; display:flex; align-items:center; justify-content:center; width:28px; height:28px; }
.loc-btn-label { display:flex; flex-direction:column; line-height:1.2; }
.loc-btn-sub { font-size:.58rem; font-weight:400; opacity:.5; letter-spacing:.06em; text-transform:uppercase; }
.loc-btn-name { font-size:.85rem; font-weight:700; }

/* ── Church info rows ── */
.loc-info {
  padding:.85rem 1.5rem 1.5rem;
  border-top:1px solid rgba(201,168,76,.07); flex-shrink:0;
}
.loc-info-row { display:flex; align-items:flex-start; gap:.65rem; padding:.45rem 0; border-bottom:1px solid rgba(201,168,76,.05); }
.loc-info-row:last-child { border-bottom:none; }
.loc-info-icon { font-size:.88rem; flex-shrink:0; margin-top:.06rem; }
.loc-info-lbl { font-size:.54rem; letter-spacing:.12em; text-transform:uppercase; color:var(--tm); margin-bottom:.08rem; }
.loc-info-val { font-size:.82rem; color:var(--tp); }
.loc-chip {
  display:inline-flex; align-items:center; gap:4px;
  background:rgba(201,168,76,.08); border:1px solid rgba(201,168,76,.2);
  border-radius:100px; padding:3px 10px; font-size:.68rem; color:var(--gl);
  letter-spacing:.04em; margin:.15rem .1rem 0 0;
}

/* ═══════════════════════
   ROUTE LINE & MARKERS
   ═══════════════════════ */
.route-line-animated { stroke-linecap:round; stroke-linejoin:round; }

/* Travel dot */
.route-travel-car { width:22px; height:22px; font-size:18px; line-height:22px; text-align:center; filter:drop-shadow(0 2px 6px rgba(59,130,246,.8)); }

/* User location ping */
.route-origin-ping-core {
  position:relative; display:inline-block; width:14px; height:14px; margin:2px;
  border-radius:50%; background:#4ade80; border:2px solid #fff;
  box-shadow:0 0 0 0 rgba(74,222,128,.6);
  animation:originPing 1.6s infinite;
}
@@keyframes originPing {
  0%   { box-shadow:0 0 0 0 rgba(74,222,128,.6); }
  70%  { box-shadow:0 0 0 12px rgba(74,222,128,0); }
  100% { box-shadow:0 0 0 0 rgba(74,222,128,0); }
}

/* ── Gold church destination pin ── */
.loc-church-pin {
  position:relative; width:28px; height:28px;
  display:flex; align-items:center; justify-content:center;
}
.loc-church-pin-inner {
  width:16px; height:16px; border-radius:50%;
  background:linear-gradient(135deg,var(--gl),var(--g));
  border:2px solid #fff; z-index:2; position:relative;
  box-shadow:0 0 12px var(--gg), 0 2px 8px rgba(0,0,0,.5);
}
.loc-church-pin-ring {
  position:absolute; border-radius:50%; border:1.5px solid var(--g);
  animation:churchPinPulse 2.4s ease-out infinite; pointer-events:none;
}
.loc-church-pin-ring-1 { width:22px; height:22px; animation-delay:0s; }
.loc-church-pin-ring-2 { width:30px; height:30px; animation-delay:.8s; }
@@keyframes churchPinPulse {
  0%   { opacity:.7; transform:scale(.8); }
  100% { opacity:0;  transform:scale(1.6); }
}

/* ── H3 Spatial Index section ── */
.loc-h3 {
  padding:.85rem 1.5rem; border-bottom:1px solid rgba(201,168,76,.07); flex-shrink:0;
}
.loc-h3-head {
  display:flex; align-items:center; justify-content:space-between; margin-bottom:.6rem;
}
.loc-h3-label {
  font-size:.48rem; letter-spacing:.18em; text-transform:uppercase; color:var(--tm);
}
.loc-h3-ws {
  display:flex; align-items:center; gap:.35rem;
  font-size:.5rem; letter-spacing:.08em; text-transform:uppercase; color:rgba(154,148,133,.5);
}
.loc-h3-ws .location-status-dot { width:6px; height:6px; animation:none; }
.loc-h3-ws .dot-online  { animation:livePulse 1.8s infinite; }
.loc-h3-cells {
  display:flex; gap:0;
}
.loc-h3-cell {
  flex:1; padding:.28rem .4rem; border-right:1px solid rgba(201,168,76,.08); text-align:center;
}
.loc-h3-cell:last-child { border-right:none; }
.loc-h3-mono { font-family:monospace; font-size:.6rem !important; letter-spacing:.01em; word-break:break-all; }

/* H3 hex cell polygons — drawn by Leaflet on the map */
.h3-hex-cell { transition:opacity .45s ease; }

/* ── Recenter button ── */
.loc-recenter-btn {
  display:flex; align-items:center; justify-content:center;
  width:36px; height:36px; margin-bottom:4px;
  background:rgba(10,10,24,.92); border:1px solid var(--gb);
  border-radius:8px; color:var(--g); font-size:1rem;
  cursor:pointer; transition:all .25s; backdrop-filter:blur(10px);
  box-shadow:0 2px 8px rgba(0,0,0,.4);
}
.loc-recenter-btn:hover { background:rgba(20,20,42,.96); color:var(--gl); box-shadow:0 0 16px var(--gg); }

/* ═══════════════════════
   RESPONSIVE
   ═══════════════════════ */
@@media (max-width:900px) {
  .loc-host { height:auto; overflow:visible; }
  .loc-shell { grid-template-columns:1fr; grid-template-rows:42vh auto; overflow:visible; }
  .loc-map-col { height:42vh; min-height:220px; max-height:460px; overflow:hidden; }
  .loc-panel { border-left:none; border-top:1px solid var(--gb); overflow-y:visible; max-height:none; }
  .loc-btns { flex-direction:row; }
  .loc-btn { flex:1; }
}
@@media (max-width:600px) {
  :root { --nav-h:56px; }
  .loc-map-col { height:36vh; min-height:180px; max-height:280px; }
  .loc-head, .loc-status-wrap, .loc-coords, .loc-eta { padding:.7rem 1rem; }
  .loc-dirs { padding:.7rem 1rem; }
  .loc-btns { flex-direction:row; padding:.65rem 1rem .8rem; gap:.4rem; }
  .loc-btn { padding:.6rem .7rem; gap:.5rem; }
  .loc-btn-logo { width:22px; height:22px; }
  .loc-info { padding:.65rem 1rem 1rem; }
  .loc-corner { width:20px; height:20px; }
  .loc-head h2 { font-size:1.05rem; }
}
@@media (max-width:860px) and (max-height:500px) and (orientation:landscape) {
  .loc-map-col { height:100vw; min-height:180px; }
}
@@media (prefers-reduced-motion:reduce) {
  .loc-scan::before, .loc-badge-pulse::before, .loc-live-dot,
  .dot-online, .dot-offline, .route-origin-ping-core { animation:none; }
}
</style>
}

<div class="loc-host">
  <div class="loc-shell">

    <!-- ══════════ MAP COLUMN ══════════ -->
    <div class="loc-map-col">
      <div id="location-map" aria-label="Interactive route map to New Bethel Missionary Baptist Church"></div>

      <!-- Atmospheric overlays -->
      <div class="loc-map-grid" aria-hidden="true"></div>
      <div class="loc-scan" aria-hidden="true"></div>

      <!-- HUD corner brackets -->
      <div class="loc-corner loc-corner-tl" aria-hidden="true"></div>
      <div class="loc-corner loc-corner-tr" aria-hidden="true"></div>
      <div class="loc-corner loc-corner-bl" aria-hidden="true"></div>
      <div class="loc-corner loc-corner-br" aria-hidden="true"></div>

      <!-- Floating destination badge -->
      <div class="loc-map-badge" aria-hidden="true">
        <div class="loc-badge-pulse"></div>
        <span class="loc-badge-txt">New Bethel Missionary Baptist Church</span>
      </div>
    </div>

    <!-- ══════════ HUD PANEL ══════════ -->
    <aside class="loc-panel" id="location-directions-panel" aria-label="Navigation and directions panel">
      <div class="loc-panel-bg" aria-hidden="true"></div>

      <!-- Top accent bar -->
      <div class="loc-panel-bar" aria-hidden="true"></div>

      <!-- Header -->
      <div class="loc-head">
        <div class="loc-head-top">
          <span class="loc-head-label">Navigation HUD</span>
          <div class="loc-live"><span class="loc-live-dot"></span>Live Route</div>
        </div>
        <h2>Route to Church</h2>
        <p>New Bethel Missionary Baptist Church &bull; Winter Haven, FL</p>
      </div>

      <!-- Destination coordinates -->
      <div class="loc-coords" aria-label="Destination coordinates">
        <div class="loc-coord">
          <div class="loc-coord-lbl">Latitude</div>
          <div class="loc-coord-val">28.0497&deg;</div>
        </div>
        <div class="loc-coord">
          <div class="loc-coord-lbl">Longitude</div>
          <div class="loc-coord-val">-81.7261&deg;</div>
        </div>
        <div class="loc-coord">
          <div class="loc-coord-lbl">Timezone</div>
          <div class="loc-coord-val">EST / UTC&#8209;5</div>
        </div>
      </div>

      <!-- H3 Spatial Index + WebSocket status -->
      <div class="loc-h3">
        <div class="loc-h3-head">
          <span class="loc-h3-label">H3 Spatial Index &bull; res&nbsp;8</span>
          <div class="loc-h3-ws">
            <span class="location-status-dot dot-offline" id="h3-ws-dot" aria-hidden="true"></span>
            <span id="h3-ws-label">WS &middot; connecting</span>
          </div>
        </div>
        <div class="loc-h3-cells">
          <div class="loc-h3-cell">
            <div class="loc-coord-lbl">Your Cell</div>
            <div class="loc-coord-val loc-h3-mono" id="h3-user-cell">&mdash;</div>
          </div>
          <div class="loc-h3-cell">
            <div class="loc-coord-lbl">Church Cell</div>
            <div class="loc-coord-val loc-h3-mono" id="h3-church-cell">&mdash;</div>
          </div>
          <div class="loc-h3-cell">
            <div class="loc-coord-lbl">Distance</div>
            <div class="loc-coord-val" id="h3-ring-dist">&mdash;</div>
          </div>
        </div>
      </div>

      <!-- GPS / location status -->
      <div class="loc-status-wrap">
        <div id="location-status-card"
             data-location-source="@Model.CurrentLocation.Source"
             data-location-success="@Model.CurrentLocation.IsSuccess.ToString().ToLowerInvariant()"
             data-location-lat="@Model.CurrentLocation.Latitude"
             data-location-lon="@Model.CurrentLocation.Longitude"
             data-routing-provider="@Model.RoutingProvider"
             data-graphhopper-key="@Model.GraphHopperApiKey"
             data-destination-name="@Model.Destination.Name"
             data-destination-address="@Model.Destination.AddressLabel"
             data-destination-lat="@Model.Destination.Latitude"
             data-destination-lon="@Model.Destination.Longitude">
          <div class="location-status-header">
            <span class="location-status-dot @(Model.CurrentLocation.IsSuccess ? "dot-online" : "dot-offline")"
                  id="location-status-dot" aria-hidden="true"></span>
            <span class="location-status-title">Your Location</span>
          </div>
          <p id="location-status-text">@Model.CurrentLocation.DisplayText</p>
          <p id="location-status-meta">Source: @(Model.CurrentLocation.IsSuccess ? "server detection" : "fallback required")</p>
          <button type="button" class="location-refresh-btn" id="location-refresh-btn">
            &#128205; Use Device GPS
          </button>
        </div>
      </div>

      <!-- Route summary / ETA -->
      <div class="loc-eta">
        <div class="loc-eta-lbl">&#128337; Route Summary</div>
        <p id="location-directions-meta" aria-live="polite">Calculating your route&hellip;</p>
      </div>

      <!-- Turn-by-turn directions -->
      <div class="loc-dirs">
        <div class="loc-dirs-eye" id="location-directions-title">Turn-by-Turn</div>
        <ol class="location-directions-steps" id="location-directions-steps"></ol>
      </div>

      <!-- Open in map app -->
      <div class="loc-btns">
        <a href="@googleMapsUrl" class="loc-btn loc-btn-google"
           target="_blank" rel="noopener noreferrer"
           aria-label="Open directions in Google Maps">
          <div class="loc-btn-logo">
            <svg width="22" height="22" viewBox="0 0 192 192" xmlns="http://www.w3.org/2000/svg">
              <path d="M96 20C65.1 20 40 45.1 40 76c0 40.5 56 96 56 96s56-55.5 56-96C152 45.1 126.9 20 96 20z" fill="#EA4335"/>
              <circle cx="96" cy="76" r="22" fill="#fff"/>
              <path d="M108 76h-14v6h8.3c-1.1 4.1-4.8 7-9.3 7a10 10 0 1 1 0-20 9.9 9.9 0 0 1 6.3 2.2l4.4-4.4A16 16 0 1 0 93 92a15.7 15.7 0 0 0 15-11H108v-5z" fill="#4285F4"/>
            </svg>
          </div>
          <div class="loc-btn-label">
            <span class="loc-btn-sub">Open in</span>
            <span class="loc-btn-name">Google Maps</span>
          </div>
        </a>
        <a href="@appleMapsUrl" class="loc-btn loc-btn-apple"
           target="_blank" rel="noopener noreferrer"
           aria-label="Open directions in Apple Maps">
          <div class="loc-btn-logo">
            <svg width="22" height="22" viewBox="0 0 814 1000" xmlns="http://www.w3.org/2000/svg" fill="#fff">
              <path d="M788.1 340.9c-5.8 4.5-108.2 62.2-108.2 190.5 0 148.4 130.3 200.9 134.2 202.2-.6 3.2-20.7 71.9-68.7 141.9-42.8 61.6-87.5 123.1-155.5 123.1s-85.5-39.5-164-39.5c-76 0-103.7 40.8-165.9 40.8s-105-57.8-155.5-127.4C46 790.7 0 663 0 541.8c0-207.5 134.4-317.3 266.5-317.3 69.4 0 126.9 45.6 170.1 45.6 41.3 0 107.2-48.3 185.7-48.3zm-5.2-168.2c31.5-37.5 54.5-89.9 54.5-142.3 0-7.1-.6-14.3-1.9-20.1-51.5 1.9-112.3 34.3-149.2 75.8-28.5 32-55.1 84.4-55.1 137.5 0 7.8 1.3 15.6 1.9 18.1 3.2.6 8.4 1.3 13.6 1.3 46.5 0 102.5-30.8 136.2-70.3z"/>
            </svg>
          </div>
          <div class="loc-btn-label">
            <span class="loc-btn-sub">Open in</span>
            <span class="loc-btn-name">Apple Maps</span>
          </div>
        </a>
      </div>

      <!-- Church info -->
      <div class="loc-info">
        <div class="loc-info-row">
          <span class="loc-info-icon">&#128205;</span>
          <div>
            <div class="loc-info-lbl">Address</div>
            <div class="loc-info-val">123 Ave Y NE, Winter Haven, FL 33881</div>
          </div>
        </div>
        <div class="loc-info-row">
          <span class="loc-info-icon">&#128336;</span>
          <div>
            <div class="loc-info-lbl">Service Times</div>
            <div>
              @foreach (var t in Model.Church.ServiceTimes)
              {
                <span class="loc-chip">&#9654; @t</span>
              }
              @if (!Model.Church.ServiceTimes.Any())
              {
                <span class="loc-chip">&#9654; Sundays at 10:00 AM</span>
              }
            </div>
          </div>
        </div>
      </div>

    </aside>
  </div>
</div>

@section Scripts {
<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"
        integrity="sha256-20nQCchB9co0qIjJZRGuk2/Z9VM+kNiyxNV1lvTlZBo="
        crossorigin=""></script>
<!-- H3 geospatial index — Uber open-source hex grid library -->
<script src="https://unpkg.com/h3-js@4.1.0/dist/browser/h3-js.umd.js" crossorigin=""></script>
<!-- SignalR — two-way WebSocket channel -->
<script src="https://cdn.jsdelivr.net/npm/@@microsoft/signalr@@8.0.7/dist/browser/signalr.min.js" crossorigin=""></script>
<script src="~/js/location-route-helpers.js" asp-append-version="true"></script>
<!-- H3 overlay must load before location-route.js so it registers church:map-ready before the event fires -->
<script src="~/js/location-h3.js" asp-append-version="true"></script>
<script src="~/js/location-route.js" asp-append-version="true"></script>
}
