@page
@model ChurchWebsite.Pages.LocationModel
@{
    ViewData["Title"] = "Location";
    var googleMapsUrl = "https://www.google.com/maps?um=1&ie=UTF-8&fb=1&gl=us&sa=X&geocode=KZf_NdbSEt2IMX5147rUXvkm&daddr=123+Ave+Y+NE,+Winter+Haven,+FL+33881";
    var appleMapsUrl = "https://maps.apple.com/?daddr=123+Ave+Y+NE,+Winter+Haven,+FL+33881&dirflg=d";
}

@section Head {
<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css"
      integrity="sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY=" crossorigin="" />
<style>
/* ─────────────────────────────────────────
   LOCATION PAGE — full-screen split layout
   Wired to _Layout.cshtml:
     • &lt;header&gt; navbar is in normal flow (~64px tall)
     • &lt;main id="main-content"&gt; wraps this page
     • &lt;footer class="global-footer"&gt; is in normal flow
     • section Head -> injects into &lt;head&gt;
     • section Scripts -> injects before &lt;/body&gt;
   ───────────────────────────────────────── */

:root {
  --g: #C9A84C; --gl: #F0D080; --gg: rgba(201,168,76,.35);
  --d: #070710; --s1: #0E0E1C; --s2: #14142A;
  --tp: #F0EDE6; --tm: #9A9485; --gb: rgba(201,168,76,.18);
  --nav-h: 64px;   /* matches Bootstrap navbar padding in site.css */
  --panel-w: 400px;
}

/* ── KILL BOOTSTRAP / SITE.CSS bleed on this page ── */
/* The layout adds bg-white to non-home nav, which is correct.
   We just make sure our dark page fills correctly under it. */
#main-content {
  /* Layout's <main> has no padding by default — good, no override needed */
}

/* ── PAGE SHELL ──
   We use position:absolute within <main> so it fills the viewport
   below the navbar without fighting the layout's normal flow.
   The footer is hidden on this page by making shell cover available height. */
.loc-page-host {
  /* Takes full viewport height minus the navbar */
  height: calc(100vh - var(--nav-h));
  display: flex;
  flex-direction: column;
  overflow: hidden;
  background: var(--d);
}

/* ── SPLIT: MAP + PANEL SIDE BY SIDE ── */
.loc-shell {
  display: grid;
  grid-template-columns: 1fr var(--panel-w);
  flex: 1;
  min-height: 0; /* critical: lets grid children shrink inside flex */
  overflow: hidden;
}

/* ── MAP COLUMN ── */
.loc-map-wrap {
  position: relative;
  min-height: 0;
  overflow: hidden;
}

#location-map {
  width: 100%;
  height: 100%;
  display: block;
}

/* Floating destination badge on map */
.loc-map-badge {
  position: absolute;
  top: 1rem;
  left: 1rem;
  z-index: 500;
  background: rgba(7, 7, 16, 0.92);
  border: 1px solid var(--gb);
  border-radius: 14px;
  padding: .75rem 1rem;
  backdrop-filter: blur(14px);
  max-width: 220px;
  pointer-events: none;
}
.loc-map-badge-eye {
  font-size: .56rem;
  letter-spacing: .2em;
  text-transform: uppercase;
  color: var(--g);
  margin-bottom: .2rem;
}
.loc-map-badge-val {
  font-size: .85rem;
  font-weight: 600;
  color: #fff;
  line-height: 1.3;
}

/* ── PANEL COLUMN ──
   Uses flex column so sections stack cleanly.
   overflow-y:auto lets the whole panel scroll if content is taller
   than available height — prevents ANY overlap. */
.loc-panel {
  background: var(--s1);
  border-left: 1px solid var(--gb);
  display: flex;
  flex-direction: column;
  overflow-y: auto;
  overflow-x: hidden;
  min-height: 0;
  /* Scrollbar styling */
  scrollbar-width: thin;
  scrollbar-color: rgba(201,168,76,.25) transparent;
}
.loc-panel::-webkit-scrollbar { width: 4px; }
.loc-panel::-webkit-scrollbar-track { background: transparent; }
.loc-panel::-webkit-scrollbar-thumb { background: rgba(201,168,76,.25); border-radius: 4px; }

/* Panel header */
.loc-panel-head {
  padding: 1.5rem 1.5rem 1.1rem;
  border-bottom: 1px solid rgba(201,168,76,.1);
  flex-shrink: 0;
}
.loc-eye {
  font-size: .58rem;
  letter-spacing: .22em;
  text-transform: uppercase;
  color: var(--g);
  margin-bottom: .45rem;
  display: block;
}
.loc-panel-head h2 {
  font-size: 1.35rem;
  font-weight: 700;
  color: #fff;
  margin-bottom: .25rem;
  line-height: 1.2;
}
.loc-panel-head p {
  font-size: .82rem;
  color: var(--tm);
  line-height: 1.55;
  margin: 0;
}

/* Status card */
.loc-status-wrap {
  padding: 1.1rem 1.5rem;
  border-bottom: 1px solid rgba(201,168,76,.08);
  flex-shrink: 0;
}
#location-status-card {
  background: rgba(201,168,76,.05);
  border: 1px solid var(--gb);
  border-radius: 12px;
  padding: .9rem 1rem;
}
.location-status-header {
  display: flex;
  align-items: center;
  gap: .45rem;
  margin-bottom: .35rem;
}
.location-status-dot {
  width: 8px;
  height: 8px;
  border-radius: 50%;
  flex-shrink: 0;
}
.dot-online  { background: #4ade80; box-shadow: 0 0 8px rgba(74,222,128,.6); }
.dot-offline { background: #f87171; box-shadow: 0 0 8px rgba(248,113,113,.5); }
.location-status-title {
  font-size: .68rem;
  letter-spacing: .14em;
  text-transform: uppercase;
  color: var(--tp);
  font-weight: 600;
}
#location-status-text {
  font-size: .82rem;
  color: var(--tm);
  margin-bottom: .15rem;
  line-height: 1.45;
}
#location-status-meta {
  font-size: .65rem;
  color: rgba(154,148,133,.5);
  margin: 0;
}
.location-refresh-btn {
  margin-top: .7rem;
  background: transparent;
  border: 1px solid rgba(201,168,76,.28);
  color: var(--g);
  border-radius: 100px;
  padding: 4px 13px;
  font-size: .68rem;
  cursor: pointer;
  transition: all .25s;
  letter-spacing: .04em;
  font-family: inherit;
}
.location-refresh-btn:hover {
  background: rgba(201,168,76,.1);
  border-color: var(--g);
}

/* Directions — flex:1 so it grows to fill space, but never causes overlap */
.loc-dirs {
  padding: 1.1rem 1.5rem;
  flex: 1 0 auto; /* grow but don't shrink below content */
  min-height: 0;
}
.loc-dir-eye {
  font-size: .58rem;
  letter-spacing: .2em;
  text-transform: uppercase;
  color: var(--g);
  margin-bottom: .5rem;
  display: block;
}
#location-directions-meta {
  font-size: .8rem;
  color: var(--tm);
  margin-bottom: .65rem;
  line-height: 1.5;
}
.location-directions-steps {
  list-style: none;
  padding: 0;
  margin: 0;
  counter-reset: step;
}
.location-directions-steps li {
  font-size: .8rem;
  color: var(--tp);
  padding: .45rem 0;
  border-bottom: 1px solid rgba(201,168,76,.07);
  line-height: 1.5;
  display: flex;
  gap: .55rem;
  align-items: flex-start;
  counter-increment: step;
}
.location-directions-steps li::before {
  content: counter(step);
  min-width: 20px;
  height: 20px;
  border-radius: 50%;
  background: rgba(201,168,76,.1);
  border: 1px solid rgba(201,168,76,.25);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: .6rem;
  color: var(--g);
  flex-shrink: 0;
  margin-top: .15rem;
}

/* ── MAP APP BUTTONS ──
   Each button is its own full-width row — NO flex shorthand,
   NO flex:1 — guaranteed to never overlap or wrap oddly. */
.loc-btns {
  padding: 1rem 1.5rem 1.25rem;
  flex-shrink: 0;
  display: flex;
  flex-direction: column; /* stack vertically → zero overlap risk */
  gap: .6rem;
  border-top: 1px solid rgba(201,168,76,.08);
}

.loc-btn {
  display: flex;
  align-items: center;
  gap: .75rem;
  padding: .7rem 1rem;
  border-radius: 12px;
  font-size: .82rem;
  font-weight: 600;
  text-decoration: none;
  transition: all .28s;
  letter-spacing: .02em;
  width: 100%;
  border: 1px solid transparent;
  flex-shrink: 0;
}

/* Google Maps button — white bg with Google color text */
.loc-btn-google {
  background: #fff;
  border-color: rgba(0,0,0,.12);
  color: #1a1a1a;
}
.loc-btn-google:hover {
  background: #f8f8f8;
  box-shadow: 0 4px 18px rgba(0,0,0,.25);
  transform: translateY(-1px);
  color: #1a1a1a;
}

/* Apple Maps button — black bg authentic to Apple */
.loc-btn-apple {
  background: #1c1c1e;
  border-color: rgba(255,255,255,.12);
  color: #fff;
}
.loc-btn-apple:hover {
  background: #2c2c2e;
  border-color: rgba(255,255,255,.22);
  box-shadow: 0 4px 18px rgba(0,0,0,.4);
  transform: translateY(-1px);
  color: #fff;
}

/* Logo containers */
.loc-btn-logo {
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 28px;
  height: 28px;
}
.loc-btn-logo svg {
  display: block;
}
.loc-btn-label {
  display: flex;
  flex-direction: column;
  line-height: 1.2;
}
.loc-btn-sublabel {
  font-size: .62rem;
  font-weight: 400;
  opacity: .6;
  letter-spacing: .04em;
  text-transform: uppercase;
}
.loc-btn-name {
  font-size: .85rem;
  font-weight: 700;
  letter-spacing: .01em;
}

/* Church info rows */
.loc-info-rows {
  padding: 1rem 1.5rem 1.5rem;
  border-top: 1px solid rgba(201,168,76,.08);
  flex-shrink: 0;
}
.loc-info-row {
  display: flex;
  align-items: flex-start;
  gap: .65rem;
  padding: .45rem 0;
  border-bottom: 1px solid rgba(201,168,76,.06);
}
.loc-info-row:last-child { border-bottom: none; }
.loc-info-icon { font-size: .88rem; flex-shrink: 0; margin-top: .1rem; }
.loc-info-label {
  font-size: .58rem;
  letter-spacing: .1em;
  text-transform: uppercase;
  color: var(--tm);
  margin-bottom: .08rem;
}
.loc-info-val { font-size: .84rem; color: var(--tp); }

/* ── LEAFLET DARK THEME ── */
.leaflet-container { background: #07070f; }
.leaflet-tile { filter: brightness(.62) saturate(.45) hue-rotate(198deg); }
.leaflet-popup-content-wrapper {
  background: var(--s1);
  border: 1px solid var(--gb);
  border-radius: 14px;
  color: var(--tp);
  box-shadow: 0 20px 50px rgba(0,0,0,.7);
}
.leaflet-popup-content { font-size: .88rem; line-height: 1.6; color: var(--tp); }
.leaflet-popup-tip { background: var(--s1); }
.leaflet-popup-close-button { color: var(--tm) !important; }
.leaflet-control-zoom a {
  background: var(--s2) !important;
  color: var(--tp) !important;
  border-color: var(--gb) !important;
}
.leaflet-control-zoom a:hover { background: var(--s1) !important; }
.leaflet-control-attribution {
  background: rgba(7,7,15,.8) !important;
  color: var(--tm) !important;
}

/* ══════════════════════════════════════════
   RESPONSIVE BREAKPOINTS
   ══════════════════════════════════════════ */

/* ── TABLET / NARROW DESKTOP (< 900px) ──
   Stack map above panel. Map is ~40vh so the panel header
   is clearly visible at the bottom of the screen, inviting scroll. */
@@media (max-width: 900px) {
  .loc-page-host {
    height: auto;
    overflow: visible;
  }
  .loc-shell {
    grid-template-columns: 1fr;
    grid-template-rows: 40vh auto;
    overflow: visible;
  }
  .loc-map-wrap {
    height: 40vh;
    min-height: 220px;
    max-height: 420px;
    overflow: hidden;
    position: relative;
  }
  .loc-panel {
    border-left: none;
    border-top: 1px solid var(--gb);
    overflow-y: visible;
    max-height: none;
  }
  /* Buttons side-by-side on tablet — enough room */
  .loc-btns {
    flex-direction: row;
  }
  .loc-btn {
    flex: 1;
  }
}

/* ── PHONE (< 600px) ──
   Map is compact (~35vh) so the directions panel starts
   near the bottom of the phone screen without any scrolling.
   User can scroll down to see full directions + buttons. */
@@media (max-width: 600px) {
  :root { --nav-h: 56px; }

  .loc-map-wrap {
    /* ~35% of viewport height — compact but still readable map */
    height: 35vh;
    min-height: 180px;
    max-height: 260px;
  }

  /* Tighten all panel sections so more fits above the fold */
  .loc-panel-head { padding: .85rem 1rem .65rem; }
  .loc-panel-head h2 { font-size: 1.05rem; margin-bottom: .15rem; }
  .loc-panel-head p { font-size: .78rem; }

  .loc-status-wrap { padding: .65rem 1rem; }
  #location-status-card { padding: .7rem .85rem; }
  #location-status-text { font-size: .78rem; }
  #location-status-meta { font-size: .62rem; }
  .location-refresh-btn { font-size: .65rem; padding: 3px 11px; margin-top: .5rem; }

  .loc-dirs { padding: .65rem 1rem; }
  .loc-dir-eye { font-size: .56rem; margin-bottom: .35rem; }
  #location-directions-meta { font-size: .75rem; margin-bottom: .5rem; }
  .location-directions-steps li { font-size: .75rem; padding: .38rem 0; }

  .loc-btns {
    flex-direction: row; /* side-by-side — saves vertical space */
    padding: .65rem 1rem .75rem;
    gap: .5rem;
  }
  .loc-btn {
    flex: 1;
    padding: .6rem .75rem;
    gap: .5rem;
  }
  .loc-btn-logo { width: 22px; height: 22px; }
  .loc-btn-logo svg { width: 18px; height: 18px; }
  .loc-btn-sublabel { font-size: .56rem; }
  .loc-btn-name { font-size: .78rem; }

  .loc-info-rows { padding: .65rem 1rem 1rem; }
  .loc-info-val { font-size: .8rem; }

  .loc-map-badge { max-width: 150px; padding: .45rem .65rem; }
  .loc-map-badge-eye { font-size: .52rem; }
  .loc-map-badge-val { font-size: .75rem; }
}

/* ── LANDSCAPE PHONE (short viewport) ── */
@@media (max-width: 860px) and (max-height: 500px) and (orientation: landscape) {
  .loc-map-wrap {
    height: 100vw;
    min-height: 180px;
  }
}
</style>
}

<!-- ─── PAGE STRUCTURE ─────────────────────────
    .loc-page-host   → fills viewport below navbar
    .loc-shell       → CSS grid: map | panel
    All inside <main> rendered by _Layout.cshtml
    ────────────────────────────────────────── -->

<div class="loc-page-host">
  <div class="loc-shell">

    <!-- MAP COLUMN -->
    <div class="loc-map-wrap">
      <div id="location-map" aria-label="Route map to church"></div>
      <div class="loc-map-badge" aria-hidden="true">
        <div class="loc-map-badge-eye">Destination</div>
        <div class="loc-map-badge-val">New Bethel Missionary Baptist Church</div>
      </div>
    </div>

    <!-- PANEL COLUMN -->
    <aside class="loc-panel" aria-label="Directions panel">

      <!-- Header -->
      <div class="loc-panel-head">
        <span class="loc-eye">Find Us</span>
        <h2>Route to Church</h2>
        <p>Winter Haven, Florida</p>
      </div>

      <!-- GPS / Location status -->
      <div class="loc-status-wrap">
        <div class="location-status-card" id="location-status-card"
             data-location-source="@Model.CurrentLocation.Source"
             data-location-success="@Model.CurrentLocation.IsSuccess.ToString().ToLowerInvariant()"
             data-location-lat="@Model.CurrentLocation.Latitude"
             data-location-lon="@Model.CurrentLocation.Longitude"
             data-routing-provider="@Model.RoutingProvider"
             data-graphhopper-key="@Model.GraphHopperApiKey"
             data-destination-name="@Model.Destination.Name"
             data-destination-address="@Model.Destination.AddressLabel"
             data-destination-lat="@Model.Destination.Latitude"
             data-destination-lon="@Model.Destination.Longitude">
          <div class="location-status-header">
            <span class="location-status-dot @(Model.CurrentLocation.IsSuccess ? "dot-online" : "dot-offline")"
                  id="location-status-dot" aria-hidden="true"></span>
            <span class="location-status-title">Your Location</span>
          </div>
          <p id="location-status-text">@Model.CurrentLocation.DisplayText</p>
          <p id="location-status-meta">Source: @(Model.CurrentLocation.IsSuccess ? "server detection" : "fallback required")</p>
          <button type="button" class="location-refresh-btn" id="location-refresh-btn">
            📍 Use Device GPS
          </button>
        </div>
      </div>

      <!-- Turn-by-turn directions -->
      <div class="loc-dirs">
        <span class="loc-dir-eye" id="location-directions-title">Directions</span>
        <p id="location-directions-meta" aria-live="polite">Finding your best route...</p>
        <ol class="location-directions-steps" id="location-directions-steps"></ol>
      </div>

      <!-- MAP APP BUTTONS -->
      <div class="loc-btns">

        <!-- Google Maps button -->
        <a href="@googleMapsUrl" class="loc-btn loc-btn-google"
           target="_blank" rel="noopener noreferrer"
           aria-label="Open route in Google Maps">
          <div class="loc-btn-logo">
            <svg width="22" height="22" viewBox="0 0 192 192" xmlns="http://www.w3.org/2000/svg">
              <!-- Google Maps pin shape -->
              <path d="M96 20C65.1 20 40 45.1 40 76c0 40.5 56 96 56 96s56-55.5 56-96C152 45.1 126.9 20 96 20z" fill="#EA4335"/>
              <circle cx="96" cy="76" r="22" fill="#fff"/>
              <!-- G letterform inside circle -->
              <path d="M108 76h-14v6h8.3c-1.1 4.1-4.8 7-9.3 7a10 10 0 1 1 0-20 9.9 9.9 0 0 1 6.3 2.2l4.4-4.4A16 16 0 1 0 93 92a15.7 15.7 0 0 0 15-11H108v-5z" fill="#4285F4"/>
            </svg>
          </div>
          <div class="loc-btn-label">
            <span class="loc-btn-sublabel">Open in</span>
            <span class="loc-btn-name">Google Maps</span>
          </div>
        </a>

        <!-- Apple Maps button -->
        <a href="@appleMapsUrl" class="loc-btn loc-btn-apple"
           target="_blank" rel="noopener noreferrer"
           aria-label="Open route in Apple Maps">
          <div class="loc-btn-logo">
            <svg width="22" height="22" viewBox="0 0 814 1000" xmlns="http://www.w3.org/2000/svg" fill="#fff">
              <path d="M788.1 340.9c-5.8 4.5-108.2 62.2-108.2 190.5 0 148.4 130.3 200.9 134.2 202.2-.6 3.2-20.7 71.9-68.7 141.9-42.8 61.6-87.5 123.1-155.5 123.1s-85.5-39.5-164-39.5c-76 0-103.7 40.8-165.9 40.8s-105-57.8-155.5-127.4C46 790.7 0 663 0 541.8c0-207.5 134.4-317.3 266.5-317.3 69.4 0 126.9 45.6 170.1 45.6 41.3 0 107.2-48.3 185.7-48.3zm-5.2-168.2c31.5-37.5 54.5-89.9 54.5-142.3 0-7.1-.6-14.3-1.9-20.1-51.5 1.9-112.3 34.3-149.2 75.8-28.5 32-55.1 84.4-55.1 137.5 0 7.8 1.3 15.6 1.9 18.1 3.2.6 8.4 1.3 13.6 1.3 46.5 0 102.5-30.8 136.2-70.3z"/>
            </svg>
          </div>
          <div class="loc-btn-label">
            <span class="loc-btn-sublabel">Open in</span>
            <span class="loc-btn-name">Apple Maps</span>
          </div>
        </a>

      </div>

      <!-- Church info -->
      <div class="loc-info-rows">
        <div class="loc-info-row">
          <span class="loc-info-icon">📍</span>
          <div>
            <div class="loc-info-label">Address</div>
            <div class="loc-info-val">123 Ave Y NE, Winter Haven, FL 33881</div>
          </div>
        </div>
        @foreach (var t in Model.Church.ServiceTimes) {
          <div class="loc-info-row">
            <span class="loc-info-icon">🕐</span>
            <div>
              <div class="loc-info-label">Service Time</div>
              <div class="loc-info-val">@t</div>
            </div>
          </div>
        }
      </div>

    </aside>
  </div><!-- end .loc-shell -->
</div><!-- end .loc-page-host -->

@section Scripts {
<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"
        integrity="sha256-20nQCchB9co0qIjJZRGuk2/Z9VM+kNiyxNV1lvTlZBo="
        crossorigin=""></script>
<script src="~/js/location-route-helpers.js" asp-append-version="true"></script>
<script src="~/js/location-route.js" asp-append-version="true"></script>
}
