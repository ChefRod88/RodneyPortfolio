@* WATCH LIVE PAGE — New Bethel Missionary Baptist Church *@
@page
@model LiveModel
@{
    ViewData["Title"] = "Watch Live";
    var hasStreamUrl = !string.IsNullOrWhiteSpace(Model.Church.LiveStreamUrl);
    var placeholderImg = !string.IsNullOrWhiteSpace(Model.Church.LiveStreamPlaceholderImageUrl) ? Model.Church.LiveStreamPlaceholderImageUrl : Model.Church.HeroImageUrl;
    var youtubeUrl = !string.IsNullOrWhiteSpace(Model.Church.SocialMedia.YouTube) ? Model.Church.SocialMedia.YouTube : "https://www.youtube.com/@NewBethelMissionaryBaptist";
    var serviceTimes = string.Join(" • ", Model.Church.ServiceTimes);
}

@section Head {
<link rel="stylesheet" href="~/css/pages/live.css" asp-append-version="true" />
}

<div class="lv-hero sr">
  <div class="lv-eyebrow"><span class="lv-live-dot"></span>Live &amp; Online Services</div>
  <h1>Watch Live</h1>
  <p class="lv-hero-sub">Join us for worship from anywhere. Stream with us on Facebook or YouTube every service.</p>
</div>

<div class="lv-container">
  <div class="lv-grid">
    <div class="lv-player sr">
      <div class="lv-ratio">
        @if(hasStreamUrl){
          <iframe src="@Model.Church.LiveStreamUrl" title="Live Stream" allowfullscreen allow="accelerometer;autoplay;clipboard-write;encrypted-media;gyroscope;picture-in-picture" style="position:absolute;inset:0;width:100%;height:100%;border:none"></iframe>
        } else {
          <div style="background:var(--s2);display:flex;flex-direction:column;align-items:center;justify-content:center;text-align:center;padding:3rem;color:var(--tm)">
            <div style="font-size:3rem;margin-bottom:1rem">📺</div>
            <h3 style="color:#fff;margin-bottom:.75rem">Stream Coming Soon</h3>
            <p style="font-size:.88rem;max-width:380px;line-height:1.7">Set <code>Church:LiveStreamUrl</code> in appsettings.json to embed your live stream here.</p>
          </div>
        }
      </div>
    </div>
    <div class="sr">
      <div class="lv-glass">
        <div class="lv-info-pad">
          <span class="lv-card-eye">Service Information</span>
          @foreach(var t in Model.Church.ServiceTimes){
            <div class="lv-info-row"><span class="lv-info-icon">🕐</span><div><div class="lv-info-label">Service Time</div><div class="lv-info-val">@t</div></div></div>
          }
          <div class="lv-info-row"><span class="lv-info-icon">📍</span><div><div class="lv-info-label">Location</div><div class="lv-info-val">Winter Haven, Florida</div></div></div>
        </div>
      </div>
      <div class="lv-glass">
        <div class="lv-info-pad">
          <span class="lv-card-eye">Watch On Your Platform</span>
          <a href="@youtubeUrl" target="_blank" rel="noopener noreferrer" class="lv-stream-btn"><div class="lv-stream-icon lv-yt-bg">▶</div><div class="lv-stream-label"><span>Stream on</span>YouTube</div></a>
          <a href="https://www.facebook.com" target="_blank" rel="noopener noreferrer" class="lv-stream-btn"><div class="lv-stream-icon lv-fb-bg">f</div><div class="lv-stream-label"><span>Stream on</span>Facebook</div></a>
        </div>
      </div>
    </div>
  </div>
</div>

<div class="lv-upcoming sr">
  <div class="lv-upcoming-inner">
    <span class="lv-section-eye">Join Us In Person</span>
    <h2>Service Times</h2>
    <div class="lv-times-grid">
      @foreach(var t in Model.Church.ServiceTimes){
        <div class="lv-time-card"><div class="lv-time-day">Weekly Service</div><div class="lv-time-val">@t</div></div>
      }
      @if(!Model.Church.ServiceTimes.Any()){<div class="lv-time-card"><div class="lv-time-day">Sunday</div><div class="lv-time-val">10:00 AM</div></div>}
    </div>
  </div>
</div>

<div class="lv-past sr">
  <h3>Missed a Service?</h3>
  <p>Browse our full sermon library and never miss a message from God&rsquo;s Word.</p>
  <a asp-page="/Sermons/Index" class="btn-gold" style="margin-right:.75rem">Browse Past Sermons &rarr;</a>
  <button onclick="openGiveModal()" class="btn-gold" style="background:linear-gradient(135deg,#00D632,#009922);box-shadow:0 8px 24px rgba(0,214,50,.35);margin-top:.75rem">&#9829; Give Online &rarr;</button>
</div>

@section Scripts {
<script src="~/js/pages/live.js" asp-append-version="true"></script>
}
