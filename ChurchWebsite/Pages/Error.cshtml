@* ERROR PAGE — New Bethel Missionary Baptist Church *@
@page
@model ErrorModel
@{
    ViewData["Title"] = "Error";
}

@section Head {
<meta name="description" content="An unexpected error occurred on the New Bethel Missionary Baptist Church website. Please return home and try again.">
<meta name="robots" content="noindex, nofollow">
<link rel="stylesheet" href="~/css/pages/error.css" asp-append-version="true" />
}

<canvas class="err-canvas" id="errCanvas"></canvas>
<div class="err-page">
  <span class="err-code">500</span>
  <h1 class="err-title">Something Went Wrong</h1>
  <div class="err-divider"></div>
  <p class="err-sub">An unexpected error occurred. Please try again or return home — we apologize for the inconvenience.</p>
  <a href="/" class="btn-gold">← Return Home</a>
  @if(Model.ShowRequestId){
    <div class="err-req"><strong style="display:block;margin-bottom:.35rem;color:var(--tp)">Request ID</strong><code>@Model.RequestId</code></div>
  }
  <div class="err-dev">
    <strong>Development Mode</strong><br>
    Swap to the <strong>Development</strong> environment for detailed error info. Set <strong>ASPNETCORE_ENVIRONMENT</strong> to <strong>Development</strong> and restart the app.
  </div>
</div>

@section Scripts {
<script src="~/js/pages/error.js" asp-append-version="true"></script>
}
