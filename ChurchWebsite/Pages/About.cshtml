@* USE CASE: About page - Leadership, History, Beliefs *@
@page
@model AboutModel
@{
    ViewData["Title"] = "About Us";
}

<style>
    :root {
        --gold: #C9A84C;
        --gold-light: #F0D080;
        --gold-glow: rgba(201, 168, 76, 0.35);
        --deep: #0A0A0F;
        --surface: #10101A;
        --surface2: #16162A;
        --surface3: #1C1C35;
        --text-primary: #F0EDE6;
        --text-muted: #9A9485;
        --glass: rgba(255,255,255,0.04);
        --glass-border: rgba(201,168,76,0.2);
    }
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body { background: var(--deep); color: var(--text-primary); font-family: 'Segoe UI', system-ui, sans-serif; overflow-x: hidden; }

    /* HERO */
    .hero {
        position: relative; min-height: 100vh; display: flex; align-items: center;
        justify-content: center; overflow: hidden;
        background: radial-gradient(ellipse 80% 60% at 50% 0%, rgba(201,168,76,0.12) 0%, transparent 70%),
                    linear-gradient(180deg, #0A0A0F 0%, #0D0D1F 100%);
    }
    .hero-grid {
        position: absolute; inset: 0;
        background-image: linear-gradient(rgba(201,168,76,0.06) 1px, transparent 1px),
                          linear-gradient(90deg, rgba(201,168,76,0.06) 1px, transparent 1px);
        background-size: 60px 60px;
        mask-image: radial-gradient(ellipse 70% 70% at 50% 50%, black 30%, transparent 100%);
    }
    .hero-orb { position: absolute; border-radius: 50%; filter: blur(80px); pointer-events: none; }
    .hero-orb-1 { width: 600px; height: 600px; top: -200px; left: -100px; background: radial-gradient(circle, rgba(201,168,76,0.15), transparent 70%); }
    .hero-orb-2 { width: 400px; height: 400px; bottom: -100px; right: -50px; background: radial-gradient(circle, rgba(58,123,255,0.1), transparent 70%); }
    .hero-content { position: relative; text-align: center; padding: 2rem; max-width: 800px; z-index: 2; }
    .hero-eyebrow {
        display: inline-flex; align-items: center; gap: 10px;
        background: var(--glass); border: 1px solid var(--glass-border); border-radius: 100px;
        padding: 6px 20px; font-size: 0.75rem; letter-spacing: 0.2em; text-transform: uppercase;
        color: var(--gold); margin-bottom: 1.5rem; backdrop-filter: blur(10px);
    }
    .hero-eyebrow::before { content:''; width:6px; height:6px; background:var(--gold); border-radius:50%; box-shadow: 0 0 8px var(--gold); animation: pulse 2s infinite; }
    @@keyframes pulse { 0%,100%{opacity:1;box-shadow:0 0 6px var(--gold)} 50%{opacity:.4;box-shadow:0 0 18px var(--gold)} }
    .hero h1 {
        font-size: clamp(2.5rem, 7vw, 5.5rem); font-weight: 800; line-height: 1.05; letter-spacing: -0.02em;
        background: linear-gradient(135deg, #F0D080 0%, #C9A84C 40%, #F0D080 70%, #C9A84C 100%);
        -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; margin-bottom: 0.5rem;
    }
    .hero-sub { font-size: clamp(1rem, 2vw, 1.2rem); color: var(--text-muted); margin-bottom: 1rem; letter-spacing: 0.05em; }
    .hero-location { display: inline-flex; align-items: center; gap: 6px; color: var(--gold-light); font-size: 0.9rem; opacity: 0.8; }
    .scroll-indicator {
        position: absolute; bottom: 2rem; left: 50%; transform: translateX(-50%);
        display: flex; flex-direction: column; align-items: center; gap: 8px;
        color: var(--text-muted); font-size: 0.7rem; letter-spacing: 0.15em; text-transform: uppercase;
        animation: float 3s ease-in-out infinite;
    }
    .scroll-indicator .line { width: 1px; height: 40px; background: linear-gradient(to bottom, var(--gold), transparent); }
    @@keyframes float { 0%,100%{transform:translateX(-50%) translateY(0)} 50%{transform:translateX(-50%) translateY(8px)} }

    /* SECTIONS */
    section { padding: 100px 2rem; }
    .container { max-width: 1200px; margin: 0 auto; }
    .section-label {
        display: inline-flex; align-items: center; gap: 12px;
        font-size: 0.7rem; letter-spacing: 0.3em; text-transform: uppercase; color: var(--gold); margin-bottom: 1rem;
    }
    .section-label::before, .section-label::after { content:''; flex:1; height:1px; background:linear-gradient(90deg, var(--gold), transparent); }
    .section-label::before { width: 30px; }
    .section-title {
        font-size: clamp(2rem, 4vw, 3.2rem); font-weight: 700; line-height: 1.1; margin-bottom: 1rem;
        background: linear-gradient(135deg, #fff 0%, #C9A84C 100%);
        -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;
    }
    .section-divider { width: 60px; height: 3px; background: linear-gradient(90deg, var(--gold), transparent); margin-bottom: 3rem; border-radius: 2px; }

    /* PASTOR */
    #leadership { background: var(--surface); }
    .pastor-grid { display: grid; grid-template-columns: minmax(0, 560px); gap: 2rem; justify-content: center; }
    @@media(max-width:768px) { .pastor-grid { grid-template-columns: 1fr; } }
    .pastor-card {
        background: linear-gradient(160deg, rgba(255,255,255,0.04) 0%, rgba(16,16,26,0.9) 100%);
        border: 1px solid rgba(201,168,76,0.12); border-radius: 36px;
        padding: 3.5rem 2.5rem 3rem; text-align: center;
        position: relative; overflow: hidden;
        transition: all 0.5s cubic-bezier(0.23,1,0.32,1);
        backdrop-filter: blur(20px);
    }
    .pastor-card::before {
        content: ''; position: absolute; top: 0; left: 20%; right: 20%; height: 1px;
        background: linear-gradient(90deg, transparent, rgba(201,168,76,0.7), transparent);
        transition: left 0.5s, right 0.5s;
    }
    .pastor-card:hover::before { left: 0; right: 0; }
    .pastor-card:hover {
        border-color: rgba(201,168,76,0.5); transform: translateY(-14px);
        box-shadow: 0 70px 140px rgba(0,0,0,0.65), 0 0 100px rgba(201,168,76,0.12);
        background: linear-gradient(160deg, rgba(201,168,76,0.07) 0%, rgba(16,16,26,0.95) 100%);
    }
    /* Circular photo container */
    .pastor-image-wrap {
        position: relative; width: 220px; height: 220px;
        margin: 0 auto 2.2rem; border-radius: 50%;
        background: none;
        display: block; overflow: visible;
    }
    /* Ambient glow */
    .pastor-avatar-glow {
        position: absolute; inset: -30px; border-radius: 50%;
        background: radial-gradient(circle, rgba(201,168,76,0.3) 0%, transparent 70%);
        opacity: 0; filter: blur(22px); transition: opacity 0.5s;
    }
    .pastor-card:hover .pastor-avatar-glow { opacity: 1; }
    /* Spinning ring */
    .pastor-spin-ring {
        position: absolute; inset: -5px; border-radius: 50%;
        background: conic-gradient(from 0deg, var(--gold) 0%, transparent 35%, var(--gold-light) 55%, transparent 75%, var(--gold) 100%);
        opacity: 0; transition: opacity 0.4s;
        animation: spin 3s linear infinite;
    }
    .pastor-card:hover .pastor-spin-ring { opacity: 1; }
    /* Solid bg to mask ring center */
    .pastor-avatar-bg {
        position: absolute; inset: 4px; border-radius: 50%;
        background: var(--surface); z-index: 1;
    }
    .pastor-avatar {
        position: relative; width: 100%; height: 100%; border-radius: 50%;
        background: linear-gradient(135deg, var(--gold), #8B6914);
        display: flex; align-items: center; justify-content: center;
        font-size: 4rem; font-weight: 700; color: var(--deep);
        border: 3px solid rgba(201,168,76,0.4);
        z-index: 2; transition: border-color 0.4s;
    }
    .pastor-card:hover .pastor-avatar { border-color: var(--gold); box-shadow: 0 0 50px var(--gold-glow); }
    /* Photo — object-position shows head + half torso */
    .pastor-photo {
        position: absolute; inset: 0; width: 100%; height: 100%;
        object-fit: cover; object-position: center 12%;
        border-radius: 50%; z-index: 3;
        border: 3px solid rgba(201,168,76,0.3);
        transition: border-color 0.4s;
    }
    .pastor-card:hover .pastor-photo { border-color: var(--gold); }
    .deacon-avatar-wrap { position: relative; width: 64px; height: 64px; margin: 0 auto 0.8rem; }
    .deacon-avatar-wrap .deacon-avatar { margin: 0; width: 100%; height: 100%; }
    .deacon-photo { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; object-position: center top; border-radius: 50%; z-index: 2; }
    .music-avatar { position: relative; overflow: hidden; }
    .music-photo { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; object-position: center top; border-radius: 24px; z-index: 2; }
    .pastor-body { padding: 0; }
    .pastor-role { font-size: 0.7rem; letter-spacing: 0.28em; text-transform: uppercase; color: var(--gold); margin-bottom: 0.5rem; }
    .pastor-name { font-size: 1.9rem; font-weight: 700; margin-bottom: 0.9rem; color: #fff; letter-spacing: -0.01em; }
    .pastor-bio { font-size: 0.92rem; color: var(--text-muted); line-height: 1.75; max-width: 460px; margin: 0 auto; }

    /* MINISTERS */
    #ministers { background: var(--deep); }
    .ministers-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(260px, 1fr)); gap: 2rem; }
    .minister-card {
        background: linear-gradient(160deg, rgba(255,255,255,0.04) 0%, rgba(16,16,26,0.9) 100%);
        border: 1px solid rgba(201,168,76,0.12); border-radius: 32px;
        padding: 3rem 2rem 2.5rem; text-align: center;
        transition: all 0.5s cubic-bezier(0.23,1,0.32,1);
        position: relative; overflow: hidden; cursor: pointer;
        backdrop-filter: blur(20px);
    }
    .minister-card::before {
        content: ''; position: absolute; top: 0; left: 25%; right: 25%; height: 1px;
        background: linear-gradient(90deg, transparent, rgba(201,168,76,0.6), transparent);
        transition: left 0.5s, right 0.5s;
    }
    .minister-card:hover::before { left: 0; right: 0; }
    .minister-card:hover {
        border-color: rgba(201,168,76,0.45); transform: translateY(-18px) scale(1.01);
        box-shadow: 0 60px 120px rgba(0,0,0,0.65), 0 0 80px rgba(201,168,76,0.1);
        background: linear-gradient(160deg, rgba(201,168,76,0.06) 0%, rgba(16,16,26,0.95) 100%);
    }
    /* Photo wrap */
    .minister-avatar-wrap {
        position: relative; width: 160px; height: 160px; margin: 0 auto 2rem;
    }
    /* Pulsing ambient glow behind the photo */
    .minister-avatar-glow {
        position: absolute; inset: -24px; border-radius: 50%;
        background: radial-gradient(circle, rgba(201,168,76,0.28) 0%, transparent 70%);
        opacity: 0; filter: blur(18px);
        transition: opacity 0.5s;
    }
    .minister-card:hover .minister-avatar-glow { opacity: 1; }
    /* Spinning conic ring */
    .minister-avatar-ring {
        position: absolute; inset: -4px; border-radius: 50%;
        background: conic-gradient(from 0deg, var(--gold) 0%, transparent 35%, var(--gold-light) 55%, transparent 75%, var(--gold) 100%);
        opacity: 0; transition: opacity 0.4s;
        animation: spin 3s linear infinite;
    }
    .minister-card:hover .minister-avatar-ring { opacity: 1; }
    @@keyframes spin { to { transform: rotate(360deg); } }
    /* Solid bg circle to mask ring center */
    .minister-avatar-bg {
        position: absolute; inset: 3px; border-radius: 50%; background: var(--deep); z-index: 1;
    }
    .minister-avatar {
        position: relative; width: 100%; height: 100%; border-radius: 50%;
        background: linear-gradient(135deg, #1e1e38, #2a2a4a);
        border: 2px solid rgba(201,168,76,0.25);
        display: flex; align-items: center; justify-content: center;
        font-size: 2.8rem; font-weight: 700; color: var(--gold-light);
        z-index: 2; transition: border-color 0.4s;
    }
    .minister-card:hover .minister-avatar { border-color: var(--gold); }
    .minister-photo {
        position: absolute; inset: 0; width: 100%; height: 100%;
        object-fit: cover; object-position: center top;
        border-radius: 50%; z-index: 3;
        border: 2px solid rgba(201,168,76,0.25);
        transition: border-color 0.4s;
    }
    .minister-card:hover .minister-photo { border-color: var(--gold); }
    .minister-role { font-size: 0.65rem; letter-spacing: 0.28em; text-transform: uppercase; color: var(--gold); margin-bottom: 0.4rem; }
    .minister-name { font-size: 1.25rem; font-weight: 700; color: #fff; margin-bottom: 0.65rem; letter-spacing: -0.01em; }
    .minister-desc { font-size: 0.85rem; color: var(--text-muted); line-height: 1.7; }

    /* DEACONS */
    #deacons { background: var(--surface); }
    .deacon-tabs { display:flex;gap:4px;background:var(--surface2);border-radius:12px;padding:4px;margin-bottom:2.5rem;max-width:360px;border:1px solid var(--glass-border); }
    .tab-btn { flex:1;padding:0.6rem 1rem;border:none;border-radius:9px;background:transparent;color:var(--text-muted);font-size:0.85rem;font-weight:600;cursor:pointer;transition:all 0.3s;letter-spacing:0.05em; }
    .tab-btn.active { background:linear-gradient(135deg,var(--gold),#8B6914);color:var(--deep);box-shadow:0 4px 20px var(--gold-glow); }
    .tab-panel { display: none; }
    .tab-panel.active { display: grid; grid-template-columns: repeat(auto-fit, minmax(180px, 1fr)); gap: 1.2rem; }
    .deacon-card { background:var(--surface2);border:1px solid var(--glass-border);border-radius:16px;padding:1.5rem 1rem;text-align:center;transition:all 0.3s;position:relative; }
    .deacon-card:hover { border-color:var(--gold);transform:translateY(-4px);box-shadow:0 15px 40px rgba(0,0,0,0.3),0 0 20px var(--gold-glow); }
    .deacon-badge { position:absolute;top:12px;right:12px;width:8px;height:8px;border-radius:50%;background:var(--gold);box-shadow:0 0 8px var(--gold); }
    .deacon-avatar { width:64px;height:64px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:1.3rem;font-weight:700;margin:0 auto 0.8rem;color:var(--deep); }
    .deacon-card.male .deacon-avatar { background:linear-gradient(135deg,#3A7BFF,#1a3a8f);color:#fff; }
    .deacon-card.female .deacon-avatar { background:linear-gradient(135deg,var(--gold),#8B6914); }
    .deacon-name { font-size: 0.9rem; font-weight: 600; color: #fff; margin-bottom: 0.2rem; }
    .deacon-title { font-size: 0.7rem; letter-spacing: 0.1em; color: var(--text-muted); text-transform: uppercase; }

    /* MUSIC */
    #music { background: var(--deep); }
    .music-card {
        background: linear-gradient(135deg, var(--surface2) 0%, #1a1a3a 100%);
        border: 1px solid var(--glass-border); border-radius: 28px; padding: 3rem;
        display: grid; grid-template-columns: auto 1fr; gap: 3rem; align-items: center;
        position: relative; overflow: hidden; transition: all 0.4s;
    }
    @@media(max-width:640px) { .music-card { grid-template-columns: 1fr; text-align: center; } }
    .music-card::before { content:'♪';position:absolute;right:3rem;top:50%;transform:translateY(-50%);font-size:10rem;color:rgba(201,168,76,0.04);pointer-events:none;line-height:1; }
    .music-card:hover { border-color: var(--gold); box-shadow: 0 30px 80px rgba(0,0,0,0.5), 0 0 50px var(--gold-glow); }
    .music-avatar { width:120px;height:120px;border-radius:24px;background:linear-gradient(135deg,var(--gold),#5a3e00);display:flex;align-items:center;justify-content:center;font-size:2.5rem;font-weight:800;color:var(--deep);border:2px solid rgba(201,168,76,0.4);box-shadow:0 0 40px var(--gold-glow);flex-shrink:0; }
    .music-info .role { font-size:0.7rem;letter-spacing:0.25em;text-transform:uppercase;color:var(--gold);margin-bottom:0.4rem; }
    .music-info h3 { font-size:2rem;font-weight:700;color:#fff;margin-bottom:0.75rem; }
    .music-info p { color:var(--text-muted);line-height:1.7;max-width:560px; }
    .music-tags { display:flex;flex-wrap:wrap;gap:8px;margin-top:1rem; }
    .music-tag { background:rgba(201,168,76,0.1);border:1px solid rgba(201,168,76,0.25);border-radius:100px;padding:4px 14px;font-size:0.75rem;color:var(--gold-light);letter-spacing:0.05em; }

    /* HISTORY */
    #history { background: var(--surface); }
    .timeline { position:relative;padding-left:2rem; }
    .timeline::before { content:'';position:absolute;left:0;top:0;bottom:0;width:2px;background:linear-gradient(to bottom,var(--gold),rgba(201,168,76,0.1));border-radius:2px; }
    .timeline-item { position:relative;padding:0 0 2.5rem 2rem;opacity:0;transform:translateX(-20px);transition:all 0.5s cubic-bezier(0.23,1,0.32,1); }
    .timeline-item.visible { opacity:1;transform:translateX(0); }
    .timeline-dot { position:absolute;left:-2.55rem;top:4px;width:14px;height:14px;border-radius:50%;background:var(--gold);border:3px solid var(--surface);box-shadow:0 0 12px var(--gold); }
    .timeline-year { font-size:0.7rem;letter-spacing:0.2em;color:var(--gold);text-transform:uppercase;margin-bottom:0.3rem; }
    .timeline-event { font-size:1rem;font-weight:600;color:#fff;margin-bottom:0.3rem; }
    .timeline-detail { font-size:0.88rem;color:var(--text-muted);line-height:1.6; }

    /* BELIEFS */
    #beliefs { background: var(--deep); }
    .beliefs-grid { display:grid;grid-template-columns:repeat(auto-fit,minmax(280px,1fr));gap:1.5rem; }
    .belief-card { background:var(--surface);border:1px solid var(--glass-border);border-radius:20px;padding:2rem;position:relative;overflow:hidden;transition:all 0.35s cubic-bezier(0.23,1,0.32,1);cursor:pointer; }
    .belief-card:hover { border-color:var(--gold);background:var(--surface2);transform:translateY(-4px);box-shadow:0 20px 50px rgba(0,0,0,0.4),0 0 30px var(--gold-glow); }
    .belief-number { position:absolute;top:1rem;right:1.5rem;font-size:3.5rem;font-weight:800;color:rgba(201,168,76,0.06);line-height:1;transition:color 0.3s; }
    .belief-card:hover .belief-number { color:rgba(201,168,76,0.12); }
    .belief-icon { font-size:1.8rem;margin-bottom:0.8rem; }
    .belief-title { font-size:1rem;font-weight:700;color:#fff;margin-bottom:0.5rem; }
    .belief-text { font-size:0.85rem;color:var(--text-muted);line-height:1.65; }

    /* CTA */
    .cta-section { background:linear-gradient(135deg,var(--surface2),#0D0D1F);padding:80px 2rem;text-align:center;border-top:1px solid var(--glass-border);position:relative;overflow:hidden; }
    .cta-section::before { content:'';position:absolute;inset:0;background:radial-gradient(ellipse 60% 60% at 50% 0%,rgba(201,168,76,0.08),transparent); }
    .cta-section h2 { font-size:2.5rem;font-weight:700;margin-bottom:0.75rem;position:relative; }
    .cta-section p { color:var(--text-muted);margin-bottom:2rem;position:relative; }
    .btn-gold { display:inline-flex;align-items:center;gap:10px;background:linear-gradient(135deg,var(--gold),#8B6914);color:var(--deep);border:none;padding:14px 36px;border-radius:100px;font-size:0.9rem;font-weight:700;letter-spacing:0.05em;cursor:pointer;text-decoration:none;transition:all 0.3s;position:relative; }
    .btn-gold:hover { transform:translateY(-2px);box-shadow:0 15px 40px var(--gold-glow); }
    /* Give CTA */
    .give-cta-wrap { margin-top:1.5rem; }
    .give-cta-btn { display:inline-flex;align-items:center;gap:10px;background:linear-gradient(135deg,#00D632,#009922);color:#fff;border:none;padding:14px 36px;border-radius:100px;font-size:0.9rem;font-weight:700;letter-spacing:0.05em;cursor:pointer;text-decoration:none;transition:all 0.3s;box-shadow:0 8px 24px rgba(0,214,50,0.35); }
    .give-cta-btn:hover { transform:translateY(-2px);box-shadow:0 14px 36px rgba(0,214,50,0.55);color:#fff; }

    /* NAV DOTS */
    .nav-dots { position:fixed;right:2rem;top:50%;transform:translateY(-50%);display:flex;flex-direction:column;gap:12px;z-index:100; }
    @@media(max-width:768px) { .nav-dots { display:none; } }
    .nav-dot { width:8px;height:8px;border-radius:50%;background:rgba(201,168,76,0.3);cursor:pointer;transition:all 0.3s;position:relative; }
    .nav-dot::before { content:attr(data-label);position:absolute;right:20px;top:50%;transform:translateY(-50%);font-size:0.7rem;color:var(--gold);white-space:nowrap;opacity:0;transition:opacity 0.3s;letter-spacing:0.1em; }
    .nav-dot:hover::before { opacity:1; }
    .nav-dot.active { background:var(--gold);box-shadow:0 0 10px var(--gold);transform:scale(1.4); }

    /* UTILS */
    .text-center { text-align: center; }
    .animate-in { opacity:0;transform:translateY(30px);transition:all 0.6s cubic-bezier(0.23,1,0.32,1); }
    .animate-in.visible { opacity:1;transform:translateY(0); }
</style>

<!-- NAV DOTS -->
<nav class="nav-dots" id="navDots">
    <div class="nav-dot active" data-label="Home"       data-target="hero"       onclick="scrollToSection('hero')"></div>
    <div class="nav-dot"        data-label="Leadership" data-target="leadership" onclick="scrollToSection('leadership')"></div>
    <div class="nav-dot"        data-label="Ministers"  data-target="ministers"  onclick="scrollToSection('ministers')"></div>
    <div class="nav-dot"        data-label="Music"      data-target="music"      onclick="scrollToSection('music')"></div>
    <div class="nav-dot"        data-label="History"    data-target="history"    onclick="scrollToSection('history')"></div>
    <div class="nav-dot"        data-label="Beliefs"    data-target="beliefs"    onclick="scrollToSection('beliefs')"></div>
</nav>


<!-- LEADERSHIP -->
<section id="leadership">
    <div class="container">
        <div class="text-center animate-in">
            <div class="section-label">Our Shepherds</div>
            <h2 class="section-title">Pastoral Leadership</h2>
            <div class="section-divider" style="margin:0 auto 3rem;"></div>
        </div>
        <div class="pastor-grid">
            <div class="pastor-card animate-in">
                <div class="pastor-image-wrap">
                    <div class="pastor-avatar-glow"></div>
                    <div class="pastor-spin-ring"></div>
                    <div class="pastor-avatar-bg"></div>
                    <div class="pastor-avatar" id="pastor-avatar-1">P</div>
                    @* Drop photo at wwwroot/images/pastor.jpeg to replace placeholder *@
                    <img src="/images/pastor.jpeg" alt="Senior Pastor" class="pastor-photo"
