@page
@{
    Layout = "_Layout";
    ViewData["Title"] = "About";
}
@section Head {
<meta name="description" content="Learn about New Bethel Missionary Baptist Church — our story, our leadership, and our mission to the Winter Haven community.">
<link rel="stylesheet" href="~/css/pages/about.css" asp-append-version="true" />
}

<!-- HERO -->
<div class="hero-section">
  <div class="hero-bg-wrap" id="heroBgWrap">
    @if (ChurchPhotos.Get("AboutHero") is { } heroPh)
    {
      <partial name="_ChurchPexelsImg" model="heroPh" />
    }
    else
    {
      <div class="hero-bg-placeholder">
        <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><path d="M21 15l-5-5L5 21"/></svg>
        Replace with church building or congregation photo
      </div>
    }
    <div class="hero-text-wrap">
      <p class="hero-eyebrow word">Our Story</p>
      <h1 class="hero-church-name">
        <span class="word"><strong>About</strong></span><span class="word"> Us</span>
      </h1>
    </div>
  </div>

  <!-- WHITE CARD LIFT -->
  <div class="white-lift">

    <!-- ══ SECTION 1: WHITE — Our Story + Mission ══ -->
    <section class="section-white" id="story">
      <div class="section-inner">

        <!-- Row 1: Image + Our Story -->
        <div class="row reveal">
          <div class="row-img" style="aspect-ratio: 0.75;">
            @if (ChurchPhotos.Get("AboutCongregation") is { } ac)
            {
              <partial name="_ChurchPexelsImg" model="ac" />
            }
            else
            {
              <div class="row-img-ph">
                <svg width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><path d="M21 15l-5-5L5 21"/></svg>
                Add congregation photo
              </div>
            }
          </div>
          <div class="row-text">
            <p class="s-label">Since 1924</p>
            <h2 class="s-h2">A church built on faith, family &amp; purpose.</h2>
            <p class="s-body">
              New Bethel Missionary Baptist Church has been a cornerstone of faith and community in Winter Haven, Florida for generations. We are a church family committed to the gospel of Jesus Christ — worshipping boldly, serving humbly, and loving without condition.<br><br>
              From humble beginnings, God has grown this ministry into a vibrant body of believers reaching souls in our city and beyond.
            </p>
            <a href="#leadership" class="ulink">
              MEET OUR LEADERS
              <span class="ucircle">
                <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="square"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
              </span>
            </a>
          </div>
        </div>

        <!-- Row 2: Mission text + values phrases -->
        <div class="values-row reveal">
          <div class="values-right-text">
            <p class="s-body"><strong>NEW BETHEL MISSIONARY BAPTIST CHURCH</strong> — A place to belong, believe, and become everything God created you to be.</p>
          </div>
          <div class="faith-phrases">
            <h2 class="s-h2" style="line-height: 1.05;">
              <span class="accent-text">Love</span> God.<br>
              <span class="accent-text">Serve</span> Others.<br>
              <span class="accent-text">Grow</span> Together.
            </h2>
          </div>
        </div>

        <!-- Row 3: Mission reversed -->
        <div class="row row-reverse reveal">
          <div class="row-img" style="aspect-ratio: 1.2;">
            @if (ChurchPhotos.Get("AboutWorship") is { } aw)
            {
              <partial name="_ChurchPexelsImg" model="aw" />
            }
            else
            {
              <div class="row-img-ph">
                <svg width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><path d="M21 15l-5-5L5 21"/></svg>
                Add worship or outreach photo
              </div>
            }
          </div>
          <div class="row-text">
            <p class="s-label">Our Mission</p>
            <h2 class="s-h2">In the room, in the city + in the world.</h2>
            <p class="s-body">We exist to lead people to become fully devoted followers of Christ. Through worship, fellowship, discipleship, ministry, and evangelism — we go where God sends us.</p>
            <a href="/Jesus" class="ulink">
              WHO IS JESUS
              <span class="ucircle">
                <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="square"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
              </span>
            </a>
          </div>
        </div>

      </div>
    </section>

    <!-- ══ SECTION 2: GRAY — Leadership ══ -->
    <section class="section-gray" id="leadership">
      <div class="section-inner">

        <div class="reveal">
          <p class="s-label" style="margin-bottom: 16px;">Our Leadership</p>
          <h2 class="s-h2">The shepherds of<br>New Bethel.</h2>
        </div>

        <!-- Pastoral leadership -->
        <div class="leader-grid reveal">

          <div class="leader-card">
            <div class="leader-img">
              @if (ChurchPhotos.Get("AboutLeader1") is { } l1)
              {
                <partial name="_ChurchPexelsImg" model="l1" />
              }
              else
              {
                <div class="leader-img-ph">
                  <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1"><circle cx="12" cy="8" r="4"/><path d="M4 20c0-4 3.6-7 8-7s8 3 8 7"/></svg>
                  Add pastor photo
                </div>
              }
            </div>
            <div>
              <p class="leader-role">Senior Pastor</p>
              <h3 class="leader-name">Pastor Dye</h3>
            </div>
            <p class="leader-bio">Leading New Bethel with a heart for souls and a vision for community transformation, Pastor Dye has guided this congregation with wisdom, compassion, and unwavering faith.</p>
          </div>

          <div class="leader-card d1">
            <div class="leader-img">
              @if (ChurchPhotos.Get("AboutLeader2") is { } l2)
              {
                <partial name="_ChurchPexelsImg" model="l2" />
              }
              else
              {
                <div class="leader-img-ph">
                  <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1"><circle cx="12" cy="8" r="4"/><path d="M4 20c0-4 3.6-7 8-7s8 3 8 7"/></svg>
                  Add minister photo
                </div>
              }
            </div>
            <div>
              <p class="leader-role">Associate Minister</p>
              <h3 class="leader-name">Min. James Owens</h3>
            </div>
            <p class="leader-bio">Dedicated to teaching and equipping the saints through the Word of God, bringing clarity and conviction to every message.</p>
          </div>

          <div class="leader-card d2">
            <div class="leader-img">
              @if (ChurchPhotos.Get("AboutLeader3") is { } l3)
              {
                <partial name="_ChurchPexelsImg" model="l3" />
              }
              else
              {
                <div class="leader-img-ph">
                  <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1"><circle cx="12" cy="8" r="4"/><path d="M4 20c0-4 3.6-7 8-7s8 3 8 7"/></svg>
                  Add minister photo
                </div>
              }
            </div>
            <div>
              <p class="leader-role">Youth Minister</p>
              <h3 class="leader-name">Min. Tanya Brooks</h3>
            </div>
            <p class="leader-bio">Passionate about the next generation, equipping young people to live boldly in faith and purpose in every season of life.</p>
          </div>

        </div>

        <!-- Deacon Board -->
        <div class="reveal">
          <p class="s-label" style="margin-bottom: 16px;">Deacon Board</p>
          <div class="deacon-grid">
            <div class="deacon-item">
              <div class="deacon-avatar">D</div>
              <p class="deacon-name">Deacon Anderson</p>
              <p class="deacon-role">Chairman</p>
            </div>
            <div class="deacon-item">
              <div class="deacon-avatar">D</div>
              <p class="deacon-name">Deacon Williams</p>
              <p class="deacon-role">Vice Chairman</p>
            </div>
            <div class="deacon-item">
              <div class="deacon-avatar">D</div>
              <p class="deacon-name">Deacon Harris</p>
              <p class="deacon-role">Treasurer</p>
            </div>
            <div class="deacon-item">
              <div class="deacon-avatar">D</div>
              <p class="deacon-name">Deacon Johnson</p>
              <p class="deacon-role">Secretary</p>
            </div>
            <div class="deacon-item">
              <div class="deacon-avatar">D</div>
              <p class="deacon-name">Deaconess Davis</p>
              <p class="deacon-role">Deaconess Board</p>
            </div>
            <div class="deacon-item">
              <div class="deacon-avatar">D</div>
              <p class="deacon-name">Deaconess Thomas</p>
              <p class="deacon-role">Deaconess Board</p>
            </div>
          </div>
        </div>

      </div>
    </section>

    <!-- ══ SECTION 3: WHITE — Core Beliefs ══ -->
    <section class="section-white" id="beliefs">
      <div class="section-inner">

        <div class="reveal">
          <p class="s-label" style="margin-bottom: 16px;">What We Believe</p>
          <h2 class="s-h2">Our core convictions.</h2>
        </div>

        <div class="beliefs-grid reveal">

          <div class="belief-item">
            <p class="belief-num">01</p>
            <p class="belief-title">Scripture</p>
            <p class="belief-text">The Bible is the inspired, infallible, and authoritative Word of God — the final standard for all faith and practice.</p>
          </div>

          <div class="belief-item">
            <p class="belief-num">02</p>
            <p class="belief-title">The Trinity</p>
            <p class="belief-text">We believe in one God, eternally existing in three persons: Father, Son, and Holy Spirit.</p>
          </div>

          <div class="belief-item">
            <p class="belief-num">03</p>
            <p class="belief-title">Salvation</p>
            <p class="belief-text">Salvation is by grace alone, through faith alone, in Christ alone. Every person who confesses Jesus as Lord and believes in His resurrection is saved.</p>
          </div>

          <div class="belief-item">
            <p class="belief-num">04</p>
            <p class="belief-title">Baptism</p>
            <p class="belief-text">Believer's baptism by immersion is an outward declaration of an inward transformation — a public testimony of faith in Christ.</p>
          </div>

          <div class="belief-item">
            <p class="belief-num">05</p>
            <p class="belief-title">The Church</p>
            <p class="belief-text">The local church is the body of Christ, called to worship, teach, serve, and share the gospel with the world.</p>
          </div>

          <div class="belief-item">
            <p class="belief-num">06</p>
            <p class="belief-title">The Return of Christ</p>
            <p class="belief-text">We believe in the personal, visible return of Jesus Christ and the resurrection of the dead for eternal life with God.</p>
          </div>

        </div>

      </div>

      <!-- BIG CTA -->
      <a href="/" class="big-cta reveal" style="text-decoration: none; margin-top: 150px;">
        <span class="big-cta-text">Come as you are.</span>
        <div class="big-cta-circle">
          <svg width="80" height="80" viewBox="0 0 144 144" fill="none" stroke="black" stroke-width="10" stroke-linecap="square">
            <path d="M 84 36 L 120 72 L 84 108 M 114 72 L 24 72"/>
          </svg>
        </div>
      </a>

    </section>

  </div><!-- end white-lift -->
</div><!-- end hero-section -->

@section Scripts {
<script src="~/js/pages/about.js" asp-append-version="true"></script>
}
