@* USE CASE: Sermon detail — futuristic dark redesign *@
@page
@model ChurchWebsite.Pages.Sermons.DetailsModel
@{
    ViewData["Title"] = Model.Sermon?.Title ?? "Sermon";
}

@section Head {
<style>
:root{--g:#C9A84C;--gl:#F0D080;--gg:rgba(201,168,76,.35);--d:#070710;--s1:#0E0E1C;--s2:#14142A;--tp:#F0EDE6;--tm:#9A9485;--gb:rgba(201,168,76,.18)}
*,*::before,*::after{box-sizing:border-box}
body{background:var(--d);color:var(--tp)}
.sd-page{max-width:1100px;margin:0 auto;padding:60px 1.5rem 100px}
.sd-back{display:inline-flex;align-items:center;gap:6px;color:var(--tm);font-size:.8rem;text-decoration:none;letter-spacing:.04em;transition:color .25s;margin-bottom:2rem}
.sd-back:hover{color:var(--g)}
.sd-layout{display:grid;grid-template-columns:1fr 300px;gap:2.5rem;align-items:start}
@@media(max-width:800px){.sd-layout{grid-template-columns:1fr}}
.sd-video-wrap{border-radius:20px;overflow:hidden;border:1px solid var(--gb);background:var(--s2);margin-bottom:2rem;aspect-ratio:16/9}
.sd-video-wrap iframe{width:100%;height:100%;border:none;display:block}
.sd-eyebrow{font-size:.65rem;letter-spacing:.25em;text-transform:uppercase;color:var(--g);margin-bottom:.75rem;display:block}
.sd-title{font-size:clamp(1.6rem,4vw,2.8rem);font-weight:700;color:#fff;line-height:1.15;margin-bottom:.6rem}
.sd-speaker{font-size:.95rem;color:var(--tm);margin-bottom:1.75rem;display:flex;align-items:center;gap:.5rem}
.sd-section-label{font-size:.65rem;letter-spacing:.22em;text-transform:uppercase;color:var(--g);margin-bottom:.75rem;display:block;margin-top:2rem}
.sd-body{font-size:.92rem;color:rgba(240,237,230,.75);line-height:1.8}
.sd-actions{display:flex;flex-wrap:wrap;gap:.75rem;margin-top:2rem}
.sd-action-btn{display:inline-flex;align-items:center;gap:7px;background:rgba(201,168,76,.08);border:1px solid rgba(201,168,76,.25);color:var(--gl);border-radius:100px;padding:10px 22px;font-size:.82rem;font-weight:600;text-decoration:none;transition:all .3s}
.sd-action-btn:hover{background:rgba(201,168,76,.18);border-color:var(--g);color:#fff;transform:translateY(-2px)}
.sd-card{background:var(--s1);border:1px solid var(--gb);border-radius:20px;overflow:hidden;position:relative;margin-bottom:1rem}
.sd-card::before{content:'';position:absolute;top:0;left:0;right:0;height:2px;background:linear-gradient(90deg,transparent,var(--g),transparent)}
.sd-card-body{padding:1.75rem}
.sd-card-title{font-size:.9rem;font-weight:700;color:#fff;margin-bottom:1rem;letter-spacing:.04em}
.sd-detail-row{display:flex;align-items:flex-start;gap:.75rem;padding:.55rem 0;border-bottom:1px solid rgba(201,168,76,.08)}
.sd-detail-row:last-child{border-bottom:none}
.sd-detail-icon{font-size:.95rem;flex-shrink:0;margin-top:.06rem}
.sd-detail-label{font-size:.58rem;letter-spacing:.12em;text-transform:uppercase;color:var(--tm);margin-bottom:.1rem}
.sd-detail-val{font-size:.86rem;color:var(--tp);font-weight:500}
.sd-series-badge{display:inline-flex;align-items:center;background:rgba(201,168,76,.1);border:1px solid rgba(201,168,76,.22);border-radius:100px;padding:4px 14px;font-size:.7rem;letter-spacing:.1em;text-transform:uppercase;color:var(--gl);margin-top:.75rem}
.btn-back-link{display:inline-flex;align-items:center;justify-content:center;gap:6px;background:transparent;border:1px solid rgba(201,168,76,.3);color:var(--g);border-radius:100px;padding:10px 22px;font-size:.8rem;font-weight:600;text-decoration:none;transition:all .3s;margin-top:.5rem;width:100%}
.btn-back-link:hover{background:rgba(201,168,76,.1);border-color:var(--g);color:var(--gl)}
.sd-verse-card{background:rgba(201,168,76,.06);border:1px solid rgba(201,168,76,.18);border-left:3px solid var(--g);border-radius:0 14px 14px 0;padding:1rem 1.25rem;margin-top:1.5rem}
.sd-verse-text{font-size:.88rem;font-style:italic;color:rgba(240,237,230,.75);line-height:1.7;margin-bottom:.3rem}
.sd-verse-ref{font-size:.72rem;letter-spacing:.1em;text-transform:uppercase;color:var(--g)}
.sr{opacity:0;transform:translateY(20px);transition:opacity .6s,transform .6s}.sr.visible{opacity:1;transform:translateY(0)}
</style>
}

@if (Model.Sermon != null)
{
<div class="sd-page">
  <a asp-page="/Sermons/Index" class="sd-back sr">&larr; Back to Sermons</a>
  <div class="sd-layout sr">
    <div>
      @if (!string.IsNullOrWhiteSpace(Model.Sermon.VideoEmbedUrl))
      {
        <div class="sd-video-wrap">
          <iframe src="@Model.Sermon.VideoEmbedUrl" title="@Model.Sermon.Title" allowfullscreen allow="accelerometer;autoplay;clipboard-write;encrypted-media;gyroscope;picture-in-picture"></iframe>
        </div>
      }
      else
      {
        <div class="sd-video-wrap" style="display:flex;flex-direction:column;align-items:center;justify-content:center;color:var(--tm);text-align:center;padding:2rem">
          <div style="font-size:3rem;margin-bottom:1rem">&#127909;</div>
          <p style="font-size:.9rem">Video coming soon</p>
        </div>
      }
      <span class="sd-eyebrow">&#127908; Message from the Word</span>
      <h1 class="sd-title">@Model.Sermon.Title</h1>
      <div class="sd-speaker">&#127908; @Model.Sermon.Speaker &bull; @Model.Sermon.Date.ToString("MMMM d, yyyy")</div>

      @if (!string.IsNullOrWhiteSpace(Model.Sermon.Description))
      {
        <span class="sd-section-label">About This Message</span>
        <p class="sd-body">@Model.Sermon.Description</p>
      }

      @if (!string.IsNullOrWhiteSpace(Model.Sermon.Verse))
      {
        <div class="sd-verse-card">
          <div class="sd-verse-text">@Model.Sermon.Verse</div>
          <div class="sd-verse-ref">Scripture Reference</div>
        </div>
      }

      <div class="sd-actions">
        @if (!string.IsNullOrWhiteSpace(Model.Sermon.AudioUrl))
        {
          <a href="@Model.Sermon.AudioUrl" class="sd-action-btn" target="_blank" rel="noopener noreferrer">&#127911; Listen (Audio)</a>
        }
        @if (!string.IsNullOrWhiteSpace(Model.Sermon.DownloadUrl))
        {
          <a href="@Model.Sermon.DownloadUrl" class="sd-action-btn" target="_blank" rel="noopener noreferrer">&#11015; Download</a>
        }
        <a asp-page="/Live" class="sd-action-btn">&#128250; Watch Live</a>
      </div>
    </div>

    <div>
      <div class="sd-card">
        <div class="sd-card-body">
          <div class="sd-card-title">&#128203; Sermon Details</div>
          <div class="sd-detail-row"><span class="sd-detail-icon">&#127908;</span><div><div class="sd-detail-label">Speaker</div><div class="sd-detail-val">@Model.Sermon.Speaker</div></div></div>
          <div class="sd-detail-row"><span class="sd-detail-icon">&#128197;</span><div><div class="sd-detail-label">Date</div><div class="sd-detail-val">@Model.Sermon.Date.ToString("MMMM d, yyyy")</div></div></div>
          @if (!string.IsNullOrWhiteSpace(Model.Sermon.Verse))
          {
            <div class="sd-detail-row"><span class="sd-detail-icon">&#128215;</span><div><div class="sd-detail-label">Scripture</div><div class="sd-detail-val">@Model.Sermon.Verse</div></div></div>
          }
          @if (!string.IsNullOrWhiteSpace(Model.Sermon.Series))
          {
            <div class="sd-series-badge">Series: @Model.Sermon.Series</div>
          }
        </div>
      </div>
      <a asp-page="/Sermons/Index" class="btn-back-link">&larr; All Sermons</a>
    </div>
  </div>
</div>
}
else
{
<div style="min-height:60vh;display:flex;flex-direction:column;align-items:center;justify-content:center;text-align:center;padding:4rem 1.5rem;background:#070710;color:#F0EDE6">
  <div style="font-size:3rem;margin-bottom:1rem">&#127909;</div>
  <h2 style="color:#fff;margin-bottom:.5rem">Sermon Not Found</h2>
  <p style="color:#9A9485;margin-bottom:2rem">This sermon doesn&rsquo;t exist or has been removed.</p>
  <a asp-page="/Sermons/Index" style="display:inline-flex;align-items:center;gap:6px;background:linear-gradient(135deg,#C9A84C,#7a5500);color:#070710;text-decoration:none;padding:12px 28px;border-radius:100px;font-weight:700;font-size:.85rem">&larr; View All Sermons</a>
</div>
}

@section Scripts {
<script>
(function(){var obs=new IntersectionObserver(function(e){e.forEach(function(x){if(x.isIntersecting)x.target.classList.add('visible')})},{threshold:.1});document.querySelectorAll('.sr').forEach(function(el){obs.observe(el)})})();
</script>
}
