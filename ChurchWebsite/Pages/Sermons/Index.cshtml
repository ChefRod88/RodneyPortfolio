@* USE CASE: Sermons list — futuristic dark redesign *@
@page
@model ChurchWebsite.Pages.Sermons.IndexModel
@{
    ViewData["Title"] = "Sermons";
}

@section Head {
<meta name="description" content="Watch sermons and teachings from New Bethel Missionary Baptist Church. Every message is a fresh encounter with God.">
<link rel="stylesheet" href="~/css/pages/sermons-index.css" asp-append-version="true" />
}

<div class="sm-hero">
  <div class="sm-hero-grid"></div>
  <div style="position:relative;z-index:1">
    <div class="sm-eyebrow"><span class="sm-eyebrow-dot"></span>Word of God</div>
    <h1>Sermon Library</h1>
    <p class="sm-hero-sub">Watch our latest teachings and grow in the Word. Every message is a fresh encounter with God.</p>
    <a asp-page="/Live" class="sm-live-btn"><span class="sm-live-dot"></span>Watch Live Stream</a>
  </div>
</div>

<div class="sm-grid">
  @if (!Model.Sermons.Any())
  {
    <div class="sm-empty">
      <div class="sm-empty-icon">&#127909;</div>
      <h3>No Sermons Yet</h3>
      <p>Check back soon — messages are on the way.</p>
    </div>
  }
  @foreach (var sermon in Model.Sermons)
  {
    <a asp-page="/Sermons/Details" asp-route-id="@sermon.Id" class="sm-card">
      <div class="sm-thumb" style="background-image:url('/images/IMG_7706.jpg')" role="img" aria-label="@sermon.Title sermon thumbnail">
        <div class="sm-play"><div class="sm-play-circle"><div class="sm-play-icon"></div></div></div>
      </div>
      <div class="sm-card-body">
        @if (!string.IsNullOrWhiteSpace(sermon.Series))
        {
          <div class="sm-series">@sermon.Series</div>
        }
        <div class="sm-title">@sermon.Title</div>
        <div class="sm-meta">@sermon.Speaker &bull; @sermon.Date.ToString("MMMM d, yyyy")</div>
        @if (!string.IsNullOrWhiteSpace(sermon.Description))
        {
          <p class="sm-desc">@sermon.Description</p>
        }
        <span class="sm-watch-btn">&#9654; Watch Now</span>
      </div>
    </a>
  }
</div>

@section Scripts {
<script src="~/js/pages/sermons-index.js" asp-append-version="true"></script>
}
