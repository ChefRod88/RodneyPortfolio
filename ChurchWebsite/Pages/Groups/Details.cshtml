@* USE CASE: Group detail — futuristic dark redesign *@
@page
@model ChurchWebsite.Pages.Groups.DetailsModel
@{
    ViewData["Title"] = Model.Group?.Name ?? "Group";
}

@section Head {
@if (Model.Group != null)
{
    var desc = !string.IsNullOrWhiteSpace(Model.Group.Description)
        ? Model.Group.Description
        : $"Join {Model.Group.Name} at New Bethel Missionary Baptist Church and grow in faith alongside others in Winter Haven, Florida.";
    <meta name="description" content="@desc">
}
<link rel="stylesheet" href="~/css/pages/groups-details.css" asp-append-version="true" />
}

@if (Model.Group != null)
{
<div class="gd-page">
  <a asp-page="/Groups/Index" class="gd-back sr">&larr; Back to Groups</a>
  <div class="gd-layout sr">
    <div>
      @if (!string.IsNullOrWhiteSpace(Model.Group.ImageUrl))
      {
        <img src="@Model.Group.ImageUrl" alt="@Model.Group.Name" class="gd-hero-img" />
      }
      @if (!string.IsNullOrWhiteSpace(Model.Group.Category))
      {
        <div class="gd-category">&#127775; @Model.Group.Category</div>
      }
      <h1 class="gd-title">@Model.Group.Name</h1>
      <span class="gd-section-label">About This Group</span>
      <p class="gd-body">@Model.Group.Description</p>

      <div>
        @if (!string.IsNullOrWhiteSpace(Model.Group.MeetingSchedule))
        {
          <div class="gd-meta-row"><span class="gd-meta-icon">&#128197;</span><div><div class="gd-meta-label">Meeting Schedule</div><div class="gd-meta-val">@Model.Group.MeetingSchedule</div></div></div>
        }
        @if (!string.IsNullOrWhiteSpace(Model.Group.Location))
        {
          <div class="gd-meta-row"><span class="gd-meta-icon">&#128205;</span><div><div class="gd-meta-label">Location</div><div class="gd-meta-val">@Model.Group.Location</div></div></div>
        }
        @if (!string.IsNullOrWhiteSpace(Model.Group.ContactEmail))
        {
          <div class="gd-meta-row"><span class="gd-meta-icon">&#9993;</span><div><div class="gd-meta-label">Contact</div><div class="gd-meta-val"><a href="mailto:@Model.Group.ContactEmail" class="gd-meta-link">@Model.Group.ContactEmail</a></div></div></div>
        }
      </div>
    </div>

    <div>
      <div class="gd-card">
        <div class="gd-card-body">
          <div class="gd-card-title">&#128075; Join This Group</div>
          <p class="gd-join-note">Ready to connect? Click below to express your interest and we&rsquo;ll get you started on this journey.</p>
          <button type="button" class="gd-join-btn" onclick="openJoinModal()">Join or Express Interest &rarr;</button>
        </div>
      </div>
      <div class="gd-card">
        <div class="gd-card-body">
          <div class="gd-card-title">&#128203; Quick Info</div>
          @if (!string.IsNullOrWhiteSpace(Model.Group.Category))
          {
            <div class="gd-meta-row"><span class="gd-meta-icon">&#127775;</span><div><div class="gd-meta-label">Category</div><div class="gd-meta-val">@Model.Group.Category</div></div></div>
          }
          @if (!string.IsNullOrWhiteSpace(Model.Group.MeetingSchedule))
          {
            <div class="gd-meta-row"><span class="gd-meta-icon">&#128197;</span><div><div class="gd-meta-label">Schedule</div><div class="gd-meta-val">@Model.Group.MeetingSchedule</div></div></div>
          }
          @if (!string.IsNullOrWhiteSpace(Model.Group.Location))
          {
            <div class="gd-meta-row"><span class="gd-meta-icon">&#128205;</span><div><div class="gd-meta-label">Location</div><div class="gd-meta-val">@Model.Group.Location</div></div></div>
          }
        </div>
      </div>
      <a asp-page="/Groups/Index" class="btn-back-link">&larr; All Groups</a>
    </div>
  </div>
</div>

<!-- Join Modal -->
<div id="joinModal" class="join-modal" role="dialog" aria-modal="true" hidden>
  <div class="join-overlay" onclick="closeJoinModal()"></div>
  <div class="join-card">
    <button class="join-close" onclick="closeJoinModal()" aria-label="Close">&#215;</button>
    <div class="join-icon">&#127995;</div>
    <div class="join-title">Join @Model.Group.Name</div>
    <p class="join-body">We&rsquo;re glad you want to get connected! Reach out to us by email and we&rsquo;ll get you plugged in.</p>
    @if (!string.IsNullOrWhiteSpace(Model.Group.ContactEmail))
    {
      <a href="mailto:@Model.Group.ContactEmail" class="join-email-btn">&#9993; Email Us to Join</a>
    }
    <button type="button" class="join-dismiss" onclick="closeJoinModal()">Maybe Later</button>
  </div>
</div>
}
else
{
<div style="min-height:60vh;display:flex;flex-direction:column;align-items:center;justify-content:center;text-align:center;padding:4rem 1.5rem;background:#070710;color:#F0EDE6">
  <div style="font-size:3rem;margin-bottom:1rem">&#128101;</div>
  <h2 style="color:#fff;margin-bottom:.5rem">Group Not Found</h2>
  <p style="color:#9A9485;margin-bottom:2rem">This group doesn&rsquo;t exist or has been removed.</p>
  <a asp-page="/Groups/Index" style="display:inline-flex;align-items:center;gap:6px;background:linear-gradient(135deg,#C9A84C,#7a5500);color:#070710;text-decoration:none;padding:12px 28px;border-radius:100px;font-weight:700;font-size:.85rem">&larr; View All Groups</a>
</div>
}

@section Scripts {
<script src="~/js/pages/groups-details.js" asp-append-version="true"></script>
}
