@* USE CASE: Groups list — futuristic dark redesign *@
@page
@model ChurchWebsite.Pages.Groups.IndexModel
@{
    ViewData["Title"] = "Groups & Ministries";
}

@section Head {
<meta name="description" content="Find your place at New Bethel Missionary Baptist Church. Explore groups and ministries to grow in faith and serve alongside others in Winter Haven, Florida.">
<link rel="stylesheet" href="~/css/pages/groups-index.css" asp-append-version="true" />
}

<div class="gr-hero">
  <div class="gr-hero-grid"></div>
  <div style="position:relative;z-index:1">
    <div class="gr-eyebrow"><span class="gr-eyebrow-dot"></span>New Bethel Missionary Baptist Church</div>
    <h1>Groups &amp; Ministries</h1>
    <p class="gr-hero-sub">Find your place, grow in faith, and serve alongside others in our church family.</p>
  </div>
</div>

<div class="gr-grid">
  @if (!Model.Groups.Any())
  {
    <div class="gr-empty">
      <div class="gr-empty-icon">&#128101;</div>
      <h3>No Groups Available</h3>
      <p>Check back soon for new groups and ministries.</p>
    </div>
  }
  @foreach (var group in Model.Groups)
  {
    <div class="gr-card">
      @if (!string.IsNullOrWhiteSpace(group.ImageUrl))
      {
        <div class="gr-thumb" style="background-image:url('@group.ImageUrl')" role="img" aria-label="@group.Name"><div class="gr-thumb-overlay"></div></div>
      }
      else
      {
        <div class="gr-thumb-empty">&#9995;</div>
      }
      <div class="gr-card-body">
        @if (!string.IsNullOrWhiteSpace(group.Category))
        {
          <div class="gr-category">&#127775; @group.Category</div>
        }
        <div class="gr-name">@group.Name</div>
        @if (!string.IsNullOrWhiteSpace(group.MeetingSchedule))
        {
          <div class="gr-schedule">&#128197; @group.MeetingSchedule</div>
        }
        @if (!string.IsNullOrWhiteSpace(group.Description))
        {
          <p class="gr-desc">@group.Description</p>
        }
        <a asp-page="/Groups/Details" asp-route-id="@group.Id" class="gr-cta">Learn More &amp; Join &rarr;</a>
      </div>
    </div>
  }
</div>

@section Scripts {
<script src="~/js/pages/groups-index.js" asp-append-version="true"></script>
}
