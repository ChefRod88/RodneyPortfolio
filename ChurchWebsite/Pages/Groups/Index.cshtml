@* USE CASE: Groups list - cards from GroupService *@
@page
@model ChurchWebsite.Pages.Groups.IndexModel
@{
    ViewData["Title"] = "Groups & Ministries";
}

<div class="container py-5 groups-page">
    <div class="text-center mb-5">
        <h1 class="display-5 fw-bold mb-2">Groups & Ministries</h1>
        <p class="lead text-muted">Find a group to join. Get connected and grow with others.</p>
    </div>

    <div class="row g-4">
        @foreach (var group in Model.Groups)
        {
            <div class="col-md-6 col-lg-4">
                <div class="card h-100 border-0 shadow-sm overflow-hidden">
                    @if (!string.IsNullOrWhiteSpace(group.ImageUrl))
                    {
                        <img src="@group.ImageUrl" alt="@group.Name" class="card-img-top" style="object-fit: contain; height: 18rem; background-color: #f8f9fa;" />
                    }
                    <div class="card-body d-flex flex-column">
                        <h5 class="card-title">@group.Name</h5>
                        <p class="card-text small text-muted mb-2">
                            @if (!string.IsNullOrWhiteSpace(group.MeetingSchedule))
                            {
                                <span>📅 @group.MeetingSchedule</span>
                            }
                        </p>
                        <p class="card-text small flex-grow-1">@group.Description</p>
                        <div class="d-flex justify-content-center mt-3">
                            <a asp-page="/Groups/Details" asp-route-id="@group.Id" class="btn btn-church-primary btn-sm">Learn More & Join</a>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
</div>
