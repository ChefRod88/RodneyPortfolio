@* USE CASE: Events list - futuristic dark redesign *@
@page
@model ChurchWebsite.Pages.Events.IndexModel
@{
    ViewData["Title"] = "Events";
}

@section Head {
<link rel="stylesheet" href="~/css/pages/events-index.css" asp-append-version="true" />
}

<div class="ev-hero">
  <div class="ev-hero-grid"></div>
  <div style="position:relative;z-index:1">
    <div class="ev-eyebrow"><span class="ev-eyebrow-dot"></span>New Bethel Missionary Baptist Church</div>
    <h1>Upcoming Events</h1>
    <p class="ev-hero-sub">Find events to attend and get connected with our community in Winter Haven, Florida.</p>
  </div>
</div>

<div class="ev-grid">
  @if (!Model.Events.Any())
  {
    <div class="ev-empty">
      <div class="ev-empty-icon">&#128197;</div>
      <h3>No Events Scheduled</h3>
      <p>Check back soon for upcoming events and gatherings.</p>
    </div>
  }
  @foreach (var evt in Model.Events)
  {
    <div class="ev-card">
      @if (!string.IsNullOrWhiteSpace(evt.ImageUrl))
      {
        <div class="ev-thumb" style="background-image:url('@evt.ImageUrl')"><div class="ev-thumb-overlay"></div></div>
      }
      else
      {
        <div class="ev-thumb-empty">&#128197;</div>
      }
      <div class="ev-card-body">
        <div class="ev-date-badge">&#128197; @evt.Date.ToString("MMM d, yyyy")</div>
        <div class="ev-title">@evt.Title</div>
        <div class="ev-meta">&#128336; @evt.Date.ToString("h:mm tt")</div>
        @if (!string.IsNullOrWhiteSpace(evt.Location))
        {
          <div class="ev-meta">&#128205; @evt.Location</div>
        }
        @if (!string.IsNullOrWhiteSpace(evt.Description))
        {
          <p class="ev-desc">@evt.Description</p>
        }
        @if (evt.Capacity.HasValue)
        {
          <div class="ev-capacity">&#128101; @evt.Capacity spots available</div>
        }
        <a asp-page="/Events/Details" asp-route-id="@evt.Id" class="ev-cta">View Details &rarr;</a>
      </div>
    </div>
  }
</div>

@section Scripts {
<script src="~/js/pages/events-index.js" asp-append-version="true"></script>
}
