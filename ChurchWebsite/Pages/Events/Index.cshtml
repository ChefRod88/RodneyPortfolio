@* USE CASE: Events list - Edify design system *@
@page
@model ChurchWebsite.Pages.Events.IndexModel
@{
    ViewData["Title"] = "Events";
}

@section Head {
<meta name="description" content="Upcoming events at New Bethel Missionary Baptist Church — Winter Haven, Florida.">
<link rel="stylesheet" href="~/css/pages/events-index.css" asp-append-version="true" />
}

<!-- PAGE HEADER -->
<div class="ev-page-header">
  <div class="ev-page-header-bg"></div>
  <div class="ev-page-header-inner">
    <p class="ev-eyebrow">New Bethel Missionary Baptist Church</p>
    <h1 class="ev-page-title">
      <span class="ev-title-word"><em>Upcoming</em></span>
      <span class="ev-title-word"> Events</span>
    </h1>
    <p class="ev-page-sub">Find events, gatherings, and ways to get connected<br>with our community in Winter Haven, Florida.</p>
  </div>
</div>

<!-- WHITE CARD LIFT -->
<div class="ev-white-lift">

  <!-- EVENTS GRID -->
  <div class="ev-content">
    @if (!Model.Events.Any())
    {
      <div class="ev-empty">
        <p class="ev-empty-label">No upcoming events</p>
        <h2 class="ev-empty-heading">Check back soon.</h2>
        <p class="ev-empty-body">We're always planning something. Come back to find praise nights,<br>workshops, outreach events, and community gatherings.</p>
        <a href="/" class="ev-ulink">
          BACK TO HOME
          <span class="ev-ucircle">
            <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="square"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </span>
        </a>
      </div>
    }
    else
    {
      <div class="ev-grid">
        @foreach (var evt in Model.Events)
        {
          <div class="ev-card ev-reveal">
            <!-- Card image -->
            <div class="ev-card-img">
              @if (!string.IsNullOrWhiteSpace(evt.ImageUrl))
              {
                <img src="@evt.ImageUrl" alt="@evt.Title" loading="lazy">
              }
              else if (ChurchPhotos.Get("EventsCardFallback") is { } fb)
              {
                <img src="@fb.ImageUrl" alt="@fb.AltText" loading="lazy" decoding="async" />
              }
              else
              {
                <div class="ev-card-img-ph">
                  <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><path d="M21 15l-5-5L5 21"/></svg>
                </div>
              }
            </div>

            <!-- Card body -->
            <div class="ev-card-body">
              <div class="ev-card-date">@evt.Date.ToString("MMM d, yyyy")</div>
              <h3 class="ev-card-title">@evt.Title</h3>
              <div class="ev-card-meta">
                <span>@evt.Date.ToString("h:mm tt")</span>
                @if (!string.IsNullOrWhiteSpace(evt.Location))
                {
                  <span class="ev-meta-sep">·</span>
                  <span>@evt.Location</span>
                }
              </div>
              @if (!string.IsNullOrWhiteSpace(evt.Description))
              {
                <p class="ev-card-desc">@evt.Description</p>
              }
              @if (evt.Capacity.HasValue)
              {
                <p class="ev-card-capacity">@evt.Capacity spots available</p>
              }
              <a asp-page="/Events/Details" asp-route-id="@evt.Id" class="ev-ulink" style="margin-top: auto; padding-top: 20px;">
                VIEW DETAILS
                <span class="ev-ucircle">
                  <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="square"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
                </span>
              </a>
            </div>
          </div>
        }
      </div>
    }
  </div>

  <!-- BIG CTA -->
  <a href="/#about" class="ev-big-cta">
    <span class="ev-big-cta-text">Join the family.</span>
    <div class="ev-big-cta-circle">
      <svg width="80" height="80" viewBox="0 0 144 144" fill="none" stroke="black" stroke-width="10" stroke-linecap="square">
        <path d="M 84 36 L 120 72 L 84 108 M 114 72 L 24 72"/>
      </svg>
    </div>
  </a>

</div><!-- end white-lift -->

@section Scripts {
<script>
  const obs = new IntersectionObserver(entries => {
    entries.forEach(e => { if (e.isIntersecting) { e.target.classList.add('visible'); obs.unobserve(e.target); } });
  }, { threshold: 0.08 });
  document.querySelectorAll('.ev-reveal').forEach(el => obs.observe(el));
</script>
}
