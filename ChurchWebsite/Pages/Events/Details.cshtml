@* USE CASE: Event detail — futuristic dark redesign *@
@page
@model ChurchWebsite.Pages.Events.DetailsModel
@{
    ViewData["Title"] = Model.Event?.Title ?? "Event";
}

@section Head {
@if (Model.Event != null)
{
    var desc = !string.IsNullOrWhiteSpace(Model.Event.Description)
        ? Model.Event.Description
        : $"{Model.Event.Title} — {Model.Event.Date:MMMM d, yyyy} at New Bethel Missionary Baptist Church, Winter Haven, Florida.";
    <meta name="description" content="@desc">
}
<link rel="stylesheet" href="~/css/pages/events-details.css" asp-append-version="true" />
}

@if (Model.Event != null)
{
<div class="ed-page">
  <a asp-page="/Events/Index" class="ed-back sr">&larr; Back to Events</a>
  <div class="ed-layout sr">
    <div>
      @if (!string.IsNullOrWhiteSpace(Model.Event.ImageUrl))
      {
        <img src="@Model.Event.ImageUrl" alt="@Model.Event.Title" class="ed-hero-img" />
      }
      <span class="ed-eyebrow">&#128197; Event Details</span>
      <h1 class="ed-title">@Model.Event.Title</h1>

      <div style="margin-bottom:2rem">
        <div class="ed-meta-row">
          <span class="ed-meta-icon">&#128336;</span>
          <div><div class="ed-meta-label">Date &amp; Time</div><div class="ed-meta-val">@Model.Event.Date.ToString("dddd, MMMM d, yyyy") &bull; @Model.Event.Date.ToString("h:mm tt")@(Model.Event.EndDate.HasValue ? " – " + Model.Event.EndDate.Value.ToString("h:mm tt") : "")</div></div>
        </div>
        @if (!string.IsNullOrWhiteSpace(Model.Event.Location))
        {
          <div class="ed-meta-row">
            <span class="ed-meta-icon">&#128205;</span>
            <div><div class="ed-meta-label">Location</div><div class="ed-meta-val">@Model.Event.Location</div></div>
          </div>
        }
        @if (Model.Event.Capacity.HasValue)
        {
          <div class="ed-meta-row">
            <span class="ed-meta-icon">&#128101;</span>
            <div><div class="ed-meta-label">Capacity</div><div class="ed-meta-val">@Model.Event.Capacity spots</div></div>
          </div>
        }
      </div>

      @if (!string.IsNullOrWhiteSpace(Model.Event.Description))
      {
        <span class="ed-section-label">About This Event</span>
        <p class="ed-body">@Model.Event.Description</p>
      }
    </div>

    <div>
      <div class="ed-card" style="margin-bottom:1rem">
        <div class="ed-card-body">
          <div class="ed-card-title">&#128075; RSVP to This Event</div>
          <p class="ed-rsvp-note">Let us know you&rsquo;re coming! RSVP to reserve your spot and we&rsquo;ll be looking for you.</p>
          <button type="button" class="ed-rsvp-btn" onclick="openRsvpModal()">RSVP Now &rarr;</button>
        </div>
      </div>
      <div class="ed-details-card">
        <div class="ed-card-body">
          <div class="ed-card-title">&#128203; Event Info</div>
          <div class="ed-meta-row"><span class="ed-meta-icon">&#128197;</span><div><div class="ed-meta-label">Date</div><div class="ed-meta-val">@Model.Event.Date.ToString("MMMM d, yyyy")</div></div></div>
          <div class="ed-meta-row"><span class="ed-meta-icon">&#128336;</span><div><div class="ed-meta-label">Time</div><div class="ed-meta-val">@Model.Event.Date.ToString("h:mm tt")</div></div></div>
          @if (!string.IsNullOrWhiteSpace(Model.Event.Location))
          {
            <div class="ed-meta-row"><span class="ed-meta-icon">&#128205;</span><div><div class="ed-meta-label">Location</div><div class="ed-meta-val">@Model.Event.Location</div></div></div>
          }
        </div>
      </div>
      <a asp-page="/Events/Index" class="btn-back-link">&larr; All Events</a>
    </div>
  </div>
</div>

<!-- RSVP Modal -->
<div id="rsvpModal" class="rsvp-modal" role="dialog" aria-modal="true" hidden>
  <div class="rsvp-overlay" onclick="closeRsvpModal()"></div>
  <div class="rsvp-card">
    <button class="rsvp-close" onclick="closeRsvpModal()" aria-label="Close">&#215;</button>
    <div class="rsvp-icon">&#127881;</div>
    <div class="rsvp-title">RSVP: @Model.Event.Title</div>
    <p class="rsvp-body">Thank you for your interest! We&rsquo;re glad you&rsquo;re planning to join us. Full RSVP functionality is coming soon — we&rsquo;ll see you there!</p>
    <button type="button" class="rsvp-dismiss" onclick="closeRsvpModal()">Got it &mdash; See You There!</button>
  </div>
</div>
}
else
{
<div style="min-height:60vh;display:flex;flex-direction:column;align-items:center;justify-content:center;text-align:center;padding:4rem 1.5rem;background:#070710;color:#F0EDE6">
  <div style="font-size:3rem;margin-bottom:1rem">&#128197;</div>
  <h2 style="color:#fff;margin-bottom:.5rem">Event Not Found</h2>
  <p style="color:#9A9485;margin-bottom:2rem">This event doesn&rsquo;t exist or has been removed.</p>
  <a asp-page="/Events/Index" style="display:inline-flex;align-items:center;gap:6px;background:linear-gradient(135deg,#C9A84C,#7a5500);color:#070710;text-decoration:none;padding:12px 28px;border-radius:100px;font-weight:700;font-size:.85rem">&larr; View All Events</a>
</div>
}

@section Scripts {
<script src="~/js/pages/events-details.js" asp-append-version="true"></script>
}
