@* ============================================
   SHARED LAYOUT — Edify design system
   Nav: floating pill (fixed, Judson + Outfit)
   Footer: dark, church data from ChurchSettings
   All pages use this via _ViewStart.cshtml
   ============================================ *@
@using ChurchWebsite.Models
@using Microsoft.Extensions.Options
@inject IOptions<ChurchSettings> ChurchOptions
@inject IHttpContextAccessor HttpContextAccessor
@{
    var church = ChurchOptions.Value;
    var path = HttpContextAccessor.HttpContext?.Request.Path.Value ?? "";
    bool IsActive(string page) => (page == "/" && (path == "/" || path == "")) || (page != "/" && path.StartsWith(page, StringComparison.OrdinalIgnoreCase));
    bool IsEvents = path.StartsWith("/Events", StringComparison.OrdinalIgnoreCase);
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@(ViewData["Title"] != null ? ViewData["Title"] + " — " : "")@church.NameText</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Judson:ital,wght@0,400;0,700;1,400&family=Outfit:wght@300;400;500&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/site-mobile.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/ChurchWebsite.styles.css" asp-append-version="true" />
    @await RenderSectionAsync("Head", required: false)
    @{
        var ogTitle = (ViewData["Title"] != null ? ViewData["Title"] + " — " : "") + church.NameText;
        var ogDescription = ViewData["Description"] as string ?? church.Tagline;
        var ogImage = ViewData["OgImage"] as string ?? church.HeroImageUrl;
        var baseUrl = $"{HttpContextAccessor.HttpContext?.Request.Scheme}://{HttpContextAccessor.HttpContext?.Request.Host}";
        var ogImageAbsolute = ogImage.StartsWith("http") ? ogImage : baseUrl + ogImage;
    }
    <!-- Open Graph / Social Sharing -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="@church.NameText" />
    <meta property="og:title" content="@ogTitle" />
    <meta property="og:description" content="@ogDescription" />
    <meta property="og:image" content="@ogImageAbsolute" />
    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="@ogTitle" />
    <meta name="twitter:description" content="@ogDescription" />
    <meta name="twitter:image" content="@ogImageAbsolute" />
    <!-- Schema.org structured data -->
    <script type="application/ld+json">
    {
      "@@context": "https://schema.org",
      "@@type": "Church",
      "name": "@church.NameText",
      "address": {
        "@@type": "PostalAddress",
        "streetAddress": "@church.Address.Street",
        "addressLocality": "@church.Address.City",
        "addressRegion": "@church.Address.State",
        "postalCode": "@church.Address.Zip",
        "addressCountry": "US"
      }@(!string.IsNullOrEmpty(church.Phone) ? $",\n      \"telephone\": \"{church.Phone}\"" : "")@(!string.IsNullOrEmpty(church.Email) ? $",\n      \"email\": \"{church.Email}\"" : "")@(church.ServiceTimes.Count > 0 ? $",\n      \"openingHoursSpecification\": {{\"@@type\": \"OpeningHoursSpecification\", \"dayOfWeek\": \"Sunday\"}}" : "")@(!string.IsNullOrEmpty(church.SocialMedia.YouTube) ? $",\n      \"sameAs\": [\"{church.SocialMedia.YouTube}\"]" : "")
    }
    </script>
    <style>
    /* ── EDIFY NAV + FOOTER (shared across all pages) ── */
    :root {
      --edify-white: #ffffff;
      --edify-bg: #ededed;
      --edify-black: #000000;
      --edify-accent: #2a967d;
      --edify-gray: #949494;
      --edify-gray-dark: #474747;
    }

    /* Pill nav */
    .nav-host {
      position: fixed; top: 0; left: 50%; transform: translateX(-50%);
      width: 100%; max-width: 1440px;
      padding: 15px 30px;
      z-index: 1000; pointer-events: none;
    }
    .nav-pill {
      display: flex; align-items: center; justify-content: space-between;
      background: var(--edify-white);
      border-radius: 15px;
      padding: 0 15px; height: 50px;
      pointer-events: all;
      transition: box-shadow 0.3s;
    }
    .nav-host.scrolled .nav-pill { box-shadow: 0 4px 20px rgba(0,0,0,0.12); }
    .nav-logo {
      font-family: 'Judson', serif; font-style: italic;
      font-size: 22px; letter-spacing: -0.06em; line-height: 0.8em;
      text-decoration: none; color: var(--edify-black);
    }
    .nav-logo strong { font-style: normal; font-weight: 700; }
    .nav-links { display: flex; align-items: center; gap: 2px; }
    .nav-links a {
      font-family: 'Outfit', sans-serif;
      font-size: 13px; font-weight: 500; letter-spacing: -0.01em;
      text-transform: uppercase; color: var(--edify-black);
      text-decoration: none; padding: 5px 8px; border-radius: 10px;
      transition: background 0.15s;
    }
    .nav-links a:hover,
    .nav-links a.nav-active { background: rgba(0,0,0,0.06); }
    .nav-hamburger { display: none; flex-direction: column; gap: 5px; cursor: pointer; padding: 8px; }
    .nav-hamburger span { width: 21px; height: 2px; background: var(--edify-black); border-radius: 2px; display: block; }

    /* Mobile nav overlay */
    .mobile-nav {
      position: fixed; inset: 0; z-index: 1100;
      background: var(--edify-white);
      display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 32px;
      opacity: 0; pointer-events: none; transition: opacity 0.3s;
    }
    .mobile-nav.open { opacity: 1; pointer-events: all; }
    .mobile-nav a {
      font-family: 'Judson', serif; font-style: italic; font-size: 36px;
      color: var(--edify-black); text-decoration: none; letter-spacing: -0.04em;
      transition: color 0.2s;
    }
    .mobile-nav a:hover { color: var(--edify-accent); }
    .mobile-nav-close {
      position: absolute; top: 20px; right: 24px;
      font-size: 28px; background: none; border: none; cursor: pointer;
      color: var(--edify-black); line-height: 1;
    }

    /* Edify footer */
    .edify-footer {
      background: var(--edify-black);
      padding: 50px 100px;
    }
    .edify-footer-top {
      display: flex; align-items: flex-start; justify-content: space-between;
      gap: 60px; margin-bottom: 100px;
      width: 100%; max-width: 1440px; margin-left: auto; margin-right: auto;
    }
    .edify-footer-contact { display: flex; flex-direction: column; gap: 10px; align-items: flex-start; }
    .edify-footer-contact a {
      font-family: 'Outfit', sans-serif;
      font-size: 13px; font-weight: 500; letter-spacing: -0.01em;
      text-transform: uppercase; color: var(--edify-white);
      text-decoration: underline; text-underline-offset: 3px; text-decoration-thickness: 1px;
    }
    .edify-footer-addr {
      font-family: 'Outfit', sans-serif;
      font-size: 13px; letter-spacing: -0.01em; text-transform: uppercase; color: rgba(255,255,255,0.85);
    }
    .edify-footer-logo {
      font-family: 'Judson', serif; font-style: italic;
      font-size: 40px; letter-spacing: -0.03em; line-height: 1em;
      color: var(--edify-gray-dark);
    }
    .edify-footer-logo strong { font-style: normal; }
    .edify-footer-nav { display: flex; flex-direction: column; gap: 10px; align-items: flex-end; }
    .edify-footer-nav-label {
      font-family: 'Outfit', sans-serif;
      font-size: 13px; letter-spacing: -0.01em; text-transform: uppercase; color: var(--edify-gray-dark); margin-bottom: 4px;
    }
    .edify-footer-nav a {
      font-family: 'Outfit', sans-serif;
      font-size: 13px; font-weight: 400; letter-spacing: -0.01em; text-transform: uppercase;
      color: var(--edify-white); text-decoration: none; opacity: 0.8; transition: opacity 0.2s;
    }
    .edify-footer-nav a:hover { opacity: 1; }
    .edify-footer-tagline-wrap {
      width: 100%; max-width: 600px; margin: 0 auto 50px;
      text-align: center;
    }
    .edify-footer-tagline {
      font-family: 'Judson', serif; font-style: italic;
      font-size: clamp(22px, 3vw, 40px);
      letter-spacing: -0.03em; line-height: 1.1em;
      color: rgba(255,255,255,0.35);
    }
    .edify-footer-bottom {
      display: flex; align-items: center; justify-content: space-between;
      padding-top: 20px; border-top: 1px solid rgba(255,255,255,0.08);
      font-family: 'Outfit', sans-serif;
      font-size: 12px; letter-spacing: -0.01em; text-transform: uppercase;
      color: rgba(255,255,255,0.4);
      width: 100%; max-width: 1440px; margin: 0 auto;
    }
    .edify-footer-socials { display: flex; gap: 12px; }
    .edify-footer-socials a { display: flex; align-items: center; opacity: 0.8; transition: opacity 0.2s; }
    .edify-footer-socials a:hover { opacity: 1; }
    .edify-footer-socials svg { width: 22px; height: 22px; }

    @@media (max-width: 1180px) {
      .nav-links { flex-wrap: wrap; justify-content: flex-end; row-gap: 4px; max-width: min(720px, 72vw); }
      .nav-links a { font-size: 11px; padding: 5px 6px; letter-spacing: -0.02em; }
    }
    @@media (max-width: 900px) {
      .edify-footer { padding: 50px 25px; }
      .edify-footer-top { flex-direction: column; align-items: center; text-align: center; margin-bottom: 50px; }
      .edify-footer-contact { align-items: center; }
      .edify-footer-nav { align-items: center; }
      .nav-links { display: none; }
      .nav-hamburger { display: flex; }
      .nav-host { padding: 10px 15px; }
    }
    </style>
</head>
<body>

<!-- MOBILE NAV OVERLAY -->
<div class="mobile-nav" id="mobileNav">
    <button class="mobile-nav-close" onclick="closeMobileNav()" aria-label="Close menu">&times;</button>
    <a href="/Give" onclick="closeMobileNav()">Give</a>
    <a href="/Jesus" onclick="closeMobileNav()">Jesus</a>
    <a href="/About" onclick="closeMobileNav()">About</a>
    <a href="/Events" onclick="closeMobileNav()">Events</a>
    <a href="/Sermons" onclick="closeMobileNav()">Sermons</a>
    <a href="/Prayer" onclick="closeMobileNav()">Prayer</a>
    <a href="/Location" onclick="closeMobileNav()">Visit</a>
    <a href="/Groups" onclick="closeMobileNav()">Groups</a>
    @if (!string.IsNullOrEmpty(church.SocialMedia.YouTube))
    {
        <a href="@church.SocialMedia.YouTube" target="_blank" rel="noopener" onclick="closeMobileNav()">Watch</a>
    }
</div>

<!-- FLOATING PILL NAV -->
<div class="nav-host" id="navHost">
    <div class="nav-pill">
        <a href="/" class="nav-logo"><strong>New Bethel</strong> Missionary Baptist Church</a>
        <div class="nav-links">
            <a href="/Give" class="@(IsActive("/Give") ? "nav-active" : "")">Give</a>
            <a href="/Jesus" class="@(IsActive("/Jesus") ? "nav-active" : "")">Jesus</a>
            <a href="/About" class="@(IsActive("/About") ? "nav-active" : "")">About</a>
            <a href="/Events" class="@(IsEvents ? "nav-active" : "")">Events</a>
            <a href="/Sermons" class="@(IsActive("/Sermons") ? "nav-active" : "")">Sermons</a>
            <a href="/Prayer" class="@(IsActive("/Prayer") ? "nav-active" : "")">Prayer</a>
            <a href="/Location" class="@(IsActive("/Location") ? "nav-active" : "")">Visit</a>
            @if (!string.IsNullOrEmpty(church.SocialMedia.YouTube))
            {
                <a href="@church.SocialMedia.YouTube" target="_blank" rel="noopener">Watch</a>
            }
        </div>
        <div class="nav-hamburger" id="hamburger" onclick="toggleMobileNav()">
            <span></span><span></span><span></span>
        </div>
    </div>
</div>

<main id="main-content" role="main">
    @RenderBody()
</main>

<!-- EDIFY DARK FOOTER -->
<footer class="edify-footer">
    <div class="edify-footer-top">
        <div class="edify-footer-contact">
            @if (!string.IsNullOrEmpty(church.Phone))
            {
                <a href="tel:@church.Phone.Replace(" ","").Replace("(","").Replace(")","").Replace("-","")">📞 @church.Phone</a>
            }
            <span class="edify-footer-addr" style="font-size:11px; opacity:0.55;">Office hours: Mon–Fri, 9AM–4PM</span>
            @if (!string.IsNullOrEmpty(church.Email))
            {
                <a href="mailto:@church.Email">✉️ @church.Email</a>
            }
            @if (!string.IsNullOrEmpty(church.FullAddress))
            {
                <span class="edify-footer-addr">📍 @church.FullAddress</span>
            }
        </div>

        <div class="edify-footer-logo"><strong>New Bethel</strong> Missionary Baptist Church</div>

        <div class="edify-footer-nav">
            <span class="edify-footer-nav-label">navigation</span>
            @if (!string.IsNullOrEmpty(church.SocialMedia.YouTube))
            {
                <a href="@church.SocialMedia.YouTube" target="_blank" rel="noopener">watch</a>
            }
            <a href="/Give">give</a>
            <a href="/Jesus">jesus</a>
            <a href="/Events">events</a>
            <a href="/Sermons">sermons</a>
            <a href="/Prayer">prayer</a>
            <a href="/Location">visit</a>
            <a href="/Groups">groups</a>
            <a href="/About">about us</a>
        </div>
    </div>

    <div class="edify-footer-tagline-wrap">
        <p class="edify-footer-tagline">@(string.IsNullOrEmpty(church.Tagline) ? "Leading people to become fully devoted followers of Christ." : church.Tagline)</p>
    </div>

    <div class="edify-footer-bottom">
        <span>© @DateTime.Now.Year, NEW BETHEL MISSIONARY BAPTIST CHURCH · <a href="https://www.pexels.com" target="_blank" rel="noopener noreferrer" style="color: inherit; text-decoration: underline; text-underline-offset: 3px;">Photos from Pexels</a></span>
        <div class="edify-footer-socials">
            @if (!string.IsNullOrEmpty(church.SocialMedia.YouTube))
            {
                <a href="@church.SocialMedia.YouTube" target="_blank" rel="noopener" aria-label="YouTube">
                    <svg viewBox="0 0 24 24" fill="white" aria-hidden="true"><path d="M21.593 7.203a2.506 2.506 0 0 0-1.762-1.766C18.265 5.007 12 5 12 5s-6.264-.007-7.831.404a2.56 2.56 0 0 0-1.766 1.778c-.413 1.566-.417 4.814-.417 4.814s-.004 3.264.406 4.814c.23.857.905 1.534 1.763 1.765 1.582.43 7.83.437 7.83.437s6.265.007 7.831-.403a2.515 2.515 0 0 0 1.767-1.763c.414-1.565.417-4.812.417-4.812s.02-3.265-.407-4.831zM9.996 15.005l.005-6 5.207 3.005-5.212 2.995z"/></svg>
                </a>
            }
            @if (!string.IsNullOrEmpty(church.SocialMedia.Instagram))
            {
                <a href="@church.SocialMedia.Instagram" target="_blank" rel="noopener" aria-label="Instagram">
                    <svg viewBox="0 0 24 24" fill="white" aria-hidden="true"><path d="M20.947 8.305a6.53 6.53 0 0 0-.419-2.216 4.61 4.61 0 0 0-2.633-2.633 6.606 6.606 0 0 0-2.186-.42c-.962-.043-1.267-.055-3.709-.055s-2.755 0-3.71.055a6.606 6.606 0 0 0-2.185.42 4.607 4.607 0 0 0-2.633 2.633 6.554 6.554 0 0 0-.419 2.185c-.043.963-.056 1.268-.056 3.71s0 2.754.056 3.71c.015.748.156 1.486.419 2.187a4.61 4.61 0 0 0 2.634 2.632 6.584 6.584 0 0 0 2.185.45c.963.043 1.268.056 3.71.056s2.755 0 3.71-.056a6.59 6.59 0 0 0 2.186-.419 4.615 4.615 0 0 0 2.633-2.633c.263-.7.404-1.438.419-2.187.043-.962.056-1.267.056-3.71-.002-2.442-.002-2.752-.058-3.709zm-8.953 8.297c-2.554 0-4.623-2.069-4.623-4.623s2.069-4.623 4.623-4.623a4.623 4.623 0 0 1 0 9.246zm4.807-8.339a1.077 1.077 0 0 1-1.078-1.078 1.077 1.077 0 1 1 2.155 0c0 .596-.482 1.078-1.077 1.078z"/><circle cx="11.994" cy="11.979" r="3.003"/></svg>
                </a>
            }
        </div>
    </div>
</footer>

<!-- GIVE MODAL -->
<div id="giveModal" class="give-modal" role="dialog" aria-modal="true" aria-labelledby="giveModalTitle" hidden>
    <div class="give-modal-overlay" onclick="closeGiveModal()"></div>
    <div class="give-modal-card">
        <div class="give-modal-top-bar"></div>
        <button class="give-modal-close" onclick="closeGiveModal()" aria-label="Close give modal">&#215;</button>
        <div class="give-modal-inner">
            <div class="give-modal-icon">&#128155;</div>
            <h2 id="giveModalTitle" class="give-modal-title">Support The Ministry</h2>
            <p class="give-modal-sub">Your generosity fuels the Gospel mission at New Bethel — feeding the hungry, reaching the streets, and sharing the love of Christ.</p>
            <div class="give-modal-amounts">
                <button class="give-modal-amt" onclick="selectGiveAmt(this)">$10</button>
                <button class="give-modal-amt gm-active" onclick="selectGiveAmt(this)">$25</button>
                <button class="give-modal-amt" onclick="selectGiveAmt(this)">$50</button>
                <button class="give-modal-amt" onclick="selectGiveAmt(this)">$100</button>
            </div>
            <p class="give-modal-hint">Select an amount or give any amount in Cash App</p>
            <div class="give-modal-cashtag">
                <div class="give-cashapp-circle">&#36;</div>
                <div>
                    <div class="give-modal-cashtag-label">Pastor&rsquo;s Cash App</div>
                    <div class="give-modal-cashtag-val">@church.CashAppTag</div>
                </div>
            </div>
            <a href="https://cash.app/@church.CashAppTag" target="_blank" rel="noopener noreferrer" class="give-modal-open-btn" onclick="closeGiveModal()">
                Open Cash App &rarr;
            </a>
            <p class="give-modal-note">&#128274; Secure payment via Cash App &bull; @church.CashAppTag</p>
            <div class="give-modal-divider"></div>
            <p class="give-modal-verse">&ldquo;Each of you should give what you have decided in your heart to give, not reluctantly or under compulsion, for God loves a cheerful giver.&rdquo; &mdash; 2 Corinthians 9:7</p>
        </div>
    </div>
</div>

<script src="~/lib/jquery/dist/jquery.min.js"></script>
<script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
<script src="~/js/site.js" asp-append-version="true"></script>
<script src="~/js/location-fallback.js" asp-append-version="true"></script>
<script>
    // Nav scroll shadow
    const navHost = document.getElementById('navHost');
    if (navHost) {
        window.addEventListener('scroll', () => navHost.classList.toggle('scrolled', window.scrollY > 20));
    }

    // Mobile nav
    function toggleMobileNav() { document.getElementById('mobileNav').classList.toggle('open'); }
    function closeMobileNav() { document.getElementById('mobileNav').classList.remove('open'); }

    // Give modal
    function openGiveModal() {
        var m = document.getElementById('giveModal');
        if (m) { m.hidden = false; document.body.style.overflow = 'hidden'; }
    }
    function closeGiveModal() {
        var m = document.getElementById('giveModal');
        if (m) { m.hidden = true; document.body.style.overflow = ''; }
    }
    function selectGiveAmt(btn) {
        document.querySelectorAll('.give-modal-amt').forEach(function(b) { b.classList.remove('gm-active'); });
        btn.classList.add('gm-active');
    }
    document.addEventListener('keydown', function(e) { if (e.key === 'Escape') closeGiveModal(); });
</script>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
