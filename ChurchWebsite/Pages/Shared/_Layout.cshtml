@* ============================================
   SHARED LAYOUT - Wraps all pages
   USE CASE: Nav, footer, scripts shared site-wide
   LOCATION: Every page (via _ViewStart.cshtml)
   ============================================ *@
@using ChurchWebsite.Models
@using Microsoft.Extensions.Options
@inject IOptions<ChurchSettings> ChurchOptions
@inject IHttpContextAccessor HttpContextAccessor
@{
    var church = ChurchOptions.Value;
    var path = HttpContextAccessor.HttpContext?.Request.Path.Value ?? "";
    bool IsActive(string page) => (page == "/" && (path == "/" || path == "")) || (page != "/" && path.StartsWith(page, StringComparison.OrdinalIgnoreCase));
    bool ShowMultilineBrand() => !IsActive("/About");
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - @church.NameText</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,600;0,700;0,900;1,400;1,600&family=DM+Sans:ital,wght@0,300;0,400;0,500;0,600;1,300&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/site-mobile.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/ChurchWebsite.styles.css" asp-append-version="true" />
    @await RenderSectionAsync("Head", required: false)
</head>
<body class="@((path == "/" || path == "") ? "home-page" : "")">
    <a href="#main-content" class="visually-hidden-focusable btn btn-primary btn-sm position-fixed top-0 start-0 m-2" style="z-index: 9999;">Skip to main content</a>

    <!-- GLOBAL CONSTELLATION CANVAS -->
    <canvas id="globalConstellation" style="position:fixed;inset:0;pointer-events:none;z-index:0;opacity:.55" aria-hidden="true"></canvas>

    <header>
        <nav class="navbar navbar-expand-lg navbar-light border-bottom box-shadow @((path != "/" && path != "") ? "bg-white" : "")" id="mainNav">
            <div class="container-fluid px-0">
                @if (ShowMultilineBrand())
                {
                    <a class="navbar-brand fw-bold archivo-black navbar-brand-multiline" asp-page="/Index" aria-label="@church.NameText">
                        @if (church.Name.Count > 0)
                        {
                            @for (var i = 0; i < church.Name.Count; i++)
                            {
                                <span>@church.Name[i]</span>
                            }
                        }
                        else
                        {
                            <span>N.B.M.B.C.</span>
                        }
                    </a>
                }
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarMain" aria-controls="navbarMain" aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="collapse navbar-collapse" id="navbarMain">
                    <ul class="navbar-nav ms-auto align-items-lg-center">
                        <li class="nav-item">
                            <a class="nav-link @(IsActive("/") && path == "/" ? "active" : "")" asp-page="/Index">Home</a>
                        </li>
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle @(IsActive("/About") || IsActive("/Location") ? "active" : "")" href="#" id="navAbout" data-bs-toggle="dropdown" aria-expanded="false">About</a>
                            <ul class="dropdown-menu" aria-labelledby="navAbout">
                                <li><a class="dropdown-item" asp-page="/About">Who We Are?</a></li>
                                @if (IsActive("/Location"))
                                {
                                    <li><span class="dropdown-item location-current-item" aria-current="page">Location</span></li>
                                }
                                else
                                {
                                    <li><a class="dropdown-item" asp-page="/Location">Location</a></li>
                                }
                                <li><hr class="dropdown-divider" /></li>
                                <li><a class="dropdown-item" asp-page="/About">Contact Us</a></li>
                            </ul>
                        </li>
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle @(IsActive("/Groups") || IsActive("/Events") ? "active" : "")" href="#" id="navNextSteps" data-bs-toggle="dropdown" aria-expanded="false">Next Steps</a>
                            <ul class="dropdown-menu" aria-labelledby="navNextSteps">
                                <li><a class="dropdown-item" asp-page="/Events/Index">Events</a></li>
                                <li><a class="dropdown-item" asp-page="/Groups/Index">Groups</a></li>
                                <li><a class="dropdown-item" asp-page="/Prayer">Request Prayer</a></li>
                            </ul>
                        </li>
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle @(IsActive("/Sermons") || IsActive("/Live") ? "active" : "")" href="#" id="navMedia" data-bs-toggle="dropdown" aria-expanded="false">Media</a>
                            <ul class="dropdown-menu" aria-labelledby="navMedia">
                                <li><a class="dropdown-item" asp-page="/Sermons/Index">Sermons</a></li>
                                <li><a class="dropdown-item" asp-page="/Live">Watch Live</a></li>
                            </ul>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link @(IsActive("/Prayer") ? "active" : "")" asp-page="/Prayer">Request Prayer</a>
                        </li>
                        <li class="nav-item ms-lg-2 mt-2 mt-lg-0">
                            <button class="nav-give-btn" onclick="openGiveModal()" aria-label="Give to New Bethel via Cash App">
                                &#9829; Give
                            </button>
                        </li>
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <main id="main-content" role="main">
        @RenderBody()
    </main>

    <footer class="global-footer" role="contentinfo">
        <div class="global-footer-inner">
            <div style="display:flex;flex-wrap:wrap;align-items:center;justify-content:center;gap:1.5rem;margin-bottom:.4rem">
                <a asp-page="/Index" style="color:rgba(255,255,255,.65);text-decoration:none;font-size:.72rem;letter-spacing:.08em;text-transform:uppercase;transition:color .2s" onmouseover="this.style.color='#C9A84C'" onmouseout="this.style.color='rgba(255,255,255,.65)'">Home</a>
                <a asp-page="/About" style="color:rgba(255,255,255,.65);text-decoration:none;font-size:.72rem;letter-spacing:.08em;text-transform:uppercase;transition:color .2s" onmouseover="this.style.color='#C9A84C'" onmouseout="this.style.color='rgba(255,255,255,.65)'">About</a>
                <a asp-page="/Events/Index" style="color:rgba(255,255,255,.65);text-decoration:none;font-size:.72rem;letter-spacing:.08em;text-transform:uppercase;transition:color .2s" onmouseover="this.style.color='#C9A84C'" onmouseout="this.style.color='rgba(255,255,255,.65)'">Events</a>
                <a asp-page="/Sermons/Index" style="color:rgba(255,255,255,.65);text-decoration:none;font-size:.72rem;letter-spacing:.08em;text-transform:uppercase;transition:color .2s" onmouseover="this.style.color='#C9A84C'" onmouseout="this.style.color='rgba(255,255,255,.65)'">Sermons</a>
                <a asp-page="/Location" style="color:rgba(255,255,255,.65);text-decoration:none;font-size:.72rem;letter-spacing:.08em;text-transform:uppercase;transition:color .2s" onmouseover="this.style.color='#C9A84C'" onmouseout="this.style.color='rgba(255,255,255,.65)'">Location</a>
                <a asp-page="/Prayer" style="color:rgba(255,255,255,.65);text-decoration:none;font-size:.72rem;letter-spacing:.08em;text-transform:uppercase;transition:color .2s" onmouseover="this.style.color='#C9A84C'" onmouseout="this.style.color='rgba(255,255,255,.65)'">Prayer</a>
                <button onclick="openGiveModal()" style="background:none;border:none;color:rgba(201,168,76,.7);font-size:.72rem;letter-spacing:.08em;text-transform:uppercase;cursor:pointer;padding:0;font-family:inherit;transition:color .2s" onmouseover="this.style.color='#C9A84C'" onmouseout="this.style.color='rgba(201,168,76,.7)'">&#9829; Give</button>
            </div>
            Copyright &copy; 2025 New Bethel Missionary Baptist Church of Winter Haven. All Rights Reserved.
        </div>
    </footer>

    <!-- FLOATING GIVE BUTTON -->
    <button class="give-fab" onclick="openGiveModal()" aria-label="Give to New Bethel via Cash App">
        <span class="give-fab-icon">&#36;</span>
        <span class="give-fab-label">Give</span>
    </button>

    <!-- GIVE MODAL -->
    <div id="giveModal" class="give-modal" role="dialog" aria-modal="true" aria-labelledby="giveModalTitle" hidden>
        <div class="give-modal-overlay" onclick="closeGiveModal()"></div>
        <div class="give-modal-card">
            <div class="give-modal-top-bar"></div>
            <button class="give-modal-close" onclick="closeGiveModal()" aria-label="Close give modal">&#215;</button>
            <div class="give-modal-inner">
                <div class="give-modal-icon">&#128155;</div>
                <h2 id="giveModalTitle" class="give-modal-title">Support The Ministry</h2>
                <p class="give-modal-sub">Your generosity fuels the Gospel mission at New Bethel — feeding the hungry, reaching the streets, and sharing the love of Christ.</p>

                <div class="give-modal-amounts">
                    <button class="give-modal-amt" onclick="selectGiveAmt(this)">$10</button>
                    <button class="give-modal-amt gm-active" onclick="selectGiveAmt(this)">$25</button>
                    <button class="give-modal-amt" onclick="selectGiveAmt(this)">$50</button>
                    <button class="give-modal-amt" onclick="selectGiveAmt(this)">$100</button>
                </div>
                <p class="give-modal-hint">Select an amount or give any amount in Cash App</p>

                <div class="give-modal-cashtag">
                    <div class="give-cashapp-circle">&#36;</div>
                    <div>
                        <div class="give-modal-cashtag-label">Pastor&rsquo;s Cash App</div>
                        <div class="give-modal-cashtag-val">$blueboy78</div>
                    </div>
                </div>

                <a href="https://cash.app/$blueboy78" target="_blank" rel="noopener noreferrer" class="give-modal-open-btn" onclick="closeGiveModal()">
                    Open Cash App &rarr;
                </a>
                <p class="give-modal-note">&#128274; Secure payment via Cash App &bull; $blueboy78</p>

                <div class="give-modal-divider"></div>
                <p class="give-modal-verse">&ldquo;Each of you should give what you have decided in your heart to give, not reluctantly or under compulsion, for God loves a cheerful giver.&rdquo; &mdash; 2 Corinthians 9:7</p>
            </div>
        </div>
    </div>

    <script src="~/js/pages/layout.js" asp-append-version="true"></script>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script src="~/js/location-fallback.js" asp-append-version="true"></script>
    <script>
        function openGiveModal() {
            var m = document.getElementById('giveModal');
            if (m) { m.hidden = false; document.body.style.overflow = 'hidden'; }
        }
        function closeGiveModal() {
            var m = document.getElementById('giveModal');
            if (m) { m.hidden = true; document.body.style.overflow = ''; }
        }
        function selectGiveAmt(btn) {
            document.querySelectorAll('.give-modal-amt').forEach(function(b) { b.classList.remove('gm-active'); });
            btn.classList.add('gm-active');
        }
        document.addEventListener('keydown', function(e) { if (e.key === 'Escape') closeGiveModal(); });
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
