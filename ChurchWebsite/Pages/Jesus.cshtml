@page
@{
    Layout = "_Layout";
    ViewData["Title"] = "Jesus";
}

@section Head {
<meta name="description" content="Learn about who Jesus is, what He taught, and what it means to follow Him at New Bethel Missionary Baptist Church.">
<style>
/* ── TOKENS ── */
:root {
  --white: #ffffff;
  --bg: #ededed;
  --black: #000000;
  --accent: #2a967d;
  --gray: #949494;
  --gray-dark: #474747;
}
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
html { scroll-behavior: smooth; -webkit-font-smoothing: antialiased; }
body { font-family: 'Outfit', sans-serif; background: var(--bg); color: var(--black); overflow-x: hidden; }

/* ── HERO ── */
.jesus-hero {
  width: 100%; height: 75vh; min-height: 500px;
  display: flex; align-items: center; justify-content: center;
  position: relative; overflow: hidden;
  background: var(--bg);
}
.jesus-hero-img {
  position: absolute; inset: 0;
  width: 100%; height: 100%; object-fit: cover;
  will-change: transform;
}
.jesus-hero-ph {
  position: absolute; inset: 0;
  background: linear-gradient(160deg, #0d1a12 0%, #112218 50%, #0d1a12 100%);
  display: flex; align-items: center; justify-content: center;
  flex-direction: column; gap: 12px;
  font-size: 11px; letter-spacing: 3px; text-transform: uppercase;
  color: rgba(255,255,255,0.2);
}
.jesus-hero-text {
  position: relative; z-index: 2;
  text-align: center;
}
.jesus-hero-title {
  font-family: 'Judson', serif; font-style: italic;
  font-size: clamp(80px, 15vw, 240px);
  letter-spacing: -0.06em; line-height: 0.85em;
  color: var(--white);
  text-shadow: 0 0 50px rgba(0,0,0,0.5);
}
.jesus-hero-title strong { font-style: normal; font-weight: 700; }

/* ── WHITE LIFT ── */
.white-lift {
  position: relative; z-index: 3;
  margin-top: -60px;
  border-radius: 60px 60px 0 0;
  background: var(--white);
  box-shadow: 0 0 10px -5px var(--black);
  overflow: hidden;
}

/* ── SECTION ── */
.section-inner {
  width: 100%; max-width: 1000px;
  margin: 0 auto; padding: 0 40px;
}

/* ── INTRO ── */
.jesus-intro-wrap {
  padding: 120px 0 80px;
}
.jesus-intro-row {
  display: flex; align-items: flex-start; gap: 80px;
}
.jesus-intro-left { flex: 1.2 0 0; }
.jesus-intro-right { flex: 1 0 0; display: flex; flex-direction: column; gap: 20px; padding-top: 8px; }
.jesus-h2 {
  font-family: 'Judson', serif;
  font-size: clamp(32px, 5vw, 72px);
  letter-spacing: -0.04em; line-height: 0.95em;
  color: var(--black);
}
.jesus-body {
  font-family: 'Outfit', sans-serif; font-weight: 400;
  font-size: clamp(15px, 1.5vw, 19px);
  letter-spacing: -0.02em; line-height: 1.5em;
  color: var(--black);
}
.accent-text { color: var(--accent); }

/* ── FAQ / ACCORDION ── */
.faq-wrap {
  padding: 0 0 100px;
}
.faq-item {
  border-top: 1px solid rgba(0,0,0,0.12);
}
.faq-item:last-child { border-bottom: 1px solid rgba(0,0,0,0.12); }
.faq-trigger {
  width: 100%; display: flex; align-items: center; justify-content: space-between;
  gap: 20px;
  padding: 28px 0;
  background: none; border: none; cursor: pointer; text-align: left;
}
.faq-question {
  font-family: 'Outfit', sans-serif; font-weight: 400;
  font-size: clamp(18px, 2vw, 28px);
  letter-spacing: -0.03em; line-height: 1.1em;
  color: var(--black);
}
.faq-icon {
  width: 28px; height: 28px; flex-shrink: 0;
  border: 1.5px solid rgba(0,0,0,0.4); border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
  transition: transform 0.3s, background 0.3s, border-color 0.3s;
}
.faq-icon svg { transition: transform 0.3s; }
.faq-item.open .faq-icon { background: var(--black); border-color: var(--black); }
.faq-item.open .faq-icon svg { transform: rotate(45deg); }
.faq-icon svg line { stroke: var(--black); transition: stroke 0.3s; }
.faq-item.open .faq-icon svg line { stroke: var(--white); }
.faq-body {
  overflow: hidden; max-height: 0;
  transition: max-height 0.45s ease, padding 0.3s ease;
  padding: 0 0 0;
}
.faq-body-inner {
  font-family: 'Outfit', sans-serif; font-weight: 300;
  font-size: clamp(15px, 1.5vw, 18px);
  letter-spacing: -0.01em; line-height: 1.6em;
  color: var(--gray-dark);
  padding-bottom: 28px;
  max-width: 780px;
}
.faq-body-inner p + p { margin-top: 14px; }

/* ── JOIN CARDS ── */
.jesus-join-wrap {
  background: var(--bg);
  padding: 80px 0 140px;
}
.jesus-join-heading {
  font-family: 'Judson', serif; font-style: italic;
  font-size: clamp(24px, 3vw, 48px);
  letter-spacing: -0.04em; line-height: 1em;
  color: var(--black); margin-bottom: 50px;
}
.jesus-join-heading strong { font-style: normal; }
.jesus-cards-row {
  display: grid; grid-template-columns: 1fr 1fr; gap: 25px;
}
.jesus-card {
  border-radius: 20px; overflow: hidden;
  display: flex; flex-direction: column;
  background: var(--white);
  box-shadow: 0 0 8px -4px rgba(0,0,0,0.35);
  transition: transform 0.3s, box-shadow 0.3s;
}
.jesus-card:hover { transform: translateY(-4px); box-shadow: 0 8px 30px -8px rgba(0,0,0,0.25); }
.jesus-card-img {
  aspect-ratio: 1.6; overflow: hidden; background: #ddd;
  position: relative;
}
.jesus-card-img img { width: 100%; height: 100%; object-fit: cover; display: block; }
.jesus-card-img-ph {
  width: 100%; height: 100%; min-height: 180px;
  display: flex; align-items: center; justify-content: center;
  color: rgba(0,0,0,0.2); font-size: 10px; letter-spacing: 2px; text-transform: uppercase;
}
.jesus-card-body {
  padding: 28px 28px 32px;
  display: flex; flex-direction: column; gap: 12px; flex: 1;
}
.jesus-card-label {
  font-size: 11px; font-weight: 500; letter-spacing: 0.12em; text-transform: uppercase;
  color: var(--accent);
}
.jesus-card-title {
  font-family: 'Judson', serif;
  font-size: clamp(22px, 2.5vw, 36px);
  letter-spacing: -0.03em; line-height: 1em;
  color: var(--black);
}
.jesus-card-desc {
  font-size: clamp(14px, 1.3vw, 16px);
  letter-spacing: -0.01em; line-height: 1.5em;
  color: var(--gray-dark); flex: 1;
}
.jesus-card-link {
  display: inline-flex; align-items: center; gap: 8px;
  font-size: 13px; font-weight: 500; letter-spacing: 0.08em; text-transform: uppercase;
  color: var(--black); text-decoration: none;
  margin-top: 8px;
  position: relative; padding-bottom: 3px; width: fit-content;
}
.jesus-card-link::after {
  content: ''; position: absolute; bottom: 0; left: 0; right: 100%;
  height: 1px; background: var(--black); transition: right 0.3s ease;
}
.jesus-card-link:hover::after { right: 0; }

/* ── REVEAL ── */
.reveal { opacity: 0; transform: translateY(50px); transition: opacity 0.8s ease, transform 0.8s ease; }
.reveal.visible { opacity: 1; transform: translateY(0); }
.d1 { transition-delay: 0.15s; }
.d2 { transition-delay: 0.3s; }

/* ── RESPONSIVE ── */
@@media (max-width: 900px) {
  .section-inner { padding: 0 25px; }
  .jesus-intro-row { flex-direction: column; gap: 30px; }
  .jesus-cards-row { grid-template-columns: 1fr; }
}
@@media (max-width: 600px) {
  .white-lift { border-radius: 30px 30px 0 0; }
  .jesus-intro-wrap { padding: 80px 0 50px; }
  .faq-trigger { padding: 20px 0; }
}
</style>
}

<!-- HERO -->
<div class="jesus-hero">
  @if (ChurchPhotos.Get("JesusHero") is { } jh)
  {
    <img class="jesus-hero-img" src="@jh.ImageUrl" alt="@jh.AltText" loading="eager" decoding="async" />
  }
  else
  {
    <div class="jesus-hero-ph">
      <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><path d="M21 15l-5-5L5 21"/></svg>
      Replace with hero photo
    </div>
  }
  <div class="jesus-hero-text">
    <h1 class="jesus-hero-title"><strong>Jesus</strong></h1>
  </div>
</div>

<!-- WHITE LIFT -->
<div class="white-lift">

  <!-- INTRO -->
  <div class="jesus-intro-wrap">
    <div class="section-inner">
      <div class="jesus-intro-row reveal">
        <div class="jesus-intro-left">
          <h2 class="jesus-h2">We're all about <span class="accent-text">Jesus.</span></h2>
        </div>
        <div class="jesus-intro-right">
          <p class="jesus-body">At New Bethel, everything we do centers on the person of Jesus Christ. We believe He is the Son of God — fully human and fully divine — who came to earth, lived a sinless life, died on the cross for our sins, and rose again on the third day.</p>
          <p class="jesus-body">Whether you're exploring faith for the first time or have been walking with Christ for years, we'd love to journey with you.</p>
        </div>
      </div>
    </div>
  </div>

  <!-- FAQ ACCORDION -->
  <div class="faq-wrap">
    <div class="section-inner">

      <div class="faq-item reveal">
        <button class="faq-trigger" aria-expanded="false">
          <span class="faq-question">The life of Jesus</span>
          <span class="faq-icon" aria-hidden="true">
            <svg width="14" height="14" viewBox="0 0 14 14" fill="none">
              <line x1="7" y1="1" x2="7" y2="13" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
              <line x1="1" y1="7" x2="13" y2="7" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
            </svg>
          </span>
        </button>
        <div class="faq-body">
          <div class="faq-body-inner">
            <p>Jesus was born in Bethlehem over 2,000 years ago to a virgin named Mary. He grew up in Nazareth, was baptized by John the Baptist, and spent about three years teaching, healing, and proclaiming the Kingdom of God.</p>
            <p>He performed countless miracles — healing the sick, raising the dead, and demonstrating His authority over nature. He called twelve disciples and poured His life into them, modeling what it means to love God and serve others.</p>
          </div>
        </div>
      </div>

      <div class="faq-item reveal d1">
        <button class="faq-trigger" aria-expanded="false">
          <span class="faq-question">The message of Jesus</span>
          <span class="faq-icon" aria-hidden="true">
            <svg width="14" height="14" viewBox="0 0 14 14" fill="none">
              <line x1="7" y1="1" x2="7" y2="13" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
              <line x1="1" y1="7" x2="13" y2="7" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
            </svg>
          </span>
        </button>
        <div class="faq-body">
          <div class="faq-body-inner">
            <p>Jesus proclaimed the Good News of the Kingdom of God — that through Him, humanity could be reconciled to God and experience life as it was always meant to be.</p>
            <p>He summarized the entire law with two commands: love God with everything you have, and love your neighbor as yourself. His teachings on grace, forgiveness, justice, and mercy continue to transform lives around the world today.</p>
          </div>
        </div>
      </div>

      <div class="faq-item reveal d2">
        <button class="faq-trigger" aria-expanded="false">
          <span class="faq-question">Jesus' death and resurrection</span>
          <span class="faq-icon" aria-hidden="true">
            <svg width="14" height="14" viewBox="0 0 14 14" fill="none">
              <line x1="7" y1="1" x2="7" y2="13" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
              <line x1="1" y1="7" x2="13" y2="7" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
            </svg>
          </span>
        </button>
        <div class="faq-body">
          <div class="faq-body-inner">
            <p>Jesus was crucified on a cross — not because He did anything wrong, but because He willingly took the punishment our sin deserves. His death is the ultimate act of love and the foundation of our salvation.</p>
            <p>Three days later, He rose from the dead. The resurrection is the cornerstone of the Christian faith. It confirms that Jesus is who He said He is, that sin and death have been defeated, and that new life is available to all who believe.</p>
          </div>
        </div>
      </div>

      <div class="faq-item reveal">
        <button class="faq-trigger" aria-expanded="false">
          <span class="faq-question">Following Jesus</span>
          <span class="faq-icon" aria-hidden="true">
            <svg width="14" height="14" viewBox="0 0 14 14" fill="none">
              <line x1="7" y1="1" x2="7" y2="13" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
              <line x1="1" y1="7" x2="13" y2="7" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
            </svg>
          </span>
        </button>
        <div class="faq-body">
          <div class="faq-body-inner">
            <p>Following Jesus is a daily, ongoing relationship — not just a one-time decision. It means trusting Him with your whole life, reading His word, praying, and being part of a community of believers who encourage one another.</p>
            <p>At New Bethel, we walk this journey together. We believe the Church is meant to be a family where everyone belongs, grows, and is sent out to make a difference in the world.</p>
          </div>
        </div>
      </div>

      <div class="faq-item reveal d1">
        <button class="faq-trigger" aria-expanded="false">
          <span class="faq-question">Where do I start?</span>
          <span class="faq-icon" aria-hidden="true">
            <svg width="14" height="14" viewBox="0 0 14 14" fill="none">
              <line x1="7" y1="1" x2="7" y2="13" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
              <line x1="1" y1="7" x2="13" y2="7" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
            </svg>
          </span>
        </button>
        <div class="faq-body">
          <div class="faq-body-inner">
            <p>The best place to start is simply showing up. Come to one of our Sunday services, meet the family, and hear the message for yourself. No matter where you are in your faith journey, you are welcome here.</p>
            <p>If you want to take a next step — whether you'd like to be baptized, join a small group, or just have a conversation — reach out to us and we'd love to connect with you personally.</p>
          </div>
        </div>
      </div>

    </div>
  </div>

</div><!-- end white-lift -->

<!-- JOIN US CARDS -->
<div class="jesus-join-wrap">
  <div class="section-inner">
    <h2 class="jesus-join-heading reveal"><strong>Take a next step.</strong></h2>
    <div class="jesus-cards-row">

      <a href="/Events" class="jesus-card reveal" style="text-decoration:none; color:inherit;">
        <div class="jesus-card-img">
          @if (ChurchPhotos.Get("JesusCardEvents") is { } je)
          {
            <partial name="_ChurchPexelsImg" model="je" />
          }
          else
          {
            <div class="jesus-card-img-ph">Add photo</div>
          }
        </div>
        <div class="jesus-card-body">
          <span class="jesus-card-label">In person</span>
          <h3 class="jesus-card-title">Upcoming Events</h3>
          <p class="jesus-card-desc">Join us for Sunday worship or one of our community events. There's a place for you here.</p>
          <span class="jesus-card-link">
            See events
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="square"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </span>
        </div>
      </a>

      <a href="https://www.youtube.com/@@NewBethelMissionaryBaptist" target="_blank" rel="noopener" class="jesus-card reveal d1" style="text-decoration:none; color:inherit;">
        <div class="jesus-card-img">
          @if (ChurchPhotos.Get("JesusCardWatch") is { } jw)
          {
            <partial name="_ChurchPexelsImg" model="jw" />
          }
          else
          {
            <div class="jesus-card-img-ph">Add photo</div>
          }
        </div>
        <div class="jesus-card-body">
          <span class="jesus-card-label">Online</span>
          <h3 class="jesus-card-title">Online Content</h3>
          <p class="jesus-card-desc">Watch sermons, messages, and more on our YouTube channel. Wherever you are, you can join us.</p>
          <span class="jesus-card-link">
            Watch now
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="square"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </span>
        </div>
      </a>

    </div>
  </div>
</div>

@section Scripts {
<script>
  // Parallax hero
  window.addEventListener('scroll', () => {
    const y = window.scrollY;
    const bg = document.querySelector('.jesus-hero-ph, .jesus-hero-img');
    if (bg) bg.style.transform = `translateY(${y * 0.3}px)`;
    const txt = document.querySelector('.jesus-hero-text');
    if (txt) txt.style.transform = `translateY(${y * 0.15}px)`;
  }, { passive: true });

  // Accordion
  document.querySelectorAll('.faq-trigger').forEach(trigger => {
    trigger.addEventListener('click', () => {
      const item = trigger.closest('.faq-item');
      const body = item.querySelector('.faq-body');
      const isOpen = item.classList.contains('open');

      // Close all
      document.querySelectorAll('.faq-item.open').forEach(openItem => {
        openItem.classList.remove('open');
        openItem.querySelector('.faq-trigger').setAttribute('aria-expanded', 'false');
        openItem.querySelector('.faq-body').style.maxHeight = '0';
      });

      // Open clicked (if it was closed)
      if (!isOpen) {
        item.classList.add('open');
        trigger.setAttribute('aria-expanded', 'true');
        body.style.maxHeight = body.scrollHeight + 'px';
      }
    });
  });

  // Scroll reveal
  const obs = new IntersectionObserver(entries => {
    entries.forEach(e => { if (e.isIntersecting) e.target.classList.add('visible'); });
  }, { threshold: 0.1 });
  document.querySelectorAll('.reveal').forEach(el => obs.observe(el));
</script>
}
